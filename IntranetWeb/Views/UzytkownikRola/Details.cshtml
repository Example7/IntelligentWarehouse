@model Interfaces.Magazyn.Dtos.UzytkownikRolaDetailsDto

@{
    ViewData["Title"] = "Szczegóły roli użytkownika";
    var item = Model.UzytkownikRola;
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-person-gear"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Szczegóły roli użytkownika</h1>
                <p class="news-admin-header__subheading mb-0">Podgląd przypisania roli do konta systemowego.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">Role użyt.</span><strong class="news-admin-stat__value">@Model.LiczbaRolUzytkownika</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Użytk. w roli</span><strong class="news-admin-stat__value">@Model.LiczbaUzytkownikowWRoli</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@item.Id</strong></div>
        </div>
    </section>
    <section class="news-details-panel">
        <div class="news-details-panel__header">
            <h2 class="news-details-panel__title">@(item.Uzytkownik?.Email ?? "-")</h2>
            <div class="news-details-panel__actions">
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary"><i class="bi bi-pencil-square me-1"></i> Edytuj</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i> Usuń</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Lista</a>
            </div>
        </div>
        <div class="news-details-grid">
            <div class="news-details-item">
                <div class="news-details-item__label">Użytkownik</div>
                <div class="news-details-item__value">@(item.Uzytkownik?.Email ?? "-")</div>
                <div class="text-muted small">@(item.Uzytkownik?.Login ?? "-")</div>
            </div>
            <div class="news-details-item"><div class="news-details-item__label">Rola</div><div class="news-details-item__value">@(item.Rola?.Nazwa ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">User ID</div><div class="news-details-item__value">@item.IdUzytkownika</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Role ID</div><div class="news-details-item__value">@item.IdRoli</div></div>
        </div>
    </section>
</div>