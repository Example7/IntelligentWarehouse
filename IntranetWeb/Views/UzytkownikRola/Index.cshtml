@model Interfaces.Magazyn.Dtos.UzytkownikRolaIndexDto

@{
    ViewData["Title"] = "Role użytkowników";
    var items = Model.Items.ToList();
    var searchTerm = Model.SearchTerm ?? string.Empty;
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-person-gear"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Role użytkowników</h1>
                <p class="news-admin-header__subheading mb-0">Przypisania ról do kont systemowych.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">Przypisania</span><strong class="news-admin-stat__value">@items.Count</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Role</span><strong class="news-admin-stat__value">@items.Select(x => x.IdRoli).Distinct().Count()</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Użytkownicy</span><strong class="news-admin-stat__value">@items.Select(x => x.IdUzytkownika).Distinct().Count()</strong></div>
        </div>
    </section>

    <section class="news-admin-toolbar">
        <form method="get" class="news-admin-search" role="search" aria-label="Wyszukiwanie przypisań ról">
            <label for="userRoleSearchTerm" class="visually-hidden">Szukaj przypisań</label>
            <div class="news-admin-search__input-wrap">
                <i class="bi bi-search news-admin-search__icon"></i>
                <input id="userRoleSearchTerm" class="form-control news-admin-search__input" name="searchTerm" value="@searchTerm"
                       placeholder="Szukaj po użytkowniku lub roli..." />
            </div>
            <button class="btn btn-primary news-admin-search__submit" type="submit">Szukaj</button>
            @if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                <a class="btn btn-outline-secondary news-admin-search__clear" href="@Url.Action("Index")" title="Wyczyść filtr"><i class="bi bi-x-lg"></i></a>
            }
        </form>
        <a class="btn news-admin-toolbar__cta" asp-action="Create"><i class="bi bi-plus-circle"></i> Dodaj przypisanie</a>
    </section>

    @if (!items.Any())
    {
        <section class="news-admin-empty">
            <div class="news-admin-empty__icon"><i class="bi bi-person-gear"></i></div>
            <h2 class="h4 mb-2">Brak przypisań ról</h2>
            <p class="text-muted mb-3">Dodaj pierwsze przypisanie roli do użytkownika.</p>
            <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-circle me-1"></i> Dodaj przypisanie</a>
        </section>
    }
    else
    {
        <section class="entity-table-panel">
            <div class="entity-table-wrap">
                <table class="table table-hover align-middle mb-0 entity-table">
                    <thead>
                        <tr>
                            <th>Użytkownik</th>
                            <th>Rola</th>
                            <th>ID</th>
                            <th class="text-end">Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in items.OrderBy(x => x.Uzytkownik?.Email).ThenBy(x => x.Rola?.Nazwa))
                    {
                        <tr>
                            <td>
                                <div class="entity-cell-title">@(item.Uzytkownik?.Email ?? "-")</div>
                                <div class="entity-cell-subtitle">@(item.Uzytkownik?.Login ?? "-") | User ID: @item.IdUzytkownika</div>
                            </td>
                            <td>
                                <span class="entity-badge entity-badge--info">@(item.Rola?.Nazwa ?? "-")</span>
                            </td>
                            <td>@item.Id</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm" role="group" aria-label="Akcje dla przypisania @item.Id">
                                    <a class="btn btn-outline-warning" asp-action="Edit" asp-route-id="@item.Id" title="Edytuj"><i class="bi bi-pencil"></i></a>
                                    <a class="btn btn-outline-info" asp-action="Details" asp-route-id="@item.Id" title="Szczegóły"><i class="bi bi-eye"></i></a>
                                    <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id" title="Usuń"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>