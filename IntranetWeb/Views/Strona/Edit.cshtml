@model Data.Data.CMS.Strona

@{
    ViewData["Title"] = "Edytuj stronę";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon" aria-hidden="true"><i class="bi bi-pencil-square"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Edytuj stronę</h1>
                <p class="news-admin-header__subheading mb-0">Aktualizacja zawartości i ustawień strony CMS.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@Model.IdStrony</strong></div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Edycja strony</h2>
            <p class="text-muted mb-0">Zmień pola i zapisz aktualizację treści.</p>
        </div>

        <form asp-action="Edit" method="post" class="news-editor-form" novalidate>
            <input type="hidden" asp-for="IdStrony" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation" role="alert"></div>

            <div class="news-form-grid">
                <div class="news-form-field news-form-field--full">
                    <label asp-for="Nazwa" class="form-label news-form-label"></label>
                    <input asp-for="Nazwa" class="form-control news-form-control" />
                    <span asp-validation-for="Nazwa" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label asp-for="TytulLinku" class="form-label news-form-label"></label>
                    <input asp-for="TytulLinku" class="form-control news-form-control" />
                    <span asp-validation-for="TytulLinku" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label asp-for="Tresc" class="form-label news-form-label"></label>
                    <textarea asp-for="Tresc" class="form-control news-form-control news-form-control--textarea" rows="10"></textarea>
                    <span asp-validation-for="Tresc" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--compact">
                    <label asp-for="Pozycja" class="form-label news-form-label"></label>
                    <input asp-for="Pozycja" class="form-control news-form-control" type="number" min="0" />
                    <span asp-validation-for="Pozycja" class="text-danger small"></span>
                </div>
            </div>

            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary"><i class="bi bi-check2-circle"></i> Zapisz zmiany</button>
                <a asp-action="Details" asp-route-id="@Model.IdStrony" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i> Anuluj</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
