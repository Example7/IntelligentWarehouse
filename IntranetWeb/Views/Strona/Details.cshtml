@model Interfaces.CMS.Dtos.StronaDetailsDto

@{
    ViewData["Title"] = "Szczegóły strony";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon" aria-hidden="true"><i class="bi bi-file-earmark-text"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Szczegóły strony</h1>
                <p class="news-admin-header__subheading mb-0">Podgląd danych strony CMS i szybkie akcje administracyjne.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@Model.IdStrony</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Pozycja</span><strong class="news-admin-stat__value">@Model.Pozycja</strong></div>
        </div>
    </section>

    <section class="news-details-panel">
        <div class="news-details-panel__header">
            <h2 class="news-details-panel__title">@Model.Nazwa</h2>
            <div class="news-details-panel__actions">
                <a asp-action="Edit" asp-route-id="@Model.IdStrony" class="btn btn-primary"><i class="bi bi-pencil-square me-1"></i> Edytuj</a>
                <a asp-action="Delete" asp-route-id="@Model.IdStrony" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i> Usuń</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Lista</a>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item">
                <div class="news-details-item__label">Tytuł odnośnika</div>
                <div class="news-details-item__value">@Model.TytulLinku</div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Nazwa strony</div>
                <div class="news-details-item__value">@Model.Nazwa</div>
            </div>
            <div class="news-details-item news-details-item--full">
                <div class="news-details-item__label">Treść strony</div>
                <div class="news-details-item__value news-details-item__value--content">@Model.Tresc</div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Pozycja wyświetlania</div>
                <div class="news-details-item__value">@Model.Pozycja</div>
            </div>
        </div>
    </section>
</div>
