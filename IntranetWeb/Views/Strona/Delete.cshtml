@model Data.Data.CMS.Strona

@{
    ViewData["Title"] = "Usuń stronę";
}

<div class="news-admin-page">
    <section class="news-admin-header news-admin-header--danger">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon news-admin-header__icon--danger" aria-hidden="true"><i class="bi bi-trash3"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Usuń stronę</h1>
                <p class="news-admin-header__subheading mb-0">Operacja jest nieodwracalna. Sprawdź dane przed usunięciem.</p>
            </div>
        </div>
    </section>

    <section class="news-delete-panel">
        <div class="news-delete-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>Potwierdzenie usunięcia</strong>
                <div>Za chwilę usuniesz stronę z systemu CMS.</div>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item">
                <div class="news-details-item__label">ID</div>
                <div class="news-details-item__value">@Model.IdStrony</div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">@Html.DisplayNameFor(m => m.Pozycja)</div>
                <div class="news-details-item__value">@Html.DisplayFor(m => m.Pozycja)</div>
            </div>
            <div class="news-details-item news-details-item--full">
                <div class="news-details-item__label">@Html.DisplayNameFor(m => m.Nazwa)</div>
                <div class="news-details-item__value">@Html.DisplayFor(m => m.Nazwa)</div>
            </div>
            <div class="news-details-item news-details-item--full">
                <div class="news-details-item__label">@Html.DisplayNameFor(m => m.TytulLinku)</div>
                <div class="news-details-item__value">@Html.DisplayFor(m => m.TytulLinku)</div>
            </div>
            <div class="news-details-item news-details-item--full">
                <div class="news-details-item__label">@Html.DisplayNameFor(m => m.Tresc)</div>
                <div class="news-details-item__value news-details-item__value--content">@Html.DisplayFor(m => m.Tresc)</div>
            </div>
        </div>

        <form asp-action="Delete" method="post" class="news-form-actions">
            <input type="hidden" asp-for="IdStrony" />
            <button type="submit" class="btn btn-danger news-form-actions__primary"><i class="bi bi-trash3-fill"></i> Usuń stronę</button>
            <a asp-action="Details" asp-route-id="@Model.IdStrony" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Anuluj</a>
        </form>
    </section>
</div>
