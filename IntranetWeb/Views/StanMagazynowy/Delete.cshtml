@model Data.Data.Magazyn.StanMagazynowy

@{
    ViewData["Title"] = "Usuń stan magazynowy";
    var jm = Model.Produkt?.DomyslnaJednostka?.Kod ?? "j.m.";
    var iloscText = Model.Ilosc.ToString("0.###");
    var iloscLabel = iloscText + " " + jm;
}

<div class="news-admin-page">
    <section class="news-admin-header news-admin-header--danger">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon news-admin-header__icon--danger"><i class="bi bi-trash3"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Usuń stan magazynowy</h1>
                <p class="news-admin-header__subheading mb-0">Potwierdź usunięcie pozycji stanu z lokalizacji.</p>
            </div>
        </div>
    </section>

    <section class="news-delete-panel">
        <div class="news-delete-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>Usunięcie stanu</strong>
                <div>Usunięcie tej pozycji usuwa bieżący stan produktu w wybranej lokalizacji. Upewnij się, że to zamierzona operacja.</div>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item">
                <div class="news-details-item__label">ID</div>
                <div class="news-details-item__value">@Model.IdStanu</div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Produkt</div>
                <div class="news-details-item__value">@(Model.Produkt?.Kod ?? "-")</div>
                @if (!string.IsNullOrWhiteSpace(Model.Produkt?.Nazwa))
                {
                    <div class="news-details-item__meta">@Model.Produkt.Nazwa</div>
                }
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Lokacja</div>
                <div class="news-details-item__value">@(Model.Lokacja?.Kod ?? "-")</div>
                <div class="news-details-item__meta">@(Model.Lokacja?.Magazyn?.Nazwa ?? "-")</div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Ilosc</div>
                <div class="news-details-item__value">@iloscLabel</div>
            </div>
        </div>

        <form asp-action="Delete" method="post" class="news-form-actions">
            <input type="hidden" asp-for="IdStanu" />
            <button type="submit" class="btn btn-danger news-form-actions__primary"><i class="bi bi-trash3-fill"></i> Usuń stan</button>
            <a asp-action="Details" asp-route-id="@Model.IdStanu" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Anuluj</a>
        </form>
    </section>
</div>
