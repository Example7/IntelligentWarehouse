@model Data.Data.Magazyn.StanMagazynowy

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>StanMagazynowy</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="IdProduktu" class="control-label"></label>
                <select asp-for="IdProduktu" class ="form-control" asp-items="ViewBag.IdProduktu"></select>
            </div>
            <div class="form-group">
                <label asp-for="IdLokacji" class="control-label"></label>
                <select asp-for="IdLokacji" class ="form-control" asp-items="ViewBag.IdLokacji"></select>
            </div>
            <div class="form-group">
                <label asp-for="Ilosc" class="control-label"></label>
                <input asp-for="Ilosc" class="form-control" />
