@model Data.Data.Magazyn.StanMagazynowy

@{
    ViewData["Title"] = "Szczegóły stanu magazynowego";
    var isAdmin = User?.IsInRole("Admin") ?? false;
    var jm = Model.Produkt?.DomyslnaJednostka?.Kod ?? "j.m.";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-stack"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Szczegóły stanu magazynowego</h1>
                <p class="news-admin-header__subheading mb-0">Podgląd pozycji stanu dla produktu i lokalizacji.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@Model.IdStanu</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Ilość</span><strong class="news-admin-stat__value">@Model.Ilosc.ToString("0.###") @jm</strong></div>
        </div>
    </section>

    <section class="news-details-panel">
        <div class="news-details-panel__header">
            <h2 class="news-details-panel__title">Stan produktu @(Model.Produkt?.Kod ?? "-")</h2>
            <div class="news-details-panel__actions">
                @if (isAdmin)
                {
                    <a asp-action="Edit" asp-route-id="@Model.IdStanu" class="btn btn-primary"><i class="bi bi-pencil-square me-1"></i> Edytuj</a>
                }
                @if (isAdmin)
                {
                <a asp-action="Delete" asp-route-id="@Model.IdStanu" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i> Usuń</a>
                }
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Lista</a>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item">
                <div class="news-details-item__label">Produkt</div>
                <div class="news-details-item__value">
                    <div class="entity-cell-title">@(Model.Produkt?.Kod ?? "-")</div>
                    <div class="entity-cell-subtitle">@(Model.Produkt?.Nazwa ?? "Brak nazwy")</div>
                    @if (Model.Produkt != null)
                    {
                        <div class="mt-2">
                            <a asp-controller="Produkt" asp-action="Details" asp-route-id="@Model.IdProduktu" class="btn btn-sm btn-outline-info"><i class="bi bi-box-seam me-1"></i> Szczegóły produktu</a>
                        </div>
                    }
                </div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Lokacja</div>
                <div class="news-details-item__value">
                    <div class="entity-cell-title">@(Model.Lokacja?.Kod ?? "-")</div>
                    <div class="entity-cell-subtitle">@(Model.Lokacja?.Magazyn?.Nazwa ?? "Brak magazynu")</div>
                    @if (Model.Lokacja != null)
                    {
                        <div class="mt-2">
                            <a asp-controller="Lokacja" asp-action="Details" asp-route-id="@Model.IdLokacji" class="btn btn-sm btn-outline-secondary"><i class="bi bi-geo-alt me-1"></i> Szczegóły lokacji</a>
                        </div>
                    }
                </div>
            </div>
            <div class="news-details-item"><div class="news-details-item__label">Ilość</div><div class="news-details-item__value">@Model.Ilosc.ToString("0.###") @jm</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Jednostka miary</div><div class="news-details-item__value">@jm</div></div>
        </div>
    </section>
</div>

