@model Data.Data.Magazyn.StanMagazynowy

@{
    ViewData["Title"] = "Szczegoly stanu magazynowego";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-stack"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Szczegoly stanu magazynowego</h1>
                <p class="news-admin-header__subheading mb-0">Podglad pozycji stanu dla produktu i lokalizacji.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@Model.IdStanu</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Ilosc</span><strong class="news-admin-stat__value">@Model.Ilosc</strong></div>
        </div>
    </section>

    <section class="news-details-panel">
        <div class="news-details-panel__header">
            <h2 class="news-details-panel__title">Stan produktu @(Model.Produkt?.Kod ?? "-")</h2>
            <div class="news-details-panel__actions">
                <a asp-action="Edit" asp-route-id="@Model.IdStanu" class="btn btn-primary"><i class="bi bi-pencil-square me-1"></i> Edytuj</a>
                <a asp-action="Delete" asp-route-id="@Model.IdStanu" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i> Usun</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Lista</a>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item"><div class="news-details-item__label">Produkt</div><div class="news-details-item__value">@(Model.Produkt?.Kod ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Lokacja</div><div class="news-details-item__value">@(Model.Lokacja?.Kod ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Ilosc</div><div class="news-details-item__value">@Model.Ilosc</div></div>
            <div class="news-details-item news-details-item--full">
                <div class="news-details-item__label">RowVersion</div>
                <div class="news-details-item__value entity-mono">@(Model.RowVersion is { Length: > 0 } ? Convert.ToBase64String(Model.RowVersion) : "-")</div>
            </div>
        </div>
    </section>
</div>
