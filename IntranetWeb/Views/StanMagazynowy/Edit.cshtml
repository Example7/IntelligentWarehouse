@model Interfaces.Magazyn.Dtos.StanMagazynowyFormDto

@{
    ViewData["Title"] = "Edytuj stan magazynowy";
    var currentJm = Model.CurrentProductUom ?? "j.m.";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-pencil-square"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Edytuj stan magazynowy</h1>
                <p class="news-admin-header__subheading mb-0">Aktualizacja produktu, lokalizacji lub ilości stanu.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@Model.StanMagazynowy.IdStanu</strong></div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Edycja stanu</h2>
            <p class="text-muted mb-0">Zmień powiązania i ilość.</p>
        </div>

        <form asp-action="Edit" method="post" class="news-editor-form" novalidate>
            <input type="hidden" asp-for="StanMagazynowy.IdStanu" />
            <input type="hidden" name="StanMagazynowy.RowVersion" value="@(Model.StanMagazynowy.RowVersion is { Length: > 0 } ? Convert.ToBase64String(Model.StanMagazynowy.RowVersion) : string.Empty)" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation" role="alert"></div>
            <div class="news-form-grid">
                <div class="news-form-field">
                    <label asp-for="StanMagazynowy.IdProduktu" class="form-label news-form-label"></label>
                    <select asp-for="StanMagazynowy.IdProduktu" class="form-select news-form-control">
                        <option value="">(wybierz produkt)</option>
                        @foreach (var item in Model.Produkty)
                        {
                            <option value="@item.Value" selected="@(item.Value == Model.StanMagazynowy.IdProduktu ? "selected" : null)">@item.Text</option>
                        }
                    </select>
                    <span asp-validation-for="StanMagazynowy.IdProduktu" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="StanMagazynowy.IdLokacji" class="form-label news-form-label"></label>
                    <select asp-for="StanMagazynowy.IdLokacji" class="form-select news-form-control">
                        <option value="">(wybierz lokacje)</option>
                        @foreach (var item in Model.Lokacje)
                        {
                            <option value="@item.Value" selected="@(item.Value == Model.StanMagazynowy.IdLokacji ? "selected" : null)">@item.Text</option>
                        }
                    </select>
                    <span asp-validation-for="StanMagazynowy.IdLokacji" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label asp-for="StanMagazynowy.Ilosc" class="form-label news-form-label"></label>
                    <input asp-for="StanMagazynowy.Ilosc"
                           asp-format="{0:0.###}"
                           type="number"
                           step="0.001"
                           min="0"
                           class="form-control news-form-control"
                           data-msg-min="Podaj wartość większa lub równa 0."
                           oninvalid="this.setCustomValidity('Podaj wartość większa lub równa 0.')"
                           oninput="this.setCustomValidity('')" />
                    <div class="small text-muted mt-1">
                        Jednostka dla wybranego produktu:
                        <span class="entity-badge entity-badge--muted" id="stockUomValue">@currentJm</span>
                    </div>
                    @if (Model.HasCapacityData)
                    {
                        <div class="stock-capacity-info mt-2">
                            <div class="stock-capacity-info__item">Rezerwacje aktywne: <strong>@Model.AktywneRezerwacjeQty.ToString("0.###")</strong></div>
                            <div class="stock-capacity-info__item">WZ Draft: <strong>@Model.DraftWzQty.ToString("0.###")</strong></div>
                            <div class="stock-capacity-info__item">Zajęte razem: <strong>@Model.ZajeteRazemQty.ToString("0.###")</strong></div>
                            <div class="stock-capacity-info__item @(Model.DostepnePoZapisieQty < 0 ? "stock-capacity-info__item--danger" : string.Empty)">
                                Dostępne po zapisie: <strong>@Model.DostepnePoZapisieQty.ToString("0.###")</strong>
                            </div>
                        </div>
                    }
                    <span asp-validation-for="StanMagazynowy.Ilosc" class="text-danger small"></span>
                </div>
            </div>
            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary"><i class="bi bi-check2-circle"></i> Zapisz zmiany</button>
                <a asp-action="Details" asp-route-id="@Model.StanMagazynowy.IdStanu" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i> Anuluj</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (function () {
            if (window.jQuery && $.validator && $.validator.messages) {
                $.validator.messages.min = "Podaj wartość większa lub równa {0}.";
                $.validator.messages.range = "Podaj wartość z zakresu od {0} do {1}.";
            }

            const productSelect = document.getElementById("StanMagazynowy_IdProduktu");
            const uomValue = document.getElementById("stockUomValue");
            const uomMap = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ProductUomMap));

            if (!productSelect || !uomValue) return;

            const updateUom = () => {
                const key = productSelect.value;
                uomValue.textContent = (uomMap && uomMap[key]) ? uomMap[key] : "j.m.";
            };

            productSelect.addEventListener("change", updateUom);
            updateUom();
        })();
    </script>
}
