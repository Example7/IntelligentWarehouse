@model Data.Data.Magazyn.StanMagazynowy

@{
    ViewData["Title"] = "Edytuj stan magazynowy";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-pencil-square"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Edytuj stan magazynowy</h1>
                <p class="news-admin-header__subheading mb-0">Aktualizacja produktu, lokalizacji lub ilosci stanu.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@Model.IdStanu</strong></div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Edycja stanu</h2>
            <p class="text-muted mb-0">Zmien powiazania i ilosc. RowVersion jest przekazywany do kontroli wspolbieznosci.</p>
        </div>

        <form asp-action="Edit" method="post" class="news-editor-form" novalidate>
            <input type="hidden" asp-for="IdStanu" />
            <input type="hidden" asp-for="RowVersion" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation" role="alert"></div>
            <div class="news-form-grid">
                <div class="news-form-field">
                    <label asp-for="IdProduktu" class="form-label news-form-label"></label>
                    <select asp-for="IdProduktu" class="form-select news-form-control" asp-items="ViewBag.IdProduktu">
                        <option value="">(wybierz produkt)</option>
                    </select>
                    <span asp-validation-for="IdProduktu" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="IdLokacji" class="form-label news-form-label"></label>
                    <select asp-for="IdLokacji" class="form-select news-form-control" asp-items="ViewBag.IdLokacji">
                        <option value="">(wybierz lokacje)</option>
                    </select>
                    <span asp-validation-for="IdLokacji" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label asp-for="Ilosc" class="form-label news-form-label"></label>
                    <input asp-for="Ilosc" class="form-control news-form-control" />
                    <span asp-validation-for="Ilosc" class="text-danger small"></span>
                </div>
            </div>
            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary"><i class="bi bi-check2-circle"></i> Zapisz zmiany</button>
                <a asp-action="Details" asp-route-id="@Model.IdStanu" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegoly</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i> Anuluj</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
