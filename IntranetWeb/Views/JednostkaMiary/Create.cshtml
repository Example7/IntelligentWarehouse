@model Data.Data.Magazyn.JednostkaMiary

@{
    ViewData["Title"] = "Dodaj jednostkę miary";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-plus-square"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Dodaj jednostkę miary</h1>
                <p class="news-admin-header__subheading mb-0">Utwórz nową jednostkę do wykorzystania w magazynie i kartotekach produktów.</p>
            </div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Dane jednostki</h2>
            <p class="text-muted mb-0">Wprowadź kod, nazwę i ustaw status aktywności.</p>
        </div>

        <form asp-action="Create" method="post" class="news-editor-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation" role="alert"></div>
            <div class="news-form-grid">
                <div class="news-form-field">
                    <label asp-for="Kod" class="form-label news-form-label"></label>
                    <input asp-for="Kod" class="form-control news-form-control" />
                    <span asp-validation-for="Kod" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="Nazwa" class="form-label news-form-label"></label>
                    <input asp-for="Nazwa" class="form-control news-form-control" />
                    <span asp-validation-for="Nazwa" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <div class="form-check form-switch mt-2">
                        <input class="form-check-input" asp-for="CzyAktywna" />
                        <label class="form-check-label news-form-label mb-0" asp-for="CzyAktywna"></label>
                    </div>
                    <span asp-validation-for="CzyAktywna" class="text-danger small"></span>
                </div>
            </div>

            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary"><i class="bi bi-check2-circle"></i> Zapisz jednostkę</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Wróć do listy</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
