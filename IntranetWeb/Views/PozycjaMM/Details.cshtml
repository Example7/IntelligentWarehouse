@model Interfaces.Magazyn.Dtos.PozycjaMMDetailsDto

@{
    ViewData["Title"] = "Szczegoly pozycji MM";
    var p = Model.Pozycja;
    var jm = p.Produkt?.DomyslnaJednostka?.Kod ?? "j.m.";
    var canEdit = Model.CzyDokumentDraft;
    var docStatus = p.Dokument?.Status ?? "-";
    var docStatusClass = string.Equals(docStatus, "Draft", StringComparison.OrdinalIgnoreCase) ? "entity-badge--warning" : string.Equals(docStatus, "Posted", StringComparison.OrdinalIgnoreCase) ? "entity-badge--success" : "entity-badge--muted";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-list-check"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Szczegoly pozycji MM</h1>
                <p class="news-admin-header__subheading mb-0">Podglad pozycji dokumentu przesuniecia z lokacjami Z i Do.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">Lp</span><strong class="news-admin-stat__value">@p.Lp</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Status MM</span><strong class="news-admin-stat__value">@docStatus</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@p.Id</strong></div>
        </div>
    </section>

    @if (TempData["PozycjaMMEditBlocked"] is string blocked && !string.IsNullOrWhiteSpace(blocked))
    {
        <div class="alert alert-warning mt-3"><i class="bi bi-exclamation-triangle me-1"></i>@blocked</div>
    }

    <section class="news-details-panel">
        <div class="news-details-panel__header">
            <h2 class="news-details-panel__title">Dokument @(p.Dokument?.Numer ?? "-") / pozycja @p.Lp</h2>
            <div class="news-details-panel__actions">
                @if (canEdit)
                {
                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-primary"><i class="bi bi-pencil-square me-1"></i> Edytuj</a>
                }
                else
                {
                    <button type="button" class="btn btn-outline-secondary" disabled title="Edycja tylko dla Draft"><i class="bi bi-pencil-square me-1"></i> Edytuj</button>
                }
                <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i> Usun</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Lista</a>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item">
                <div class="news-details-item__label">Dokument MM</div>
                <div class="news-details-item__value entity-mono">@(p.Dokument?.Numer ?? "-")</div>
                @if (p.Dokument != null)
                {
                    <div class="mt-2"><a class="btn btn-sm btn-outline-info" asp-controller="DokumentMM" asp-action="Details" asp-route-id="@p.Dokument.Id"><i class="bi bi-file-earmark-text me-1"></i>Szczegoly MM</a></div>
                }
            </div>
            <div class="news-details-item"><div class="news-details-item__label">Status dokumentu MM</div><div class="news-details-item__value"><span class="entity-badge @docStatusClass">@docStatus</span></div></div>
            <div class="news-details-item">
                <div class="news-details-item__label">Produkt</div>
                <div class="news-details-item__value">@(p.Produkt?.Kod ?? "-")</div>
                <div class="news-details-item__value news-details-item__value--content">@(p.Produkt?.Nazwa ?? "-")</div>
                @if (p.Produkt != null)
                {
                    <div class="mt-2"><a class="btn btn-sm btn-outline-info" asp-controller="Produkt" asp-action="Details" asp-route-id="@p.Produkt.IdProduktu"><i class="bi bi-box-seam me-1"></i>Szczegoly produktu</a></div>
                }
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Partia</div>
                <div class="news-details-item__value">@(p.Partia?.NumerPartii ?? "(brak)")</div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Z lokacji</div>
                <div class="news-details-item__value">@(p.LokacjaZ?.Kod ?? "-")</div>
                <div class="news-details-item__value news-details-item__value--content">@(p.LokacjaZ?.Magazyn?.Nazwa ?? "-")</div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Do lokacji</div>
                <div class="news-details-item__value">@(p.LokacjaDo?.Kod ?? "-")</div>
                <div class="news-details-item__value news-details-item__value--content">@(p.LokacjaDo?.Magazyn?.Nazwa ?? "-")</div>
            </div>
            <div class="news-details-item"><div class="news-details-item__label">Ilosc</div><div class="news-details-item__value">@p.Ilosc.ToString("0.###") @jm</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Jednostka miary</div><div class="news-details-item__value">@jm</div></div>
        </div>
    </section>
</div>
