@model Data.Data.Magazyn.UstawienieAplikacji

@{
    ViewData["Title"] = "Edytuj ustawienie aplikacji";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-pencil-square"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Edytuj ustawienie aplikacji</h1>
                <p class="news-admin-header__subheading mb-0">Zmień wartość i opis ustawienia konfiguracyjnego.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">Klucz</span><strong class="news-admin-stat__value">@Model.Klucz</strong></div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Edycja ustawienia</h2>
            <p class="text-muted mb-0">Klucz jest identyfikatorem rekordu i pozostaje niezmienny. Czas modyfikacji ustawia system.</p>
        </div>

        <form asp-action="Edit" method="post" class="news-editor-form" novalidate>
            <input type="hidden" asp-for="Klucz" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation" role="alert"></div>
            <div class="news-form-grid">
                <div class="news-form-field">
                    <label class="form-label news-form-label">Klucz</label>
                    <input class="form-control news-form-control entity-mono" value="@Model.Klucz" disabled />
                </div>
                <div class="news-form-field">
                    <label asp-for="ZmienilUserId" class="form-label news-form-label">Zmienił User ID (opcjonalnie)</label>
                    <input asp-for="ZmienilUserId" class="form-control news-form-control" type="number" min="1" />
                    <span asp-validation-for="ZmienilUserId" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label asp-for="Wartosc" class="form-label news-form-label">Wartość</label>
                    <textarea asp-for="Wartosc" class="form-control news-form-control news-form-control--textarea" rows="4"></textarea>
                    <span asp-validation-for="Wartosc" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label asp-for="Opis" class="form-label news-form-label">Opis (opcjonalnie)</label>
                    <textarea asp-for="Opis" class="form-control news-form-control news-form-control--textarea" rows="3"></textarea>
                    <span asp-validation-for="Opis" class="text-danger small"></span>
                </div>
            </div>
            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary"><i class="bi bi-check2-circle"></i> Zapisz zmiany</button>
                <a asp-action="Details" asp-route-id="@Model.Klucz" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i> Anuluj</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}