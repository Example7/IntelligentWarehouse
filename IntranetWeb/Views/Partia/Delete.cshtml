@model Data.Data.Magazyn.Partia

@{
    ViewData["Title"] = "Usuń partie";
}

<div class="news-admin-page">
    <section class="news-admin-header news-admin-header--danger">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon news-admin-header__icon--danger"><i class="bi bi-trash3"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Usuń partie</h1>
                <p class="news-admin-header__subheading mb-0">Potwierdź usunięcie partii produktu.</p>
            </div>
        </div>
    </section>

    <section class="news-delete-panel">
        <div class="news-delete-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>Usunięcie partii</strong>
                <div>Partia może być powiązana ze stanem magazynowym i dokumentami ruchu.</div>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item"><div class="news-details-item__label">Numer partii</div><div class="news-details-item__value entity-mono">@Model.NumerPartii</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Produkt</div><div class="news-details-item__value">@(Model.Produkt?.Nazwa ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Kod produktu</div><div class="news-details-item__value entity-mono">@(Model.Produkt?.Kod ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Dostawca</div><div class="news-details-item__value">@(Model.Dostawca?.Nazwa ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Data produkcji</div><div class="news-details-item__value">@(Model.DataProdukcji?.ToString("yyyy-MM-dd") ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Data ważności</div><div class="news-details-item__value">@(Model.DataWaznosci?.ToString("yyyy-MM-dd") ?? "-")</div></div>
        </div>

        <form asp-action="Delete" method="post" class="news-form-actions">
            <input type="hidden" asp-for="IdPartii" />
            <button type="submit" class="btn btn-danger news-form-actions__primary"><i class="bi bi-trash3-fill"></i> Usuń partie</button>
            <a asp-action="Details" asp-route-id="@Model.IdPartii" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Anuluj</a>
        </form>
    </section>
</div>
