@model Interfaces.Magazyn.Dtos.RuchMagazynowyIndexDto

@{
    ViewData["Title"] = "Ruchy magazynowe";
    var items = Model.Items.ToList();
    var searchTerm = Model.SearchTerm ?? string.Empty;
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-arrow-left-right"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Ruchy magazynowe</h1>
                <p class="news-admin-header__subheading mb-0">Historia operacji magazynowych: przyjęcia, wydania, przesunięcia i korekty.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">Łacznie</span><strong class="news-admin-stat__value">@items.Count</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Typow</span><strong class="news-admin-stat__value">@items.Select(x => x.Typ).Distinct().Count()</strong></div>
        </div>
    </section>

    <section class="news-admin-toolbar">
        <form method="get" class="news-admin-search" role="search" aria-label="Wyszukiwanie ruchow magazynowych">
            <label for="movementSearchTerm" class="visually-hidden">Szukaj ruchow magazynowych</label>
            <div class="news-admin-search__input-wrap">
                <i class="bi bi-search news-admin-search__icon"></i>
                <input id="movementSearchTerm" class="form-control news-admin-search__input" name="searchTerm" value="@searchTerm"
                       placeholder="Szukaj po referencji lub notatce..." />
            </div>
            <button class="btn btn-primary news-admin-search__submit" type="submit">Szukaj</button>
            @if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                <a class="btn btn-outline-secondary news-admin-search__clear" href="@Url.Action("Index")"><i class="bi bi-x-lg"></i></a>
            }
        </form>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary"
               asp-controller="Raport"
               asp-action="RuchyMagazynowe"
               asp-route-searchTerm="@Model.SearchTerm"
               title="Przejdź do raportu ruchów magazynowych">
                <i class="bi bi-file-earmark-spreadsheet me-1"></i> Raport ruchów
            </a>
            <a class="btn news-admin-toolbar__cta" asp-action="Create"><i class="bi bi-plus-circle"></i> Dodaj ruch</a>
        </div>
    </section>

    @if (!items.Any())
    {
        <section class="news-admin-empty">
            <div class="news-admin-empty__icon"><i class="bi bi-arrow-left-right"></i></div>
            <h2 class="h4 mb-2">Brak ruchów magazynowych</h2>
            <p class="text-muted mb-3">Dodaj pierwszy ruch, aby rozpocząć rejestrowanie operacji magazynowych.</p>
            <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-circle me-1"></i> Dodaj ruch</a>
        </section>
    }
    else
    {
        <section class="entity-table-panel">
            <div class="entity-table-wrap">
                <table class="table table-hover align-middle mb-0 entity-table">
                    <thead>
                        <tr>
                            <th>Typ</th>
                            <th>Produkt</th>
                            <th>Z</th>
                            <th>Do</th>
                            <th class="text-end">Ilość</th>
                            <th>Referencja</th>
                            <th>Notatka</th>
                            <th>Utworzono</th>
                            <th>Użytkownik</th>
                            <th class="text-end">Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in items)
                    {
                        <tr>
                            <td><partial name="_MovementTypeBadge" model="item.Typ" /></td>
                            <td>
                                <div class="entity-cell-title">@(item.Produkt?.Kod ?? "-")</div>
                                <div class="entity-cell-subtitle">@(string.IsNullOrWhiteSpace(item.Produkt?.Nazwa) ? $"ID ruchu: {item.IdRuchu}" : item.Produkt!.Nazwa)</div>
                            </td>
                            <td title="@(item.LokacjaZ?.Magazyn?.Nazwa ?? "-")">@(item.LokacjaZ?.Kod ?? "-")</td>
                            <td title="@(item.LokacjaDo?.Magazyn?.Nazwa ?? "-")">@(item.LokacjaDo?.Kod ?? "-")</td>
                            <td class="text-end">
                                @{
                                    var jm = item.Produkt?.DomyslnaJednostka?.Kod ?? "j.m.";
                                }
                                @($"{item.Ilosc.ToString("0.###")} {jm}")
                            </td>
                            <td><span class="entity-cell-subtitle" title="@item.Referencja">@(string.IsNullOrWhiteSpace(item.Referencja) ? "-" : item.Referencja)</span></td>
                            <td><span class="entity-cell-subtitle text-truncate" title="@item.Notatka">@(string.IsNullOrWhiteSpace(item.Notatka) ? "-" : item.Notatka)</span></td>
                            <td>@item.UtworzonoUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(item.Uzytkownik?.Email ?? "-")</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm" role="group" aria-label="Akcje dla ruchu @item.IdRuchu">
                                    <a class="btn btn-outline-warning" asp-action="Edit" asp-route-id="@item.IdRuchu" title="Edytuj ruch" aria-label="Edytuj ruch"><i class="bi bi-pencil"></i></a>
                                    <a class="btn btn-outline-info" asp-action="Details" asp-route-id="@item.IdRuchu" title="Szczegóły ruchu" aria-label="Szczegóły ruchu"><i class="bi bi-eye"></i></a>
                                    <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@item.IdRuchu" title="Usuń ruch" aria-label="Usuń ruch"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>
