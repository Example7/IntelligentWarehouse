@model Data.Data.Magazyn.RuchMagazynowy
@using Data.Data.Magazyn

@{
    ViewData["Title"] = "Dodaj ruch magazynowy";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-plus-square"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Dodaj ruch magazynowy</h1>
                <p class="news-admin-header__subheading mb-0">Zarejestruj operacje magazynowa dla produktu i lokalizacji.</p>
            </div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Dane ruchu</h2>
            <p class="text-muted mb-0">Wypelnij typ ruchu, produkt, lokacje, ilość i metadane operacji.</p>
        </div>

        <form asp-action="Create" method="post" class="news-editor-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation" role="alert"></div>
            <div class="news-form-grid">
                <div class="news-form-field">
                    <label asp-for="Typ" class="form-label news-form-label"></label>
                    <select asp-for="Typ" class="form-select news-form-control" asp-items="Html.GetEnumSelectList<TypRuchuMagazynowego>()">
                        <option value="">(wybierz typ ruchu)</option>
                    </select>
                    <div class="small text-muted mt-1" id="movementTypeHint">
                        Wybierz typ ruchu, aby zobaczyć które pola lokacji sa wymagane.
                    </div>
                    <span asp-validation-for="Typ" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="IdProduktu" class="form-label news-form-label"></label>
                    <select asp-for="IdProduktu" class="form-select news-form-control" asp-items="ViewBag.IdProduktu">
                        <option value="">(wybierz produkt)</option>
                    </select>
                    <span asp-validation-for="IdProduktu" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="IdLokacjiZ" class="form-label news-form-label"></label>
                    <select asp-for="IdLokacjiZ" class="form-select news-form-control" asp-items="ViewBag.IdLokacjiZ">
                        <option value="">(brak)</option>
                    </select>
                    <div class="small text-muted mt-1" id="movementFromHint"></div>
                    <span asp-validation-for="IdLokacjiZ" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="IdLokacjiDo" class="form-label news-form-label"></label>
                    <select asp-for="IdLokacjiDo" class="form-select news-form-control" asp-items="ViewBag.IdLokacjiDo">
                        <option value="">(brak)</option>
                    </select>
                    <div class="small text-muted mt-1" id="movementToHint"></div>
                    <span asp-validation-for="IdLokacjiDo" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="Ilosc" class="form-label news-form-label"></label>
                    <input asp-for="Ilosc" class="form-control news-form-control" />
                    <span asp-validation-for="Ilosc" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label asp-for="Referencja" class="form-label news-form-label"></label>
                    <select asp-for="Referencja" class="form-select news-form-control" data-selected="@Model?.Referencja">
                        <option value="">(brak)</option>
                    </select>
                    <input type="hidden" id="referenceOptionsByType" value="@ViewData["ReferenceOptionsByTypeJson"]" />
                    <span asp-validation-for="Referencja" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label asp-for="Notatka" class="form-label news-form-label"></label>
                    <input asp-for="Notatka" class="form-control news-form-control" />
                    <span asp-validation-for="Notatka" class="text-danger small"></span>
                </div>
            </div>
            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary"><i class="bi bi-check2-circle"></i> Zapisz ruch</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Wroć do listy</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    @{ await Html.RenderPartialAsync("_RuchMagazynowyFormBehaviorScripts"); }
}
