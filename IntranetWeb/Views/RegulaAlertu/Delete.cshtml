@model Interfaces.Magazyn.Dtos.RegulaAlertuDeleteDto

@{
    ViewData["Title"] = "Usuń regułę alertu";
    var r = Model.Regula;
}

<div class="news-admin-page">
    <section class="news-admin-header news-admin-header--danger">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon news-admin-header__icon--danger"><i class="bi bi-trash3"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Usuń regułę alertu</h1>
                <p class="news-admin-header__subheading mb-0">Potwierdź usunięcie konfiguracji alertu magazynowego.</p>
            </div>
        </div>
    </section>

    <section class="news-delete-panel">
        <div class="news-delete-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>Usunięcie reguły alertu</strong>
                <div>@(Model.CzyMoznaUsunac ? "Po usunięciu system przestanie generować alerty wg tej reguły." : "Nie można usunąć reguły, ponieważ ma powiązane alerty.")</div>
            </div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mt-3"><div asp-validation-summary="All" class="mb-0"></div></div>
        }

        <div class="news-details-grid">
            <div class="news-details-item"><div class="news-details-item__label">Typ</div><div class="news-details-item__value">@r.Typ</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Próg</div><div class="news-details-item__value">@r.Prog.ToString("0.###")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Magazyn</div><div class="news-details-item__value">@(r.Magazyn?.Nazwa ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Produkt</div><div class="news-details-item__value">@(r.Produkt?.Nazwa ?? "Reguła ogólna")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Status</div><div class="news-details-item__value">@(r.CzyWlaczona ? "Włączona" : "Wyłączona")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Alerty</div><div class="news-details-item__value">@Model.LiczbaAlertow</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Utworzono</div><div class="news-details-item__value">@r.UtworzonoUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div></div>
        </div>

        <form asp-action="Delete" method="post" class="news-form-actions">
            <input type="hidden" asp-for="Regula.Id" name="id" value="@r.Id" />
            <button type="submit" class="btn btn-danger news-form-actions__primary" @(Model.CzyMoznaUsunac ? null : "disabled")><i class="bi bi-trash3-fill"></i> Usuń regułę</button>
            <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Anuluj</a>
        </form>
    </section>
</div>