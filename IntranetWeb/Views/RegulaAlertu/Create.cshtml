@model Data.Data.Magazyn.RegulaAlertu

@{
    ViewData["Title"] = "Dodaj regułę alertu";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-plus-square"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Dodaj regułę alertu</h1>
                <p class="news-admin-header__subheading mb-0">Utwórz nową regułę alertu dla magazynu lub produktu.</p>
            </div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Dane reguły</h2>
            <p class="text-muted mb-0">Wybierz magazyn, opcjonalnie produkt, typ reguły i wartość progu.</p>
        </div>

        <form asp-action="Create" method="post" class="news-editor-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation" role="alert"></div>
            <div class="news-form-grid">
                <div class="news-form-field">
                    <label asp-for="IdMagazynu" class="form-label news-form-label"></label>
                    <select asp-for="IdMagazynu" class="form-select news-form-control" asp-items="ViewBag.IdMagazynu"></select>
                    <span asp-validation-for="IdMagazynu" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="IdProduktu" class="form-label news-form-label"></label>
                    <select asp-for="IdProduktu" class="form-select news-form-control" asp-items="ViewBag.IdProduktu"></select>
                    <span asp-validation-for="IdProduktu" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="Typ" class="form-label news-form-label"></label>
                    <input asp-for="Typ" class="form-control news-form-control" />
                    <span asp-validation-for="Typ" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="Prog" class="form-label news-form-label"></label>
                    <input asp-for="Prog" class="form-control news-form-control" />
                    <span asp-validation-for="Prog" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="UtworzonoUtc" class="form-label news-form-label"></label>
                    <input asp-for="UtworzonoUtc" class="form-control news-form-control" />
                    <span asp-validation-for="UtworzonoUtc" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <div class="form-check form-switch mt-4">
                        <input class="form-check-input" asp-for="CzyWlaczona" />
                        <label class="form-check-label news-form-label mb-0" asp-for="CzyWlaczona"></label>
                    </div>
                    <span asp-validation-for="CzyWlaczona" class="text-danger small"></span>
                </div>
            </div>
            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary"><i class="bi bi-check2-circle"></i> Zapisz regułę</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Wróć do listy</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
