@model Interfaces.Magazyn.Dtos.DostawcaDeleteDto

@{
    ViewData["Title"] = "Usuń dostawcę";
    var dostawca = Model.Dostawca;
}

<div class="news-admin-page">
    <section class="news-admin-header news-admin-header--danger">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon news-admin-header__icon--danger"><i class="bi bi-trash3"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Usuń dostawcę</h1>
                <p class="news-admin-header__subheading mb-0">Potwierdź usunięcie dostawcy z bazy kontrahentów.</p>
            </div>
        </div>
    </section>

    <section class="news-delete-panel">
        <div class="news-delete-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>Usunięcie dostawcy</strong>
                <div>Operacja jest blokowana, jesli dostawca ma powiazane dokumenty PZ lub partie.</div>
            </div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger news-form-validation mt-3" role="alert"></div>
        }

        <div class="news-details-grid">
            <div class="news-details-item"><div class="news-details-item__label">ID</div><div class="news-details-item__value">@dostawca.IdDostawcy</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Status</div><div class="news-details-item__value">@(dostawca.CzyAktywny ? "Aktywny" : "Nieaktywny")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Nazwa</div><div class="news-details-item__value">@dostawca.Nazwa</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Dokumenty PZ</div><div class="news-details-item__value">@Model.LiczbaDokumentowPz</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Partie</div><div class="news-details-item__value">@Model.LiczbaPartii</div></div>
            <div class="news-details-item"><div class="news-details-item__label">NIP</div><div class="news-details-item__value entity-mono">@(string.IsNullOrWhiteSpace(dostawca.NIP) ? "-" : dostawca.NIP)</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Email</div><div class="news-details-item__value">@(string.IsNullOrWhiteSpace(dostawca.Email) ? "-" : dostawca.Email)</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Telefon</div><div class="news-details-item__value">@(string.IsNullOrWhiteSpace(dostawca.Telefon) ? "-" : dostawca.Telefon)</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Utworzono</div><div class="news-details-item__value">@dostawca.UtworzonoUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div></div>
            <div class="news-details-item news-details-item--full"><div class="news-details-item__label">Adres</div><div class="news-details-item__value news-details-item__value--content">@(string.IsNullOrWhiteSpace(dostawca.Adres) ? "Brak adresu" : dostawca.Adres)</div></div>
        </div>

        <form asp-action="Delete" method="post" class="news-form-actions">
            <input type="hidden" name="id" value="@dostawca.IdDostawcy" />
            <button type="submit" class="btn btn-danger news-form-actions__primary" disabled="@(!Model.CzyMoznaUsunac)">
                <i class="bi bi-trash3-fill"></i> Usuń dostawcę
            </button>
            <a asp-action="Details" asp-route-id="@dostawca.IdDostawcy" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Anuluj</a>
        </form>
    </section>
</div>

