@model Interfaces.Magazyn.Dtos.DostawcaIndexDto

@{
    ViewData["Title"] = "Dostawcy";
    var items = Model.Items.ToList();
    var searchTerm = Model.SearchTerm ?? string.Empty;
    var activeCount = items.Count(x => x.Dostawca.CzyAktywny);
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-truck"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Dostawcy</h1>
                <p class="news-admin-header__subheading mb-0">Baza dostawców i dane kontaktowe do obsługi przyjęć.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">Łącznie</span><strong class="news-admin-stat__value">@items.Count</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Aktywni</span><strong class="news-admin-stat__value">@activeCount</strong></div>
        </div>
    </section>

    <section class="news-admin-toolbar">
        <form method="get" class="news-admin-search" role="search" aria-label="Wyszukiwanie dostawców">
            <label for="supplierSearchTerm" class="visually-hidden">Szukaj dostawców</label>
            <div class="news-admin-search__input-wrap">
                <i class="bi bi-search news-admin-search__icon"></i>
                <input id="supplierSearchTerm" class="form-control news-admin-search__input" name="searchTerm" value="@searchTerm"
                       placeholder="Szukaj po nazwie, NIP, emailu, telefonie lub adresie..." />
            </div>
            <button class="btn btn-primary news-admin-search__submit" type="submit">Szukaj</button>
            @if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                <a class="btn btn-outline-secondary news-admin-search__clear" href="@Url.Action("Index")"><i class="bi bi-x-lg"></i></a>
            }
        </form>
        <a class="btn news-admin-toolbar__cta" asp-action="Create"><i class="bi bi-plus-circle"></i> Dodaj dostawcę</a>
    </section>

    @if (!items.Any())
    {
        <section class="news-admin-empty">
            <div class="news-admin-empty__icon"><i class="bi bi-truck"></i></div>
            <h2 class="h4 mb-2">Brak dostawców</h2>
            <p class="text-muted mb-3">Dodaj pierwszego dostawcę, aby rejestrować dokumenty PZ.</p>
            <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-circle me-1"></i> Dodaj dostawcę</a>
        </section>
    }
    else
    {
        <div class="news-admin-grid">
            @foreach (var item in items.OrderBy(x => x.Dostawca.Nazwa))
            {
                var d = item.Dostawca;
                <article class="news-card">
                    <div class="news-card__accent"></div>
                    <div class="news-card__body">
                        <div class="news-card__meta-top">
                            <span class="news-card__badge"><i class="bi bi-upc"></i> ID @d.IdDostawcy</span>
                            @if (d.CzyAktywny)
                            {
                                <span class="entity-badge">Aktywny</span>
                            }
                            else
                            {
                                <span class="entity-badge entity-badge--muted">Nieaktywny</span>
                            }
                        </div>

                        <h2 class="news-card__title" title="@d.Nazwa">@d.Nazwa</h2>
                        <p class="news-card__content" title="@d.Adres">@(string.IsNullOrWhiteSpace(d.Adres) ? "Brak adresu." : d.Adres)</p>

                        <div class="entity-inline-meta">
                            <span class="entity-inline-meta__label">NIP:</span>
                            <span class="entity-inline-meta__value entity-mono">@(string.IsNullOrWhiteSpace(d.NIP) ? "-" : d.NIP)</span>
                        </div>
                        <div class="entity-inline-meta">
                            <span class="entity-inline-meta__label">Kontakt:</span>
                            <span class="entity-inline-meta__value">@(d.Email ?? d.Telefon ?? "-")</span>
                        </div>
                        <div class="entity-inline-meta">
                            <span class="entity-inline-meta__label">PZ:</span>
                            <span class="entity-inline-meta__value">@item.LiczbaDokumentowPz</span>
                        </div>
                        <div class="entity-inline-meta">
                            <span class="entity-inline-meta__label">Partie:</span>
                            <span class="entity-inline-meta__value">@item.LiczbaPartii</span>
                        </div>

                        <div class="news-card__footer">
                            <div class="btn-group btn-group-sm" role="group" aria-label="Akcje dla dostawcy @d.Nazwa">
                                <a class="btn btn-outline-warning" asp-action="Edit" asp-route-id="@d.IdDostawcy" title="Edytuj dostawcę"><i class="bi bi-pencil"></i></a>
                                <a class="btn btn-outline-info" asp-action="Details" asp-route-id="@d.IdDostawcy" title="Szczegóły dostawcy"><i class="bi bi-eye"></i></a>
                                <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@d.IdDostawcy" title="Usuń dostawcę"><i class="bi bi-trash"></i></a>
                            </div>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</div>
