@model Data.Data.Magazyn.ProduktJednostka

@{
    ViewData["Title"] = "Dodaj jednostkę produktu";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-plus-square"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Dodaj jednostkę produktu</h1>
                <p class="news-admin-header__subheading mb-0">Dodaj powiązanie produktu z jednostką miary i przelicznikiem.</p>
            </div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Dane powiązania</h2>
            <p class="text-muted mb-0">Wybierz produkt, jednostkę i podaj przelicznik do domyślnej.</p>
        </div>

        <form asp-action="Create" method="post" class="news-editor-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation" role="alert"></div>
            <div class="news-form-grid">
                <div class="news-form-field">
                    <label asp-for="IdProduktu" class="form-label news-form-label"></label>
                    <select asp-for="IdProduktu" class="form-select news-form-control" asp-items="ViewBag.IdProduktu"></select>
                    <span asp-validation-for="IdProduktu" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="IdJednostki" class="form-label news-form-label"></label>
                    <select asp-for="IdJednostki" class="form-select news-form-control" asp-items="ViewBag.IdJednostki"></select>
                    <span asp-validation-for="IdJednostki" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label asp-for="PrzelicznikDoDomyslnej" class="form-label news-form-label"></label>
                    <input asp-for="PrzelicznikDoDomyslnej" class="form-control news-form-control" />
                    <span asp-validation-for="PrzelicznikDoDomyslnej" class="text-danger small"></span>
                </div>
            </div>
            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary"><i class="bi bi-check2-circle"></i> Zapisz jednostkę produktu</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Wróć do listy</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
