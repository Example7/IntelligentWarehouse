@model Interfaces.Magazyn.Dtos.ProduktJednostkaIndexDto

@{
    var isAdmin = User?.IsInRole("Admin") ?? false;
    ViewData["Title"] = "Jednostki produktów";
    var items = (Model.Items ?? new()).ToList();
    var searchTerm = Model.SearchTerm ?? string.Empty;
    var distinctProducts = items.Select(x => x.IdProduktu).Distinct().Count();
    var distinctUoms = items.Select(x => x.IdJednostki).Distinct().Count();
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon" aria-hidden="true"><i class="bi bi-rulers"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Jednostki produktów</h1>
                <p class="news-admin-header__subheading mb-0">Powiązania produktów z jednostkami miary i przelicznikami.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">Łącznie</span><strong class="news-admin-stat__value">@items.Count</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Produkty</span><strong class="news-admin-stat__value">@distinctProducts</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">JM</span><strong class="news-admin-stat__value">@distinctUoms</strong></div>
        </div>
    </section>

    <section class="news-admin-toolbar">
        <form method="get" class="news-admin-search" role="search" aria-label="Wyszukiwanie jednostek produktów">
            <label for="productUomSearchTerm" class="visually-hidden">Szukaj jednostek produktów</label>
            <div class="news-admin-search__input-wrap">
                <i class="bi bi-search news-admin-search__icon" aria-hidden="true"></i>
                <input id="productUomSearchTerm" class="form-control news-admin-search__input" name="searchTerm" value="@searchTerm"
                       placeholder="Szukaj po produkcie lub jednostce..." />
            </div>
            <button class="btn btn-primary news-admin-search__submit" type="submit">Szukaj</button>
            @if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                <a class="btn btn-outline-secondary news-admin-search__clear" href="@Url.Action("Index")" title="Wyczyść filtr"><i class="bi bi-x-lg"></i></a>
            }
        </form>
        <a class="btn news-admin-toolbar__cta" asp-action="Create"><i class="bi bi-plus-circle"></i> Dodaj jednostkę produktu</a>
    </section>

    @if (!items.Any())
    {
        <section class="news-admin-empty">
            <div class="news-admin-empty__icon"><i class="bi bi-rulers"></i></div>
            <h2 class="h4 mb-2">Brak jednostek produktów</h2>
            <p class="text-muted mb-3">
                @if (string.IsNullOrWhiteSpace(searchTerm))
                {
                    <span>Nie dodano jeszcze powiązań produkt–JM.</span>
                }
                else
                {
                    <span>Brak wyników dla frazy: <strong>@searchTerm</strong>.</span>
                }
            </p>
            <div class="d-flex justify-content-center gap-2 flex-wrap">
                <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-circle me-1"></i> Dodaj jednostkę produktu</a>
                @if (!string.IsNullOrWhiteSpace(searchTerm))
                {
                    <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Wyczyść filtr</a>
                }
            </div>
        </section>
    }
    else
    {
        <section class="entity-table-panel">
            <div class="entity-table-wrap">
                <table class="table table-hover align-middle mb-0 entity-table">
                    <thead>
                        <tr>
                            <th>Produkt</th>
                            <th>Jednostka</th>
                            <th class="text-end">Przelicznik</th>
                            <th class="text-end">Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in items)
                    {
                        <tr>
                            <td>
                                <div class="entity-cell-title">@(item.Produkt?.Kod ?? "-")</div>
                                <div class="entity-cell-subtitle">@(item.Produkt?.Nazwa ?? "-")</div>
                            </td>
                            <td>
                                <div class="entity-cell-title">@(item.Jednostka?.Kod ?? "-")</div>
                                <div class="entity-cell-subtitle">@(item.Jednostka?.Nazwa ?? "-")</div>
                            </td>
                            <td class="text-end">
                                <span class="entity-mono">@item.PrzelicznikDoDomyslnej.ToString("0.######")</span>
                                <div class="entity-cell-subtitle">do domyślnej JM produktu</div>
                            </td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm" role="group" aria-label="Akcje dla jednostki produktu @item.Id">
                                    <a class="btn btn-outline-warning" asp-action="Edit" asp-route-id="@item.Id" title="Edytuj powiązanie"><i class="bi bi-pencil"></i></a>
                                    <a class="btn btn-outline-info" asp-action="Details" asp-route-id="@item.Id" title="Szczegóły powiązania"><i class="bi bi-eye"></i></a>
                                    @if (isAdmin)
                                    {
                                        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id" title="Usuń powiązanie"><i class="bi bi-trash"></i></a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>