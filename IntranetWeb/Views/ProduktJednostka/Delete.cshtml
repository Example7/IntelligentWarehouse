@model Interfaces.Magazyn.Dtos.ProduktJednostkaDeleteDto

@{
    ViewData["Title"] = "Usuń jednostkę produktu";
    var item = Model.ProduktJednostka;
}

<div class="news-admin-page">
    <section class="news-admin-header news-admin-header--danger">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon news-admin-header__icon--danger" aria-hidden="true"><i class="bi bi-trash3"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Usuń jednostkę produktu</h1>
                <p class="news-admin-header__subheading mb-0">Potwierdź usunięcie powiązania produktu z jednostką miary.</p>
            </div>
        </div>
    </section>

    <section class="news-delete-panel">
        <div class="news-delete-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>Usunięcie jednostki produktu</strong>
                <div>Usunięcie powiązania może wpływać na przeliczenia ilości. Pozostałe jednostki dla produktu: @(Math.Max(Model.LiczbaJednostekProduktu - 1, 0)).</div>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item">
                <div class="news-details-item__label">Produkt</div>
                <div class="news-details-item__value">
                    @(item.Produkt?.Kod ?? "-")
                    <div class="entity-cell-subtitle">@(item.Produkt?.Nazwa ?? "-")</div>
                </div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Jednostka</div>
                <div class="news-details-item__value">
                    @(item.Jednostka?.Kod ?? "-")
                    <div class="entity-cell-subtitle">@(item.Jednostka?.Nazwa ?? "-")</div>
                </div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Przelicznik</div>
                <div class="news-details-item__value entity-mono">@item.PrzelicznikDoDomyslnej.ToString("0.######")</div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Jednostki dla produktu</div>
                <div class="news-details-item__value">@Model.LiczbaJednostekProduktu</div>
            </div>
        </div>

        <form asp-action="Delete" method="post" class="news-form-actions">
            <input type="hidden" name="id" value="@item.Id" />
            <button type="submit" class="btn btn-danger news-form-actions__primary"><i class="bi bi-trash3-fill"></i> Usuń powiązanie</button>
            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
            <a asp-controller="Produkt" asp-action="Details" asp-route-id="@item.IdProduktu" class="btn btn-outline-secondary"><i class="bi bi-box-seam"></i> Produkt</a>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Anuluj</a>
        </form>
    </section>
</div>