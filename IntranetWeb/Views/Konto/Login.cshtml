@model IntranetWeb.Models.Auth.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Logowanie";
}
<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Logowanie - IntranetWeb</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <div class="container min-vh-100 d-flex align-items-center justify-content-center py-5">
        <div class="card shadow-sm border-0" style="max-width: 420px; width: 100%;">
            <div class="card-body p-4">
                <div class="mb-4">
                    <div class="small text-uppercase text-muted fw-bold">Intelligent Warehouse</div>
                    <h1 class="h3 mb-1">Logowanie</h1>
                    <p class="text-muted mb-0">Panel intranetowy systemu ZSI.</p>
                </div>

                <form asp-action="Login" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <input asp-for="ReturnUrl" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="LoginOrEmail" class="form-label"></label>
                        <input asp-for="LoginOrEmail" class="form-control" autocomplete="username" />
                        <span asp-validation-for="LoginOrEmail" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" autocomplete="current-password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label"></label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Zaloguj</button>
                </form>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
