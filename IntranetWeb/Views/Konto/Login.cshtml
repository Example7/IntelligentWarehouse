@model IntranetWeb.Models.Auth.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Logowanie";
}
<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Logowanie</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-page">
    <div class="login-shell">
        <div class="login-card">
            <div class="login-card__head">
                <span class="login-card__brand-icon"><i class="bi bi-boxes"></i></span>
                <div>
                    <div class="login-card__kicker">Intelligent Warehouse</div>
                    <h1 class="login-card__title">Logowanie do intranetu</h1>
                    <p class="login-card__subtitle">Dostęp do panelu operacyjnego WMS i CMS.</p>
                </div>
            </div>

            <form asp-action="Login" method="post" novalidate class="login-form">
                @Html.AntiForgeryToken()
                <input asp-for="ReturnUrl" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="LoginOrEmail" class="form-label login-form__label"></label>
                    <div class="login-form__input-wrap">
                        <i class="bi bi-person login-form__icon"></i>
                        <input asp-for="LoginOrEmail" class="form-control login-form__input" autocomplete="username" />
                    </div>
                    <span asp-validation-for="LoginOrEmail" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label login-form__label"></label>
                    <div class="login-form__input-wrap">
                        <i class="bi bi-key login-form__icon"></i>
                        <input asp-for="Password" class="form-control login-form__input" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label login-form__remember"></label>
                </div>

                <button type="submit" class="btn login-form__submit w-100">
                    <i class="bi bi-box-arrow-in-right me-1"></i>
                    Zaloguj
                </button>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
