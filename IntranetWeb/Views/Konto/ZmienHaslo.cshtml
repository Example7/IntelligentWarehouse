@model IntranetWeb.Models.Auth.ChangePasswordViewModel
@{
    ViewData["Title"] = "Zmiana hasła";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-key"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Zmiana hasła</h1>
                <p class="news-admin-header__subheading mb-0">Zmiana hasła dla zalogowanego użytkownika.</p>
            </div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Ustaw nowe hasło</h2>
            <p class="text-muted mb-0">Nowe hasło zostanie zapisane jako hash (Identity PasswordHasher).</p>
        </div>
        <form asp-action="ZmienHaslo" method="post" class="news-editor-form" novalidate>
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation" role="alert"></div>
            <div class="news-form-grid">
                <div class="news-form-field news-form-field--full">
                    <label asp-for="CurrentPassword" class="form-label news-form-label"></label>
                    <input asp-for="CurrentPassword" class="form-control news-form-control" autocomplete="current-password" />
                    <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="NewPassword" class="form-label news-form-label"></label>
                    <input asp-for="NewPassword" class="form-control news-form-control" autocomplete="new-password" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="ConfirmNewPassword" class="form-label news-form-label"></label>
                    <input asp-for="ConfirmNewPassword" class="form-control news-form-control" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                </div>
            </div>
            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary"><i class="bi bi-check2-circle"></i> Zmień hasło</button>
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i> Anuluj</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
