@model Data.Data.Magazyn.Produkt

@{
    ViewData["Title"] = "Szczegóły produktu";
    var jednostkaMiary = Model.DomyslnaJednostka?.Kod ?? "j.m.";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-box-seam"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Szczegóły produktu</h1>
                <p class="news-admin-header__subheading mb-0">Podgląd pełnych danych produktu magazynowego.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@Model.IdProduktu</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Kod</span><strong class="news-admin-stat__value">@Model.Kod</strong></div>
        </div>
    </section>

    <section class="news-details-panel">
        <div class="news-details-panel__header">
            <h2 class="news-details-panel__title">@Model.Nazwa</h2>
            <div class="news-details-panel__actions">
                <a asp-action="Edit" asp-route-id="@Model.IdProduktu" class="btn btn-primary"><i class="bi bi-pencil-square me-1"></i> Edytuj</a>
                <a asp-action="Delete" asp-route-id="@Model.IdProduktu" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i> Usuń</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Lista</a>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item"><div class="news-details-item__label">Kod</div><div class="news-details-item__value">@Model.Kod</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Nazwa</div><div class="news-details-item__value">@Model.Nazwa</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Kategoria</div><div class="news-details-item__value">@(Model.Kategoria?.Nazwa ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Domyślna jednostka miary</div><div class="news-details-item__value">@(Model.DomyslnaJednostka?.Kod ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Stan minimalny</div><div class="news-details-item__value">@Model.StanMinimalny.ToString("0.###") @jednostkaMiary</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Status</div><div class="news-details-item__value">@(Model.CzyAktywny ? "Aktywny" : "Nieaktywny")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Punkt ponownego zamówienia (ROP)</div><div class="news-details-item__value">@(Model.PunktPonownegoZamowienia.HasValue ? $"{Model.PunktPonownegoZamowienia.Value.ToString("0.###")} {jednostkaMiary}" : "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Ilość ponownego zamówienia (ROQ)</div><div class="news-details-item__value">@(Model.IloscPonownegoZamowienia.HasValue ? $"{Model.IloscPonownegoZamowienia.Value.ToString("0.###")} {jednostkaMiary}" : "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Utworzono</div><div class="news-details-item__value">@Model.UtworzonoUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div></div>
            <div class="news-details-item news-details-item--full">
                <div class="news-details-item__label">Opis</div>
                <div class="news-details-item__value news-details-item__value--content">@(string.IsNullOrWhiteSpace(Model.Opis) ? "Brak opisu" : Model.Opis)</div>
            </div>
        </div>
    </section>
</div>
