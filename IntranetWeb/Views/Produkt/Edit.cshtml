@model Data.Data.Magazyn.Produkt

@{
    ViewData["Title"] = "Edytuj produkt";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-pencil-square"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Edytuj produkt</h1>
                <p class="news-admin-header__subheading mb-0">Aktualizacja danych kartoteki produktu.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@Model.IdProduktu</strong></div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Edycja produktu</h2>
            <p class="text-muted mb-0">Zmień parametry produktu i zapisz zmiany.</p>
        </div>

        <form asp-action="Edit" method="post" class="news-editor-form" novalidate>
            <input type="hidden" asp-for="IdProduktu" />
            <input type="hidden" asp-for="UtworzonoUtc" />
            <input type="hidden" asp-for="RowVersion" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation" role="alert"></div>

            <div class="news-form-grid">
                <div class="news-form-field">
                    <label asp-for="Kod" class="form-label news-form-label"></label>
                    <input asp-for="Kod" class="form-control news-form-control" />
                    <span asp-validation-for="Kod" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="Nazwa" class="form-label news-form-label"></label>
                    <input asp-for="Nazwa" class="form-control news-form-control" />
                    <span asp-validation-for="Nazwa" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label asp-for="Opis" class="form-label news-form-label"></label>
                    <textarea asp-for="Opis" class="form-control news-form-control news-form-control--textarea" rows="5"></textarea>
                    <span asp-validation-for="Opis" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="IdKategorii" class="form-label news-form-label"></label>
                    <select asp-for="IdKategorii" class="form-select news-form-control" asp-items="ViewBag.IdKategorii"></select>
                    <span asp-validation-for="IdKategorii" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="IdDomyslnejJednostki" class="form-label news-form-label"></label>
                    <select asp-for="IdDomyslnejJednostki" class="form-select news-form-control" asp-items="ViewBag.IdDomyslnejJednostki"></select>
                    <span asp-validation-for="IdDomyslnejJednostki" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="StanMinimalny" class="form-label news-form-label"></label>
                    <input asp-for="StanMinimalny" class="form-control news-form-control" />
                    <span asp-validation-for="StanMinimalny" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="PunktPonownegoZamowienia" class="form-label news-form-label"></label>
                    <input asp-for="PunktPonownegoZamowienia" class="form-control news-form-control" />
                    <span asp-validation-for="PunktPonownegoZamowienia" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="IloscPonownegoZamowienia" class="form-label news-form-label"></label>
                    <input asp-for="IloscPonownegoZamowienia" class="form-control news-form-control" />
                    <span asp-validation-for="IloscPonownegoZamowienia" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <div class="form-check news-form-check">
                        <input class="form-check-input" asp-for="CzyAktywny" />
                        <label class="form-check-label" asp-for="CzyAktywny"></label>
                    </div>
                </div>
            </div>

            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary"><i class="bi bi-check2-circle"></i> Zapisz zmiany</button>
                <a asp-action="Details" asp-route-id="@Model.IdProduktu" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i> Anuluj</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
