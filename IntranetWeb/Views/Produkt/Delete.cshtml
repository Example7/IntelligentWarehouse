@model Interfaces.Magazyn.Dtos.ProduktDeleteDto

@{
    ViewData["Title"] = "Usuń produkt";
    var p = Model.Produkt;
}

<div class="news-admin-page">
    <section class="news-admin-header news-admin-header--danger">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon news-admin-header__icon--danger"><i class="bi bi-trash3"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Usuń produkt</h1>
                <p class="news-admin-header__subheading mb-0">Potwierdź usunięcie kartoteki produktu.</p>
            </div>
        </div>
    </section>

    <section class="news-delete-panel">
        <div class="news-delete-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>Usunięcie produktu</strong>
                <div>Operacja jest blokowana, jeśli produkt ma powiązane stany, dokumenty lub inne rekordy WMS.</div>
            </div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation mt-3 mb-0" role="alert"></div>
        }

        <div class="news-details-grid">
            <div class="news-details-item"><div class="news-details-item__label">Kod</div><div class="news-details-item__value">@p.Kod</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Nazwa</div><div class="news-details-item__value">@p.Nazwa</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Kategoria</div><div class="news-details-item__value">@(p.Kategoria?.Nazwa ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">JM</div><div class="news-details-item__value">@(p.DomyslnaJednostka?.Kod ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Stany magazynowe</div><div class="news-details-item__value">@Model.LiczbaStanowMagazynowych</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Ruchy magazynowe</div><div class="news-details-item__value">@Model.LiczbaRuchowMagazynowych</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Pozycje PZ / WZ / MM</div><div class="news-details-item__value">@Model.LiczbaPozycjiPz / @Model.LiczbaPozycjiWz / @Model.LiczbaPozycjiMm</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Rezerwacje / Inwent.</div><div class="news-details-item__value">@Model.LiczbaPozycjiRezerwacji / @Model.LiczbaPozycjiInwentaryzacji</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Alerty / Reguły</div><div class="news-details-item__value">@Model.LiczbaAlertow / @Model.LiczbaRegulAlertow</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Kody / Jednostki / Partie</div><div class="news-details-item__value">@Model.LiczbaKodowProduktu / @Model.LiczbaJednostekProduktu / @Model.LiczbaPartii</div></div>
            <div class="news-details-item news-details-item--full">
                <div class="news-details-item__label">Opis</div>
                <div class="news-details-item__value news-details-item__value--content">@(string.IsNullOrWhiteSpace(p.Opis) ? "Brak opisu" : p.Opis)</div>
            </div>
        </div>

        <form asp-action="Delete" method="post" class="news-form-actions">
            <input type="hidden" name="id" value="@p.IdProduktu" />
            @if (Model.CzyMoznaUsunac)
            {
                <button type="submit" class="btn btn-danger news-form-actions__primary"><i class="bi bi-trash3-fill"></i> Usuń produkt</button>
            }
            else
            {
                <button type="submit" class="btn btn-danger news-form-actions__primary" disabled><i class="bi bi-trash3-fill"></i> Usuń produkt</button>
            }
            <a asp-action="Details" asp-route-id="@p.IdProduktu" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Anuluj</a>
        </form>
    </section>
</div>