@model Data.Data.Magazyn.Produkt

@{
    ViewData["Title"] = "Usuń produkt";
}

<div class="news-admin-page">
    <section class="news-admin-header news-admin-header--danger">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon news-admin-header__icon--danger"><i class="bi bi-trash3"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Usuń produkt</h1>
                <p class="news-admin-header__subheading mb-0">Potwierdź usunięcie kartoteki produktu.</p>
            </div>
        </div>
    </section>

    <section class="news-delete-panel">
        <div class="news-delete-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>Usunięcie produktu</strong>
                <div>Produkt może być powiązany ze stanami i dokumentami magazynowymi.</div>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item"><div class="news-details-item__label">Kod</div><div class="news-details-item__value">@Model.Kod</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Nazwa</div><div class="news-details-item__value">@Model.Nazwa</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Kategoria</div><div class="news-details-item__value">@(Model.Kategoria?.Nazwa ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">JM</div><div class="news-details-item__value">@(Model.DomyslnaJednostka?.Kod ?? "-")</div></div>
            <div class="news-details-item news-details-item--full">
                <div class="news-details-item__label">Opis</div>
                <div class="news-details-item__value news-details-item__value--content">@(string.IsNullOrWhiteSpace(Model.Opis) ? "Brak opisu" : Model.Opis)</div>
            </div>
        </div>

        <form asp-action="Delete" method="post" class="news-form-actions">
            <input type="hidden" asp-for="IdProduktu" />
            <button type="submit" class="btn btn-danger news-form-actions__primary"><i class="bi bi-trash3-fill"></i> Usuń produkt</button>
            <a asp-action="Details" asp-route-id="@Model.IdProduktu" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Anuluj</a>
        </form>
    </section>
</div>
