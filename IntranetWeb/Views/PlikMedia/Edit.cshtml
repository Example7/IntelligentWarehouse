@model Data.Data.CMS.PlikMedia

@{
    ViewData["Title"] = "Edytuj plik media";

    static string HumanSize(long bytes)
    {
        string[] units = ["B", "KB", "MB", "GB"];
        double size = bytes;
        var i = 0;
        while (size >= 1024 && i < units.Length - 1)
        {
            size /= 1024;
            i++;
        }

        return $"{size:0.##} {units[i]}";
    }

    static string ShortContentType(string? contentType)
    {
        var normalized = (contentType ?? string.Empty).Trim().ToLowerInvariant();
        return normalized switch
        {
            "application/vnd.openxmlformats-officedocument.wordprocessingml.document" => "DOCX",
            "application/pdf" => "PDF",
            "image/jpeg" => "JPG",
            "image/png" => "PNG",
            _ => string.IsNullOrWhiteSpace(contentType) ? "-" : contentType
        };
    }
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon" aria-hidden="true"><i class="bi bi-pencil-square"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Edytuj plik media</h1>
                <p class="news-admin-header__subheading mb-0">Aktualizacja metadanych pliku w repozytorium CMS.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@Model.Id</strong></div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Edycja metadanych</h2>
            <p class="text-muted mb-0">Możesz podmienić plik i zmienić opis. Typ, rozmiar i ścieżka są zarządzane automatycznie.</p>
        </div>
        <form asp-action="Edit" method="post" enctype="multipart/form-data" class="news-editor-form" novalidate>
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation" role="alert"></div>
            <div class="news-form-grid">
                <div class="news-form-field">
                    <label class="form-label news-form-label">Aktualny plik</label>
                    <input class="form-control news-form-control" value="@Model.NazwaPliku" readonly />
                    <small class="text-muted">Typ: <strong>@ShortContentType(Model.ContentType)</strong> | Rozmiar: <strong>@HumanSize(Model.RozmiarBajty)</strong></small>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label for="mediaFile" class="form-label news-form-label">Podmień plik (opcjonalnie)</label>
                    <input id="mediaFile" name="mediaFile" class="form-control news-form-control" type="file" />
                    <small class="text-muted">Po wyborze nowego pliku metadane zostaną nadpisane automatycznie.</small>
                </div>
                <div class="news-form-field">
                    <label class="form-label news-form-label">Wgrano</label>
                    <input class="form-control news-form-control" value="@Model.WgranoUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")" readonly />
                </div>
                <div class="news-form-field news-form-field--full">
                    <label asp-for="Sciezka" class="form-label news-form-label"></label>
                    <input asp-for="Sciezka" class="form-control news-form-control" readonly />
                    <span asp-validation-for="Sciezka" class="text-danger small"></span>
                </div>
                <input asp-for="NazwaPliku" type="hidden" />
                <input asp-for="ContentType" type="hidden" />
                <input asp-for="RozmiarBajty" type="hidden" />
                <input asp-for="Sciezka" type="hidden" />
                <div class="news-form-field news-form-field--full">
                    <label asp-for="Opis" class="form-label news-form-label"></label>
                    <textarea asp-for="Opis" class="form-control news-form-control news-form-control--textarea" rows="4"></textarea>
                    <span asp-validation-for="Opis" class="text-danger small"></span>
                </div>
            </div>
            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary"><i class="bi bi-check2-circle"></i> Zapisz zmiany</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i> Anuluj</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
