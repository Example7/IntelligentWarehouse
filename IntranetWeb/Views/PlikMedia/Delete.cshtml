@model Data.Data.CMS.PlikMedia

@{
    ViewData["Title"] = "Usuń plik media";
}

<div class="news-admin-page">
    <section class="news-admin-header news-admin-header--danger">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon news-admin-header__icon--danger"><i class="bi bi-trash3"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Usuń plik media</h1>
                <p class="news-admin-header__subheading mb-0">Potwierdź usunięcie wpisu metadanych pliku z repozytorium CMS.</p>
            </div>
        </div>
    </section>

    <section class="news-delete-panel">
        <div class="news-delete-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>Usunięcie wpisu media</strong>
                <div>Sprawdź, czy plik nie jest referencjonowany przez strony lub aktualności.</div>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item"><div class="news-details-item__label">ID</div><div class="news-details-item__value">@Model.Id</div></div>
            <div class="news-details-item"><div class="news-details-item__label">@Html.DisplayNameFor(m => m.NazwaPliku)</div><div class="news-details-item__value">@Html.DisplayFor(m => m.NazwaPliku)</div></div>
            <div class="news-details-item"><div class="news-details-item__label">@Html.DisplayNameFor(m => m.ContentType)</div><div class="news-details-item__value">@Html.DisplayFor(m => m.ContentType)</div></div>
            <div class="news-details-item"><div class="news-details-item__label">@Html.DisplayNameFor(m => m.RozmiarBajty)</div><div class="news-details-item__value">@Html.DisplayFor(m => m.RozmiarBajty) B</div></div>
            <div class="news-details-item"><div class="news-details-item__label">@Html.DisplayNameFor(m => m.Wgral)</div><div class="news-details-item__value">@(Model.Wgral?.Email ?? "-")</div></div>
            <div class="news-details-item news-details-item--full"><div class="news-details-item__label">@Html.DisplayNameFor(m => m.Sciezka)</div><div class="news-details-item__value entity-mono">@Html.DisplayFor(m => m.Sciezka)</div></div>
            <div class="news-details-item news-details-item--full"><div class="news-details-item__label">@Html.DisplayNameFor(m => m.Opis)</div><div class="news-details-item__value news-details-item__value--content">@(string.IsNullOrWhiteSpace(Model.Opis) ? "Brak opisu" : Model.Opis)</div></div>
        </div>

        <form asp-action="Delete" method="post" class="news-form-actions">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger news-form-actions__primary"><i class="bi bi-trash3-fill"></i> Usuń wpis</button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Anuluj</a>
        </form>
    </section>
</div>
