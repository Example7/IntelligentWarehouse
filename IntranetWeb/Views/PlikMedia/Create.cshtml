@model Data.Data.CMS.PlikMedia

@{
    ViewData["Title"] = "Dodaj plik media";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon" aria-hidden="true"><i class="bi bi-plus-square"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Dodaj plik media</h1>
                <p class="news-admin-header__subheading mb-0">Utwórz wpis metadanych pliku w repozytorium CMS.</p>
            </div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Metadane pliku</h2>
            <p class="text-muted mb-0">Wypełnij dane techniczne i informacyjne pliku. Czas wgrania jest ustawiany automatycznie.</p>
        </div>
        <form asp-action="Create" method="post" enctype="multipart/form-data" class="news-editor-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation" role="alert"></div>
            <div class="news-form-grid">
                <div class="news-form-field">
                    <label for="mediaFile" class="form-label news-form-label">Plik</label>
                    <input id="mediaFile" name="mediaFile" class="form-control news-form-control" type="file" required />
                    <small class="text-muted">Nazwa, typ, rozmiar i ścieżka zostaną uzupełnione automatycznie.</small>
                    <span asp-validation-for="Sciezka" class="text-danger small"></span>
                </div>
                <input asp-for="NazwaPliku" type="hidden" />
                <input asp-for="ContentType" type="hidden" />
                <input asp-for="Sciezka" type="hidden" />
                <input asp-for="RozmiarBajty" type="hidden" />
                <div class="news-form-field news-form-field--full">
                    <label asp-for="Opis" class="form-label news-form-label"></label>
                    <textarea asp-for="Opis" class="form-control news-form-control news-form-control--textarea" rows="4"></textarea>
                    <span asp-validation-for="Opis" class="text-danger small"></span>
                </div>
            </div>
            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary"><i class="bi bi-check2-circle"></i> Zapisz plik</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Wróć do listy</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
