@model Data.Data.Magazyn.DokumentWZ

@{
    ViewData["Title"] = "Szczegoly WZ";
    var isPosted = string.Equals(Model.Status, "Posted", StringComparison.OrdinalIgnoreCase);
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-file-earmark-text"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Szczegóły dokumentu WZ</h1>
                <p class="news-admin-header__subheading mb-0">Podgląd danych dokumentu wydania oraz statusu księgowania.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@Model.Id</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Status</span><strong class="news-admin-stat__value">@Model.Status</strong></div>
        </div>
    </section>

    <section class="news-details-panel">
        <div class="news-details-panel__header">
            <h2 class="news-details-panel__title">@Model.Numer</h2>
            <div class="news-details-panel__actions">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil-square me-1"></i> Edytuj</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i> Usuń</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Lista</a>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item"><div class="news-details-item__label">Numer</div><div class="news-details-item__value entity-mono">@Model.Numer</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Status</div><div class="news-details-item__value"><span class="entity-badge @(isPosted ? "entity-badge--success" : "entity-badge--warning")">@Model.Status</span></div></div>
            <div class="news-details-item"><div class="news-details-item__label">Magazyn</div><div class="news-details-item__value">@(Model.Magazyn?.Nazwa ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Klient</div><div class="news-details-item__value">@(Model.Klient?.Nazwa ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Data wydania</div><div class="news-details-item__value">@Model.DataWydaniaUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Utworzył</div><div class="news-details-item__value">@(Model.Utworzyl?.Email ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Zaksięgowano</div><div class="news-details-item__value">@(Model.ZaksiegowanoUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Pozycji</div><div class="news-details-item__value">@Model.Pozycje.Count</div></div>
            <div class="news-details-item news-details-item--full">
                <div class="news-details-item__label">Notatka</div>
                <div class="news-details-item__value news-details-item__value--content">@(string.IsNullOrWhiteSpace(Model.Notatka) ? "Brak notatki" : Model.Notatka)</div>
            </div>
            <div class="news-details-item news-details-item--full">
                <div class="news-details-item__label">RowVersion</div>
                <div class="news-details-item__value entity-mono">@(Model.RowVersion is { Length: > 0 } ? Convert.ToBase64String(Model.RowVersion) : "-")</div>
            </div>
        </div>
    </section>
</div>
