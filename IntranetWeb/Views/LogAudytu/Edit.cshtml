@model Data.Data.Magazyn.LogAudytu

@{
    ViewData["Title"] = "Edytuj wpis audytu";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-pencil-square"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Edytuj wpis audytu</h1>
                <p class="news-admin-header__subheading mb-0">Aktualizuj dane wpisu logu audytu i zapisane wartości JSON.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@Model.Id</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Akcja</span><strong class="news-admin-stat__value">@Model.Akcja</strong></div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Edycja wpisu</h2>
            <p class="text-muted mb-0">Zmień akcję, encję i dane JSON, a następnie zapisz zmiany.</p>
        </div>

        <form asp-action="Edit" method="post" class="news-editor-form" novalidate>
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation" role="alert"></div>
            <div class="news-form-grid">
                <div class="news-form-field">
                    <label asp-for="UserId" class="form-label news-form-label">Użytkownik (opcjonalnie)</label>
                    <select asp-for="UserId" class="form-select news-form-control" asp-items="ViewBag.UserId"></select>
                    <span asp-validation-for="UserId" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="Akcja" class="form-label news-form-label">Akcja</label>
                    <input asp-for="Akcja" class="form-control news-form-control" placeholder="CREATE / UPDATE / DELETE / LOGIN" />
                    <span asp-validation-for="Akcja" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="Encja" class="form-label news-form-label">Encja</label>
                    <input asp-for="Encja" class="form-control news-form-control" placeholder="np. Produkt" />
                    <span asp-validation-for="Encja" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="IdEncji" class="form-label news-form-label">ID encji (opcjonalnie)</label>
                    <input asp-for="IdEncji" class="form-control news-form-control" placeholder="np. 123" />
                    <span asp-validation-for="IdEncji" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="KiedyUtc" class="form-label news-form-label">Kiedy</label>
                    <input asp-for="KiedyUtc" type="datetime-local" class="form-control news-form-control" />
                    <span asp-validation-for="KiedyUtc" class="text-danger small"></span>
                    <div class="form-text">Wartość z formularza jest traktowana jako czas lokalny i zapisywana jako UTC.</div>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label asp-for="StareJson" class="form-label news-form-label">Stare JSON</label>
                    <textarea asp-for="StareJson" class="form-control news-form-control news-form-control--textarea" rows="5" placeholder="{ ... }"></textarea>
                    <span asp-validation-for="StareJson" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label asp-for="NoweJson" class="form-label news-form-label">Nowe JSON</label>
                    <textarea asp-for="NoweJson" class="form-control news-form-control news-form-control--textarea" rows="5" placeholder="{ ... }"></textarea>
                    <span asp-validation-for="NoweJson" class="text-danger small"></span>
                </div>
            </div>
            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary"><i class="bi bi-check2-circle"></i> Zapisz zmiany</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i> Anuluj</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}