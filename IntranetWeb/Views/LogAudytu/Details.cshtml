@model Interfaces.Magazyn.Dtos.LogAudytuDetailsDto

@{
    ViewData["Title"] = "Szczegóły wpisu audytu";
    var log = Model.Log;
    var actionClass = string.Equals(log.Akcja, "DELETE", StringComparison.OrdinalIgnoreCase)
        ? "entity-badge--danger"
        : string.Equals(log.Akcja, "UPDATE", StringComparison.OrdinalIgnoreCase)
            ? "entity-badge--warning"
            : string.Equals(log.Akcja, "CREATE", StringComparison.OrdinalIgnoreCase)
                ? "entity-badge--success"
                : "entity-badge--muted";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-journal-text"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Szczegóły wpisu audytu</h1>
                <p class="news-admin-header__subheading mb-0">Podgląd akcji, encji, czasu wykonania i danych przed/po zmianie.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@log.Id</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Akcja</span><strong class="news-admin-stat__value">@log.Akcja</strong></div>
        </div>
    </section>

    <section class="news-details-panel">
        <div class="news-details-panel__header">
            <h2 class="news-details-panel__title">@log.Encja</h2>
            <div class="news-details-panel__actions">
                <a asp-action="Edit" asp-route-id="@log.Id" class="btn btn-primary"><i class="bi bi-pencil-square me-1"></i> Edytuj</a>
                <a asp-action="Delete" asp-route-id="@log.Id" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i> Usuń</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Lista</a>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item"><div class="news-details-item__label">Akcja</div><div class="news-details-item__value"><span class="entity-badge @actionClass">@log.Akcja</span></div></div>
            <div class="news-details-item"><div class="news-details-item__label">Encja</div><div class="news-details-item__value">@log.Encja</div></div>
            <div class="news-details-item"><div class="news-details-item__label">ID encji</div><div class="news-details-item__value entity-mono">@(string.IsNullOrWhiteSpace(log.IdEncji) ? "-" : log.IdEncji)</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Użytkownik</div><div class="news-details-item__value">@(log.Uzytkownik?.Email ?? "System")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">UserId</div><div class="news-details-item__value">@(log.UserId?.ToString() ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Kiedy</div><div class="news-details-item__value">@log.KiedyUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div></div>
            <div class="news-details-item news-details-item--full">
                <div class="news-details-item__label">Stare JSON</div>
                <div class="news-details-item__value news-details-item__value--content">
                    @if (string.IsNullOrWhiteSpace(log.StareJson))
                    {
                        <span class="text-muted">Brak danych.</span>
                    }
                    else
                    {
                        <pre class="mb-0 entity-json-block">@log.StareJson</pre>
                    }
                </div>
            </div>
            <div class="news-details-item news-details-item--full">
                <div class="news-details-item__label">Nowe JSON</div>
                <div class="news-details-item__value news-details-item__value--content">
                    @if (string.IsNullOrWhiteSpace(log.NoweJson))
                    {
                        <span class="text-muted">Brak danych.</span>
                    }
                    else
                    {
                        <pre class="mb-0 entity-json-block">@log.NoweJson</pre>
                    }
                </div>
            </div>
        </div>
    </section>
</div>