@model IEnumerable<Data.Data.Magazyn.Lokacja>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Magazyn)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Kod)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Opis)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CzyAktywna)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Magazyn.Nazwa)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Kod)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Opis)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CzyAktywna)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.IdLokacji">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.IdLokacji">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.IdLokacji">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
