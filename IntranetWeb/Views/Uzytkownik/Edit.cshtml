@model Data.Data.Magazyn.Uzytkownik

@{
    ViewData["Title"] = "Edytuj uzytkownika";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-pencil-square"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Edytuj uzytkownika</h1>
                <p class="news-admin-header__subheading mb-0">Aktualizacja danych konta systemowego.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@Model.IdUzytkownika</strong></div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Edycja konta</h2>
            <p class="text-muted mb-0">Zmien login, hash hasla, email lub status aktywnosci.</p>
        </div>
        <form asp-action="Edit" method="post" class="news-editor-form" novalidate>
            <input type="hidden" asp-for="IdUzytkownika" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation" role="alert"></div>
            <div class="news-form-grid">
                <div class="news-form-field">
                    <label asp-for="Login" class="form-label news-form-label"></label>
                    <input asp-for="Login" class="form-control news-form-control" />
                    <span asp-validation-for="Login" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="Email" class="form-label news-form-label"></label>
                    <input asp-for="Email" class="form-control news-form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label asp-for="HashHasla" class="form-label news-form-label"></label>
                    <input asp-for="HashHasla" type="password" class="form-control news-form-control" autocomplete="new-password" />
                    <span asp-validation-for="HashHasla" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <div class="form-check form-switch mt-2">
                        <input class="form-check-input" asp-for="CzyAktywny" />
                        <label class="form-check-label news-form-label mb-0" asp-for="CzyAktywny"></label>
                    </div>
                    <span asp-validation-for="CzyAktywny" class="text-danger small"></span>
                </div>
            </div>
            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary"><i class="bi bi-check2-circle"></i> Zapisz zmiany</button>
                <a asp-action="Details" asp-route-id="@Model.IdUzytkownika" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegoly</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i> Anuluj</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
