@model Interfaces.Magazyn.Dtos.UzytkownikDeleteDto

@{
    ViewData["Title"] = "Usuń użytkownika";
    var user = Model.Uzytkownik;
}

<div class="news-admin-page">
    <section class="news-admin-header news-admin-header--danger">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon news-admin-header__icon--danger"><i class="bi bi-trash3"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Usuń użytkownika</h1>
                <p class="news-admin-header__subheading mb-0">Potwierdź usunięcie konta systemowego.</p>
            </div>
        </div>
    </section>

    <section class="news-delete-panel">
        <div class="news-delete-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>Usunięcie użytkownika</strong>
                <div>Operacja jest blokowana, jeśli konto ma powiązane rekordy (role, dokumenty, rezerwacje, logi audytu).</div>
            </div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mt-3" role="alert"></div>
        }

        <div class="news-details-grid">
            <div class="news-details-item"><div class="news-details-item__label">ID</div><div class="news-details-item__value">@user.IdUzytkownika</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Status</div><div class="news-details-item__value">@(user.CzyAktywny ? "Aktywny" : "Nieaktywny")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Login</div><div class="news-details-item__value">@user.Login</div></div>
            <div class="news-details-item"><div class="news-details-item__label">E-mail</div><div class="news-details-item__value">@user.Email</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Role</div><div class="news-details-item__value">@Model.LiczbaRol</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Klienci</div><div class="news-details-item__value">@Model.LiczbaKlientow</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Dokumenty PZ</div><div class="news-details-item__value">@Model.LiczbaDokumentowPz</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Dokumenty WZ</div><div class="news-details-item__value">@Model.LiczbaDokumentowWz</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Dokumenty MM</div><div class="news-details-item__value">@Model.LiczbaDokumentowMm</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Inwentaryzacje</div><div class="news-details-item__value">@Model.LiczbaInwentaryzacji</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Rezerwacje</div><div class="news-details-item__value">@Model.LiczbaRezerwacji</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Ruchy magazynowe</div><div class="news-details-item__value">@Model.LiczbaRuchow</div></div>
            <div class="news-details-item news-details-item--full"><div class="news-details-item__label">Logi audytu</div><div class="news-details-item__value">@Model.LiczbaLogowAudytu</div></div>
        </div>

        <form asp-action="Delete" method="post" class="news-form-actions">
            <input type="hidden" name="id" value="@user.IdUzytkownika" />
            <button type="submit" class="btn btn-danger news-form-actions__primary" @(Model.CzyMoznaUsunac ? null : "disabled")>
                <i class="bi bi-trash3-fill"></i> Usuń użytkownika
            </button>
            <a asp-action="Details" asp-route-id="@user.IdUzytkownika" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Anuluj</a>
        </form>
    </section>
</div>
