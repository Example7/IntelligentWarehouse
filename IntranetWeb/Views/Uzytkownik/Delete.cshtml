@model Data.Data.Magazyn.Uzytkownik

@{
    ViewData["Title"] = "Usun uzytkownika";
}

<div class="news-admin-page">
    <section class="news-admin-header news-admin-header--danger">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon news-admin-header__icon--danger"><i class="bi bi-trash3"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Usun uzytkownika</h1>
                <p class="news-admin-header__subheading mb-0">Potwierdz usuniecie konta systemowego.</p>
            </div>
        </div>
    </section>
    <section class="news-delete-panel">
        <div class="news-delete-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>Usuniecie uzytkownika</strong>
                <div>Sprawdz, czy konto nie jest powiazane z rolami lub historią operacji.</div>
            </div>
        </div>
        <div class="news-details-grid">
            <div class="news-details-item"><div class="news-details-item__label">ID</div><div class="news-details-item__value">@Model.IdUzytkownika</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Login</div><div class="news-details-item__value">@Model.Login</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Email</div><div class="news-details-item__value">@Model.Email</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Status</div><div class="news-details-item__value">@(Model.CzyAktywny ? "Aktywny" : "Nieaktywny")</div></div>
            <div class="news-details-item news-details-item--full"><div class="news-details-item__label">Haslo</div><div class="news-details-item__value">@(string.IsNullOrWhiteSpace(Model.HashHasla) ? "Brak" : "Ustawione (ukryte)")</div></div>
        </div>
        <form asp-action="Delete" method="post" class="news-form-actions">
            <input type="hidden" asp-for="IdUzytkownika" />
            <button type="submit" class="btn btn-danger news-form-actions__primary"><i class="bi bi-trash3-fill"></i> Usun uzytkownika</button>
            <a asp-action="Details" asp-route-id="@Model.IdUzytkownika" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegoly</a>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Anuluj</a>
        </form>
    </section>
</div>
