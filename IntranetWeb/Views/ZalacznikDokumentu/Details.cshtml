@model Data.Data.CMS.ZalacznikDokumentu

@{
    ViewData["Title"] = "Szczegóły załącznika dokumentu";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-paperclip"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Szczegóły załącznika dokumentu</h1>
                <p class="news-admin-header__subheading mb-0">Podgląd metadanych załącznika i powiązania z dokumentem.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@Model.Id</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Dokument</span><strong class="news-admin-stat__value">@Model.TypDokumentu / @Model.IdDokumentu</strong></div>
        </div>
    </section>

    <section class="news-details-panel">
        <div class="news-details-panel__header">
            <h2 class="news-details-panel__title">@Model.NazwaPliku</h2>
            <div class="news-details-panel__actions">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil-square me-1"></i> Edytuj</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i> Usuń</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Lista</a>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item"><div class="news-details-item__label">@Html.DisplayNameFor(m => m.TypDokumentu)</div><div class="news-details-item__value">@Html.DisplayFor(m => m.TypDokumentu)</div></div>
            <div class="news-details-item"><div class="news-details-item__label">@Html.DisplayNameFor(m => m.IdDokumentu)</div><div class="news-details-item__value">@Html.DisplayFor(m => m.IdDokumentu)</div></div>
            <div class="news-details-item"><div class="news-details-item__label">@Html.DisplayNameFor(m => m.NazwaPliku)</div><div class="news-details-item__value">@Html.DisplayFor(m => m.NazwaPliku)</div></div>
            <div class="news-details-item"><div class="news-details-item__label">@Html.DisplayNameFor(m => m.ContentType)</div><div class="news-details-item__value">@Html.DisplayFor(m => m.ContentType)</div></div>
            <div class="news-details-item"><div class="news-details-item__label">@Html.DisplayNameFor(m => m.WgranoUtc)</div><div class="news-details-item__value">@Model.WgranoUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">@Html.DisplayNameFor(m => m.Wgral)</div><div class="news-details-item__value">@(Model.Wgral?.Email ?? "-")</div></div>
            <div class="news-details-item news-details-item--full"><div class="news-details-item__label">@Html.DisplayNameFor(m => m.Sciezka)</div><div class="news-details-item__value entity-mono">@Html.DisplayFor(m => m.Sciezka)</div></div>
        </div>
    </section>
</div>
