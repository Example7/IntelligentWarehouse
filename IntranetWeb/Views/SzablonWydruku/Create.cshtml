@model Data.Data.CMS.SzablonWydruku

@{
    ViewData["Title"] = "Dodaj szablon wydruku";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon" aria-hidden="true"><i class="bi bi-plus-square"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Dodaj szablon wydruku</h1>
                <p class="news-admin-header__subheading mb-0">Utwórz nowy szablon dokumentu do wydruków.</p>
            </div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Metadane szablonu</h2>
            <p class="text-muted mb-0">Podaj typ dokumentu, wersję i nazwę, a następnie wgraj plik. Nazwa pliku i ścieżka ustawiają się automatycznie.</p>
        </div>
        <form asp-action="Create" method="post" enctype="multipart/form-data" class="news-editor-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation" role="alert"></div>
            <div class="news-form-grid">
                <div class="news-form-field">
                    <label asp-for="TypDokumentu" class="form-label news-form-label">Typ dokumentu</label>
                    <input asp-for="TypDokumentu" class="form-control news-form-control" placeholder="np. PZ, WZ, MM" />
                    <span asp-validation-for="TypDokumentu" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="Wersja" class="form-label news-form-label">Wersja</label>
                    <input asp-for="Wersja" class="form-control news-form-control" />
                    <span asp-validation-for="Wersja" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label asp-for="Nazwa" class="form-label news-form-label">Nazwa</label>
                    <input asp-for="Nazwa" class="form-control news-form-control" />
                    <span asp-validation-for="Nazwa" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label class="form-label news-form-label" for="templateFile">Plik szablonu</label>
                    <input id="templateFile" name="templateFile" type="file" class="form-control news-form-control" accept=".docx,.html,.htm,.txt,.md" required />
                    <div class="form-text">Wymagane. Plik zostanie zapisany do katalogu <code>Templates/{typ}</code>, a ścieżka ustawi się automatycznie.</div>
                    <span asp-validation-for="Sciezka" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <div class="form-check news-form-check">
                        <input class="form-check-input" asp-for="CzyAktywny" />
                        <label class="form-check-label" asp-for="CzyAktywny">Aktywny</label>
                    </div>
                </div>
            </div>
            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary"><i class="bi bi-check2-circle"></i> Zapisz szablon</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Wróć do listy</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}