@model Data.Data.CMS.SzablonWydruku

@{
    ViewData["Title"] = "Edytuj szablon wydruku";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon" aria-hidden="true"><i class="bi bi-pencil-square"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Edytuj szablon wydruku</h1>
                <p class="news-admin-header__subheading mb-0">Aktualizacja metadanych i aktywności szablonu.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@Model.Id</strong></div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Edycja szablonu</h2>
            <p class="text-muted mb-0">Możesz zmienić typ, wersję, nazwę i status. Podmiana pliku jest opcjonalna.</p>
        </div>
        <form asp-action="Edit" method="post" enctype="multipart/form-data" class="news-editor-form" novalidate>
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation" role="alert"></div>
            <div class="news-form-grid">
                <div class="news-form-field">
                    <label asp-for="TypDokumentu" class="form-label news-form-label">Typ dokumentu</label>
                    <input asp-for="TypDokumentu" class="form-control news-form-control" />
                    <span asp-validation-for="TypDokumentu" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="Wersja" class="form-label news-form-label">Wersja</label>
                    <input asp-for="Wersja" class="form-control news-form-control" />
                    <span asp-validation-for="Wersja" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label asp-for="Nazwa" class="form-label news-form-label">Nazwa</label>
                    <input asp-for="Nazwa" class="form-control news-form-control" />
                    <span asp-validation-for="Nazwa" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label class="form-label news-form-label">Aktualny plik</label>
                    <input class="form-control news-form-control" value="@Model.NazwaPliku" readonly />
                </div>
                <div class="news-form-field">
                    <label class="form-label news-form-label">Wgrano</label>
                    <input class="form-control news-form-control" value="@Model.WgranoUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")" readonly />
                </div>
                <div class="news-form-field news-form-field--full">
                    <label class="form-label news-form-label" for="templateFile">Nowy plik szablonu (opcjonalnie)</label>
                    <input id="templateFile" name="templateFile" type="file" class="form-control news-form-control" accept=".docx,.html,.htm,.txt,.md" />
                    <div class="form-text">Po podmianie pliku system automatycznie zaktualizuje nazwę pliku i ścieżkę.</div>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label class="form-label news-form-label">Ścieżka</label>
                    <input class="form-control news-form-control" value="@Model.Sciezka" readonly />
                </div>
                <div class="news-form-field news-form-field--full">
                    <div class="form-check news-form-check">
                        <input class="form-check-input" asp-for="CzyAktywny" />
                        <label class="form-check-label" asp-for="CzyAktywny">Aktywny</label>
                    </div>
                </div>
            </div>
            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary"><i class="bi bi-check2-circle"></i> Zapisz zmiany</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i> Anuluj</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}