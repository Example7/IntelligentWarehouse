@model Interfaces.CMS.Dtos.SzablonWydrukuDetailsDto

@{
    ViewData["Title"] = "Szczegóły szablonu wydruku";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon" aria-hidden="true"><i class="bi bi-file-earmark-text"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Szczegóły szablonu wydruku</h1>
                <p class="news-admin-header__subheading mb-0">Podgląd wersji i metadanych szablonu dokumentu.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@Model.Id</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Wersja</span><strong class="news-admin-stat__value">@Model.Wersja</strong></div>
        </div>
    </section>

    <section class="news-details-panel">
        <div class="news-details-panel__header">
            <h2 class="news-details-panel__title">@Model.Nazwa</h2>
            <div class="news-details-panel__actions">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil-square me-1"></i> Edytuj</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i> Usuń</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Lista</a>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item">
                <div class="news-details-item__label">Typ dokumentu</div>
                <div class="news-details-item__value">@Model.TypDokumentu</div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Wersja</div>
                <div class="news-details-item__value">@Model.Wersja</div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Status</div>
                <div class="news-details-item__value">@(Model.CzyAktywny ? "Aktywny" : "Nieaktywny")</div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Wgrano</div>
                <div class="news-details-item__value">@Model.WgranoUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div>
            </div>
            <div class="news-details-item news-details-item--full">
                <div class="news-details-item__label">Nazwa szablonu</div>
                <div class="news-details-item__value">@Model.Nazwa</div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Nazwa pliku</div>
                <div class="news-details-item__value">@Model.NazwaPliku</div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Wgrał</div>
                <div class="news-details-item__value">@(string.IsNullOrWhiteSpace(Model.WgralEmail) ? "-" : Model.WgralEmail)</div>
            </div>
            <div class="news-details-item news-details-item--full">
                <div class="news-details-item__label">Ścieżka</div>
                <div class="news-details-item__value entity-mono">@Model.Sciezka</div>
            </div>
        </div>
    </section>
</div>
