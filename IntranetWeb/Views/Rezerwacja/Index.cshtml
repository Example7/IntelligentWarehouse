@model Interfaces.Magazyn.Dtos.RezerwacjaIndexDto
@{
    ViewData["Title"] = "Rezerwacje";
    var items = Model.Items.ToList();
    var searchTerm = Model.SearchTerm ?? string.Empty;
    var draftCount = items.Count(x => string.Equals(x.Status, "Draft", StringComparison.OrdinalIgnoreCase));
    var activeCount = items.Count(x => string.Equals(x.Status, "Active", StringComparison.OrdinalIgnoreCase));
    var completedCount = items.Count(x => string.Equals(x.Status, "Completed", StringComparison.OrdinalIgnoreCase));
}
<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-bookmark-check"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Rezerwacje</h1>
                <p class="news-admin-header__subheading mb-0">Rejestr rezerwacji magazynowych z filtrowaniem i szybkim CRUD.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">Łącznie</span><strong class="news-admin-stat__value">@items.Count</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Draft</span><strong class="news-admin-stat__value">@draftCount</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Active</span><strong class="news-admin-stat__value">@activeCount</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Completed</span><strong class="news-admin-stat__value">@completedCount</strong></div>
        </div>
    </section>
    <section class="news-admin-toolbar">
        <form method="get" class="news-admin-search" role="search">
            <div class="news-admin-search__input-wrap"><i class="bi bi-search news-admin-search__icon"></i><input class="form-control news-admin-search__input" name="searchTerm" value="@searchTerm" placeholder="Szukaj po numerze, statusie, magazynie lub notatce..." /></div>
            <button class="btn btn-primary news-admin-search__submit" type="submit">Szukaj</button>
            @if (!string.IsNullOrWhiteSpace(searchTerm)) { <a class="btn btn-outline-secondary news-admin-search__clear" href="@Url.Action("Index")"><i class="bi bi-x-lg"></i></a> }
        </form>
        <a class="btn news-admin-toolbar__cta" asp-action="Create"><i class="bi bi-plus-circle"></i> Dodaj rezerwacje</a>
    </section>
    @if (!items.Any())
    {
        <section class="news-admin-empty"><div class="news-admin-empty__icon"><i class="bi bi-inbox"></i></div><h2 class="h4 mb-2">Brak rezerwacji</h2></section>
    }
    else
    {
        <section class="entity-table-panel"><div class="entity-table-wrap"><table class="table table-hover align-middle mb-0 entity-table"><thead><tr><th>Numer</th><th>Magazyn</th><th>Status</th><th>Utworzono</th><th>Wygasa</th><th>Utworzył</th><th>Notatka</th><th class="text-end">Akcje</th></tr></thead><tbody>
        @foreach (var item in items.OrderByDescending(x => x.UtworzonoUtc).ThenByDescending(x => x.Id))
        {
            var statusClass = string.Equals(item.Status, "Active", StringComparison.OrdinalIgnoreCase) ? "entity-badge--success" : string.Equals(item.Status, "Draft", StringComparison.OrdinalIgnoreCase) ? "entity-badge--warning" : string.Equals(item.Status, "Completed", StringComparison.OrdinalIgnoreCase) ? "entity-badge--info" : "entity-badge--muted";
            var canEdit = !string.Equals(item.Status, "Completed", StringComparison.OrdinalIgnoreCase) && !string.Equals(item.Status, "Cancelled", StringComparison.OrdinalIgnoreCase) && !string.Equals(item.Status, "Released", StringComparison.OrdinalIgnoreCase);
            <tr>
                <td><div class="entity-cell-title">@item.Numer</div></td>
                <td>@(item.Magazyn?.Nazwa ?? "-")</td>
                <td><span class="entity-badge @statusClass">@item.Status</span></td>
                <td>@item.UtworzonoUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                <td>@(item.WygasaUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                <td>@(item.Utworzyl?.Email ?? "-")</td>
                <td><div class="entity-cell-subtitle text-truncate" title="@item.Notatka">@(string.IsNullOrWhiteSpace(item.Notatka) ? "-" : item.Notatka)</div></td>
                <td class="text-end"><div class="btn-group btn-group-sm">@if (canEdit){<a class="btn btn-outline-warning" asp-action="Edit" asp-route-id="@item.Id" title="Edytuj"><i class="bi bi-pencil"></i></a>} else {<button type="button" class="btn btn-outline-secondary" disabled title="Edycja zablokowana"><i class="bi bi-pencil"></i></button>}<a class="btn btn-outline-info" asp-action="Details" asp-route-id="@item.Id" title="Szczegóły"><i class="bi bi-eye"></i></a><a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id" title="Usuń"><i class="bi bi-trash"></i></a></div></td>
            </tr>
        }
        </tbody></table></div></section>
    }
</div>
