@model IEnumerable<Data.Data.Magazyn.Rezerwacja>

@{
    ViewData["Title"] = "Rezerwacje";
    var items = Model.ToList();
    var searchTerm = Context.Request.Query["searchTerm"].ToString();
    var activeCount = items.Count(x => !x.WygasaUtc.HasValue || x.WygasaUtc > DateTime.UtcNow);
    var expiredCount = items.Count(x => x.WygasaUtc.HasValue && x.WygasaUtc <= DateTime.UtcNow);
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon" aria-hidden="true"><i class="bi bi-bookmark-check"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Rezerwacje</h1>
                <p class="news-admin-header__subheading mb-0">Rejestr rezerwacji magazynowych z filtrowaniem i szybkim CRUD.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">Łącznie</span><strong class="news-admin-stat__value">@items.Count</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Aktywne</span><strong class="news-admin-stat__value">@activeCount</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Wygasłe</span><strong class="news-admin-stat__value">@expiredCount</strong></div>
        </div>
    </section>

    <section class="news-admin-toolbar">
        <form method="get" class="news-admin-search" role="search" aria-label="Wyszukiwanie rezerwacji">
            <label for="reservationSearchTerm" class="visually-hidden">Szukaj rezerwacji</label>
            <div class="news-admin-search__input-wrap">
                <i class="bi bi-search news-admin-search__icon" aria-hidden="true"></i>
                <input id="reservationSearchTerm" class="form-control news-admin-search__input" name="searchTerm" value="@searchTerm"
                       placeholder="Szukaj po numerze, statusie lub notatce..." />
            </div>
            <button class="btn btn-primary news-admin-search__submit" type="submit">Szukaj</button>
            @if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                <a class="btn btn-outline-secondary news-admin-search__clear" href="@Url.Action("Index")" title="Wyczyść filtr"><i class="bi bi-x-lg"></i></a>
            }
        </form>
        <a class="btn news-admin-toolbar__cta" asp-action="Create"><i class="bi bi-plus-circle"></i> Dodaj rezerwacje</a>
    </section>

    @if (!items.Any())
    {
        <section class="news-admin-empty">
            <div class="news-admin-empty__icon"><i class="bi bi-bookmark-x"></i></div>
            <h2 class="h4 mb-2">Brak rezerwacji</h2>
            <p class="text-muted mb-3">
                @if (string.IsNullOrWhiteSpace(searchTerm))
                {
                    <span>Nie dodano jeszcze żadnych rezerwacji magazynowych.</span>
                }
                else
                {
                    <span>Brak wyników dla frazy: <strong>@searchTerm</strong>.</span>
                }
            </p>
            <div class="d-flex justify-content-center gap-2 flex-wrap">
                <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-circle me-1"></i> Dodaj rezerwacje</a>
                @if (!string.IsNullOrWhiteSpace(searchTerm))
                {
                    <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Wyczyść filtr</a>
                }
            </div>
        </section>
    }
    else
    {
        <section class="entity-table-panel">
            <div class="entity-table-wrap">
                <table class="table table-hover align-middle mb-0 entity-table">
                    <thead>
                        <tr>
                            <th>Numer</th>
                            <th>Magazyn</th>
                            <th>Status</th>
                            <th>Utworzono</th>
                            <th>Wygasa</th>
                            <th>Utworzył</th>
                            <th>Notatka</th>
                            <th class="text-end">Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in items.OrderByDescending(x => x.UtworzonoUtc).ThenByDescending(x => x.Id))
                    {
                        var isExpired = item.WygasaUtc.HasValue && item.WygasaUtc <= DateTime.UtcNow;
                        var statusClass = isExpired ? "entity-badge--danger"
                            : string.Equals(item.Status, "Draft", StringComparison.OrdinalIgnoreCase) ? "entity-badge--warning"
                            : "entity-badge--success";
                        <tr>
                            <td><div class="entity-cell-title">@item.Numer</div></td>
                            <td>@(item.Magazyn?.Nazwa ?? "-")</td>
                            <td><span class="entity-badge @statusClass">@item.Status</span></td>
                            <td>@item.UtworzonoUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(item.WygasaUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                            <td>@(item.Utworzyl?.Email ?? "-")</td>
                            <td>
                                <div class="entity-cell-subtitle text-truncate" title="@item.Notatka">
                                    @(string.IsNullOrWhiteSpace(item.Notatka) ? "-" : item.Notatka)
                                </div>
                            </td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm" role="group" aria-label="Akcje dla rezerwacji @item.Numer">
                                    <a class="btn btn-outline-warning" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil"></i></a>
                                    <a class="btn btn-outline-info" asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye"></i></a>
                                    <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>
