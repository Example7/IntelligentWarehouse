@model Interfaces.Magazyn.Dtos.DokumentPZIndexDto

@{
    var isAdmin = User?.IsInRole("Admin") ?? false;
    ViewData["Title"] = "Przyjęcia PZ";
    var items = Model.Items.ToList();
    var searchTerm = Model.SearchTerm ?? string.Empty;
    var postedCount = items.Count(x => string.Equals(x.Status, "Posted", StringComparison.OrdinalIgnoreCase));
    var draftCount = items.Count(x => string.Equals(x.Status, "Draft", StringComparison.OrdinalIgnoreCase));
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon" aria-hidden="true"><i class="bi bi-box-arrow-in-down"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Przyjęcia PZ</h1>
                <p class="news-admin-header__subheading mb-0">Rejestr dokumentów przyjęcia z filtrowaniem i szybkim CRUD.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">Łącznie</span><strong class="news-admin-stat__value">@items.Count</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Posted</span><strong class="news-admin-stat__value">@postedCount</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Draft</span><strong class="news-admin-stat__value">@draftCount</strong></div>
        </div>
    </section>

    <section class="news-admin-toolbar">
        <form method="get" class="news-admin-search" role="search" aria-label="Wyszukiwanie dokumentów PZ">
            <label for="pzSearchTerm" class="visually-hidden">Szukaj dokumentów PZ</label>
            <div class="news-admin-search__input-wrap">
                <i class="bi bi-search news-admin-search__icon" aria-hidden="true"></i>
                <input id="pzSearchTerm" class="form-control news-admin-search__input" name="searchTerm" value="@searchTerm"
                       placeholder="Szukaj po numerze, statusie lub notatce..." />
            </div>
            <button class="btn btn-primary news-admin-search__submit" type="submit">Szukaj</button>
            @if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                <a class="btn btn-outline-secondary news-admin-search__clear" href="@Url.Action("Index")" title="Wyczyść filtr"><i class="bi bi-x-lg"></i></a>
            }
        </form>
        <a class="btn news-admin-toolbar__cta" asp-action="Create"><i class="bi bi-plus-circle"></i> Dodaj PZ</a>
    </section>

    @if (!items.Any())
    {
        <section class="news-admin-empty">
            <div class="news-admin-empty__icon"><i class="bi bi-inbox"></i></div>
            <h2 class="h4 mb-2">Brak dokumentów PZ</h2>
            <p class="text-muted mb-3">
                @if (string.IsNullOrWhiteSpace(searchTerm))
                {
                    <span>Nie dodano jeszcze żadnych przyjęć magazynowych.</span>
                }
                else
                {
                    <span>Brak wyników dla frazy: <strong>@searchTerm</strong>.</span>
                }
            </p>
            <div class="d-flex justify-content-center gap-2 flex-wrap">
                <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-circle me-1"></i> Dodaj PZ</a>
                @if (!string.IsNullOrWhiteSpace(searchTerm))
                {
                    <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Wyczyść filtr</a>
                }
            </div>
        </section>
    }
    else
    {
        <section class="entity-table-panel">
            <div class="entity-table-wrap">
                <table class="table table-hover align-middle mb-0 entity-table">
                    <thead>
                        <tr>
                            <th>Numer</th>
                            <th>Magazyn</th>
                            <th>Dostawca</th>
                            <th>Status</th>
                            <th>Data przyjęcia</th>
                            <th>Utworzony przez</th>
                            <th>Zaksięgowano</th>
                            <th>Notatka</th>
                            <th class="text-end">Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in items.OrderByDescending(x => x.DataPrzyjeciaUtc).ThenByDescending(x => x.Id))
                    {
                        var statusClass = string.Equals(item.Status, "Posted", StringComparison.OrdinalIgnoreCase)
                            ? "entity-badge--success"
                            : string.Equals(item.Status, "Draft", StringComparison.OrdinalIgnoreCase)
                                ? "entity-badge--warning"
                                : "entity-badge--muted";
                        <tr>
                            <td><div class="entity-cell-title">@item.Numer</div></td>
                            <td>@(item.Magazyn?.Nazwa ?? "-")</td>
                            <td>@(item.Dostawca?.Nazwa ?? "-")</td>
                            <td><span class="entity-badge @statusClass">@item.Status</span></td>
                            <td>@item.DataPrzyjeciaUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(item.Utworzyl?.Email ?? "-")</td>
                            <td>@(item.ZaksiegowanoUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                            <td>
                                <div class="entity-cell-subtitle text-truncate" title="@item.Notatka">
                                    @(string.IsNullOrWhiteSpace(item.Notatka) ? "-" : item.Notatka)
                                </div>
                            </td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm" role="group" aria-label="Akcje dla dokumentu PZ @item.Numer">
                                    <a class="btn btn-outline-warning" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil"></i></a>
                                    <a class="btn btn-outline-info" asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye"></i></a>
                                    @if (isAdmin)
                                    {
                                        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id"><i class="bi bi-trash"></i></a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>