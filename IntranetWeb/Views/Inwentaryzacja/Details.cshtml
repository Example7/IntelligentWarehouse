@model Interfaces.Magazyn.Dtos.InwentaryzacjaDetailsDto

@{
    ViewData["Title"] = "Szczegóły inwentaryzacji";
    var d = Model.Dokument;
    var isDraft = string.Equals(d.Status, "Draft", StringComparison.OrdinalIgnoreCase);
    var isClosed = string.Equals(d.Status, "Closed", StringComparison.OrdinalIgnoreCase);
    var statusClass = isClosed ? "entity-badge--success" : isDraft ? "entity-badge--warning" : "entity-badge--muted";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-clipboard-check"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Szczegóły inwentaryzacji</h1>
                <p class="news-admin-header__subheading mb-0">Podgląd dokumentu inwentaryzacji, statusu oraz pozycji liczenia.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">Pozycje</span><strong class="news-admin-stat__value">@Model.LiczbaPozycji</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Status</span><strong class="news-admin-stat__value">@d.Status</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@d.Id</strong></div>
        </div>
    </section>

    @if (TempData["InwentaryzacjaEditBlocked"] is string blocked && !string.IsNullOrWhiteSpace(blocked))
    {
        <div class="alert alert-warning mt-3"><i class="bi bi-exclamation-triangle me-1"></i>@blocked</div>
    }
    @if (TempData["InwentaryzacjaCloseSuccess"] is string ok && !string.IsNullOrWhiteSpace(ok))
    {
        <div class="alert alert-success mt-3"><i class="bi bi-check-circle me-1"></i>@ok</div>
    }
    @if (TempData["InwentaryzacjaCloseError"] is string err && !string.IsNullOrWhiteSpace(err))
    {
        <div class="alert alert-danger mt-3"><i class="bi bi-exclamation-octagon me-1"></i>@err</div>
    }

    <section class="news-details-panel">
        <div class="news-details-panel__header">
            <h2 class="news-details-panel__title">@d.Numer</h2>
            <div class="news-details-panel__actions">
                @if (isDraft)
                {
                    <a asp-action="Edit" asp-route-id="@d.Id" class="btn btn-primary"><i class="bi bi-pencil-square me-1"></i> Edytuj</a>
                    <form asp-action="CloseDocument" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@d.Id" />
                        <button type="submit" class="btn btn-outline-success"><i class="bi bi-check2-circle me-1"></i> Zamknij</button>
                    </form>
                }
                else
                {
                    <button type="button" class="btn btn-outline-secondary" disabled title="Edycja tylko dla Draft"><i class="bi bi-pencil-square me-1"></i> Edytuj</button>
                }
                <a asp-action="Delete" asp-route-id="@d.Id" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i> Usuń</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Lista</a>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item"><div class="news-details-item__label">Numer</div><div class="news-details-item__value entity-mono">@d.Numer</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Status</div><div class="news-details-item__value"><span class="entity-badge @statusClass">@d.Status</span></div></div>
            <div class="news-details-item"><div class="news-details-item__label">Magazyn</div><div class="news-details-item__value">@(d.Magazyn?.Nazwa ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Utworzył</div><div class="news-details-item__value">@(d.Utworzyl?.Email ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Data rozpoczęcia</div><div class="news-details-item__value">@d.StartUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Zakończono</div><div class="news-details-item__value">@(d.KoniecUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Suma oczekiwana (mieszane JM)</div><div class="news-details-item__value">@Model.SumaOczekiwana.ToString("0.###")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Suma policzona (mieszane JM)</div><div class="news-details-item__value">@Model.SumaPoliczona.ToString("0.###")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Suma różnic (mieszane JM)</div><div class="news-details-item__value">@Model.SumaRoznic.ToString("+0.###;-0.###;0")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Pozycji</div><div class="news-details-item__value">@Model.LiczbaPozycji</div></div>
            <div class="news-details-item news-details-item--full"><div class="news-details-item__label">Notatka</div><div class="news-details-item__value news-details-item__value--content">@(string.IsNullOrWhiteSpace(d.Notatka) ? "Brak notatki" : d.Notatka)</div></div>
        </div>
    </section>

    <section class="entity-table-panel mt-3">
        <div class="entity-table-panel__header d-flex justify-content-between align-items-center flex-wrap gap-2 px-3 py-2">
            <div>
                <h3 class="mb-0 h5">Pozycje inwentaryzacji (@Model.LiczbaPozycji)</h3>
                <div class="text-muted small">Pozycje liczenia przypisane do tego dokumentu.</div>
            </div>
            <a class="btn btn-sm btn-outline-secondary" asp-controller="PozycjaInwentaryzacji" asp-action="Index"><i class="bi bi-list-ul me-1"></i> Lista pozycji</a>
        </div>

        @if (!Model.Pozycje.Any())
        {
            <div class="news-admin-empty py-4">
                <div class="news-admin-empty__icon"><i class="bi bi-list-task"></i></div>
                <h4 class="h6 mb-1">Brak pozycji inwentaryzacji</h4>
                <p class="text-muted mb-0">Ten dokument nie ma jeszcze żadnych pozycji.</p>
            </div>
        }
        else
        {
            <div class="entity-table-wrap">
                <table class="table table-hover align-middle mb-0 entity-table">
                    <thead>
                        <tr>
                            <th class="text-end">Lp</th>
                            <th>Produkt</th>
                            <th>Lokacja</th>
                            <th class="text-end">Oczekiwana</th>
                            <th class="text-end">Policzona</th>
                            <th class="text-end">Różnica</th>
                            <th class="text-end">Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var p in Model.Pozycje)
                    {
                        var jm = p.Produkt?.DomyslnaJednostka?.Kod ?? "j.m.";
                        var roznica = p.IloscPoliczona - p.IloscOczekiwana;
                        var diffClass = roznica > 0 ? "text-success" : roznica < 0 ? "text-danger" : "text-muted";
                        <tr>
                            <td class="text-end">@p.Lp</td>
                            <td><div class="entity-cell-title">@(p.Produkt?.Kod ?? "-")</div><div class="entity-cell-subtitle">@(p.Produkt?.Nazwa ?? "Brak nazwy")</div></td>
                            <td><div class="entity-cell-title">@(p.Lokacja?.Kod ?? "-")</div><div class="entity-cell-subtitle">@(p.Lokacja?.Magazyn?.Nazwa ?? "-")</div></td>
                            <td class="text-end">@p.IloscOczekiwana.ToString("0.###") @jm</td>
                            <td class="text-end">@p.IloscPoliczona.ToString("0.###") @jm</td>
                            <td class="text-end"><span class="@diffClass">@roznica.ToString("+0.###;-0.###;0") @jm</span></td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <a class="btn btn-outline-info" asp-controller="PozycjaInwentaryzacji" asp-action="Details" asp-route-id="@p.Id"><i class="bi bi-eye"></i></a>
                                    @if (isDraft)
                                    {
                                        <a class="btn btn-outline-warning" asp-controller="PozycjaInwentaryzacji" asp-action="Edit" asp-route-id="@p.Id"><i class="bi bi-pencil"></i></a>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-outline-secondary" disabled title="Edycja tylko dla Draft"><i class="bi bi-pencil"></i></button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>
