@model IEnumerable<Data.Data.Magazyn.Kategoria>

@{
    ViewData["Title"] = "Kategorie";
    var items = Model.ToList();
    var searchTerm = Context.Request.Query["searchTerm"].ToString();
    var rootCount = items.Count(x => x.IdNadrzednejKategorii == null);
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-tags"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Kategorie</h1>
                <p class="news-admin-header__subheading mb-0">Struktura kategorii produktów i relacje nadrzędne.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">Łącznie</span><strong class="news-admin-stat__value">@items.Count</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Główne</span><strong class="news-admin-stat__value">@rootCount</strong></div>
        </div>
    </section>

    <section class="news-admin-toolbar">
        <form method="get" class="news-admin-search" role="search" aria-label="Wyszukiwanie kategorii">
            <label for="categorySearchTerm" class="visually-hidden">Szukaj kategorii</label>
            <div class="news-admin-search__input-wrap">
                <i class="bi bi-search news-admin-search__icon"></i>
                <input id="categorySearchTerm" class="form-control news-admin-search__input" name="searchTerm" value="@searchTerm"
                       placeholder="Szukaj po nazwie lub ścieżce..." />
            </div>
            <button class="btn btn-primary news-admin-search__submit" type="submit">Szukaj</button>
            @if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                <a class="btn btn-outline-secondary news-admin-search__clear" href="@Url.Action("Index")"><i class="bi bi-x-lg"></i></a>
            }
        </form>
        <a class="btn news-admin-toolbar__cta" asp-action="Create"><i class="bi bi-plus-circle"></i> Dodaj kategorię</a>
    </section>

    @if (!items.Any())
    {
        <section class="news-admin-empty">
            <div class="news-admin-empty__icon"><i class="bi bi-tags"></i></div>
            <h2 class="h4 mb-2">Brak kategorii</h2>
            <p class="text-muted mb-3">Dodaj pierwszą kategorię, aby zbudować strukturę katalogu produktów.</p>
            <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-circle me-1"></i> Dodaj kategorię</a>
        </section>
    }
    else
    {
        <div class="news-admin-grid">
            @foreach (var item in items.OrderBy(x => x.Sciezka ?? x.Nazwa))
            {
                <article class="news-card">
                    <div class="news-card__accent"></div>
                    <div class="news-card__body">
                        <div class="news-card__meta-top">
                            <span class="news-card__badge"><i class="bi bi-diagram-3"></i> ID @item.IdKategorii</span>
                            <span class="news-card__position">@(item.IdNadrzednejKategorii is null ? "Główna" : "Podkategoria")</span>
                        </div>
                        <h2 class="news-card__title" title="@item.Nazwa">@item.Nazwa</h2>
                        <p class="news-card__content" title="@item.Sciezka">@(string.IsNullOrWhiteSpace(item.Sciezka) ? "Brak zdefiniowanej ścieżki." : item.Sciezka)</p>
                        <div class="entity-inline-meta">
                            <span class="entity-inline-meta__label">Nadrzędna:</span>
                            <span class="entity-inline-meta__value">@(item.NadrzednaKategoria?.Nazwa ?? "-")</span>
                        </div>
                        <div class="news-card__footer">
                            <div class="btn-group btn-group-sm" role="group" aria-label="Akcje dla kategorii @item.Nazwa">
                                <a class="btn btn-outline-warning" asp-action="Edit" asp-route-id="@item.IdKategorii"><i class="bi bi-pencil"></i></a>
                                <a class="btn btn-outline-info" asp-action="Details" asp-route-id="@item.IdKategorii"><i class="bi bi-eye"></i></a>
                                <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@item.IdKategorii"><i class="bi bi-trash"></i></a>
                            </div>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</div>
