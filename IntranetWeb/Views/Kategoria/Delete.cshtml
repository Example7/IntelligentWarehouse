@model Data.Data.Magazyn.Kategoria

@{
    ViewData["Title"] = "Usuń kategorię";
}

<div class="news-admin-page">
    <section class="news-admin-header news-admin-header--danger">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon news-admin-header__icon--danger"><i class="bi bi-trash3"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Usuń kategorię</h1>
                <p class="news-admin-header__subheading mb-0">Potwierdź usunięcie kategorii z katalogu.</p>
            </div>
        </div>
    </section>

    <section class="news-delete-panel">
        <div class="news-delete-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>Usunięcie kategorii</strong>
                <div>Operacja może być zablokowana, jeśli istnieją powiązania z produktami lub podkategoriami.</div>
            </div>
        </div>
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
        <div class="news-details-grid">
            <div class="news-details-item"><div class="news-details-item__label">ID</div><div class="news-details-item__value">@Model.IdKategorii</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Nazwa</div><div class="news-details-item__value">@Model.Nazwa</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Nadrzędna</div><div class="news-details-item__value">@(Model.NadrzednaKategoria?.Nazwa ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Przypisane produkty</div><div class="news-details-item__value">@((int?)ViewBag.LiczbaProduktow ?? 0)</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Podkategorie</div><div class="news-details-item__value">@((int?)ViewBag.LiczbaPodkategorii ?? 0)</div></div>
            <div class="news-details-item news-details-item--full">
                <div class="news-details-item__label">Ścieżka</div>
                <div class="news-details-item__value news-details-item__value--content">@(string.IsNullOrWhiteSpace(Model.Sciezka) ? "Brak ścieżki" : Model.Sciezka)</div>
            </div>
        </div>
        <form asp-action="Delete" method="post" class="news-form-actions">
            <input type="hidden" asp-for="IdKategorii" />
            <button type="submit" class="btn btn-danger news-form-actions__primary" disabled="@(!(bool)(ViewBag.CzyMoznaUsunac ?? false))"><i class="bi bi-trash3-fill"></i> Usuń kategorię</button>
            <a asp-action="Details" asp-route-id="@Model.IdKategorii" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Anuluj</a>
        </form>
    </section>
</div>
