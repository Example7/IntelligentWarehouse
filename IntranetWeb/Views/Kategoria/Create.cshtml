@model Data.Data.Magazyn.Kategoria

@{
    ViewData["Title"] = "Dodaj kategorię";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-plus-square"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Dodaj kategorię</h1>
                <p class="news-admin-header__subheading mb-0">Utwórz kategorię główną lub podkategorię.</p>
            </div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Dane kategorii</h2>
            <p class="text-muted mb-0">Określ nazwę, ścieżkę i kategorię nadrzędną (opcjonalnie).</p>
        </div>

        <form asp-action="Create" method="post" class="news-editor-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation" role="alert"></div>
            <div class="news-form-grid">
                <div class="news-form-field news-form-field--full">
                    <label asp-for="IdNadrzednejKategorii" class="form-label news-form-label"></label>
                    <select asp-for="IdNadrzednejKategorii" class="form-select news-form-control" asp-items="ViewBag.IdNadrzednejKategorii">
                        <option value="">(brak - kategoria główna)</option>
                    </select>
                    <span asp-validation-for="IdNadrzednejKategorii" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label asp-for="Nazwa" class="form-label news-form-label"></label>
                    <input asp-for="Nazwa" class="form-control news-form-control" />
                    <span asp-validation-for="Nazwa" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label asp-for="Sciezka" class="form-label news-form-label"></label>
                    <input asp-for="Sciezka" class="form-control news-form-control" />
                    <span asp-validation-for="Sciezka" class="text-danger small"></span>
                </div>
            </div>
            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary"><i class="bi bi-check2-circle"></i> Zapisz kategorię</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Wróć do listy</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
