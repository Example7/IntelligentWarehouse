@model IntranetWeb.Models.Klient.KlientDetailsPageViewModel

@{
    var isAdmin = User?.IsInRole("Admin") ?? false;
    ViewData["Title"] = "Szczegóły klienta";
    var details = Model.Details;
    var klient = details.Klient;
    var ostatnieWz = details.OstatnieDokumentyWz;
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-people"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Szczegóły klienta</h1>
                <p class="news-admin-header__subheading mb-0">Podgląd danych kontaktowych i ostatnich dokumentów WZ klienta.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">Dokumenty WZ</span><strong class="news-admin-stat__value">@details.LiczbaDokumentowWz</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Posted</span><strong class="news-admin-stat__value">@details.LiczbaDokumentowWzPosted</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Draft</span><strong class="news-admin-stat__value">@details.LiczbaDokumentowWzDraft</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@klient.IdKlienta</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Status</span><strong class="news-admin-stat__value">@(klient.CzyAktywny ? "Aktywny" : "Nieaktywny")</strong></div>
        </div>
    </section>

    <section class="news-details-panel">
        <div class="news-details-panel__header">
            <h2 class="news-details-panel__title">@klient.Nazwa</h2>
            <div class="news-details-panel__actions">
                <a asp-action="Edit" asp-route-id="@klient.IdKlienta" class="btn btn-primary"><i class="bi bi-pencil-square me-1"></i> Edytuj</a>
                @if (isAdmin)
                {
                <a asp-action="Delete" asp-route-id="@klient.IdKlienta" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i> Usuń</a>
                }
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Lista</a>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item"><div class="news-details-item__label">Nazwa</div><div class="news-details-item__value">@klient.Nazwa</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Email</div><div class="news-details-item__value">@(string.IsNullOrWhiteSpace(klient.Email) ? "-" : klient.Email)</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Telefon</div><div class="news-details-item__value">@(string.IsNullOrWhiteSpace(klient.Telefon) ? "-" : klient.Telefon)</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Status</div><div class="news-details-item__value">@(klient.CzyAktywny ? "Aktywny" : "Nieaktywny")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Utworzono</div><div class="news-details-item__value">@klient.UtworzonoUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Dokumenty WZ</div><div class="news-details-item__value">@details.LiczbaDokumentowWz</div></div>
            <div class="news-details-item"><div class="news-details-item__label">WZ posted / draft</div><div class="news-details-item__value">@details.LiczbaDokumentowWzPosted / @details.LiczbaDokumentowWzDraft</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Konto użytkownika</div><div class="news-details-item__value">@(klient.Uzytkownik?.Email ?? "-")</div></div>
            <div class="news-details-item news-details-item--full"><div class="news-details-item__label">Adres</div><div class="news-details-item__value news-details-item__value--content">@(string.IsNullOrWhiteSpace(klient.Adres) ? "Brak adresu" : klient.Adres)</div></div>
        </div>
    </section>

    <section class="news-details-panel">
        <div class="news-details-panel__header">
            <h2 class="news-details-panel__title">Konto mobilne klienta</h2>
        </div>

        @if (klient.IdUzytkownika.HasValue && klient.Uzytkownik != null)
        {
            <div class="news-details-grid">
                <div class="news-details-item"><div class="news-details-item__label">ID użytkownika</div><div class="news-details-item__value">@klient.Uzytkownik.IdUzytkownika</div></div>
                <div class="news-details-item"><div class="news-details-item__label">Login</div><div class="news-details-item__value">@klient.Uzytkownik.Login</div></div>
                <div class="news-details-item"><div class="news-details-item__label">Email</div><div class="news-details-item__value">@klient.Uzytkownik.Email</div></div>
                <div class="news-details-item"><div class="news-details-item__label">Status</div><div class="news-details-item__value">@(klient.Uzytkownik.CzyAktywny ? "Aktywne" : "Nieaktywne")</div></div>
                <div class="news-details-item news-details-item--full">
                    <div class="news-details-item__label">Role konta</div>
                    <div class="news-details-item__value">@(Model.RoleKontaMobilnego.Any() ? string.Join(", ", Model.RoleKontaMobilnego) : "-")</div>
                </div>
            </div>
            <div class="client-account-feedback">
                <div class="client-account-note client-account-note--info">Konto mobilne jest już przypisane do tego klienta.</div>

                @if (!Model.CzyKontoMobilneMaRoleKlienta || Model.CzyKontoMobilneMaRolePracownicze)
                {
                    <div class="client-account-note client-account-note--warning">
                        To konto nie jest poprawnym kontem klienta (role: @(Model.RoleKontaMobilnego.Any() ? string.Join(", ", Model.RoleKontaMobilnego) : "brak")).
                        Zalecane: odłączyć konto i utworzyć dedykowane konto klienta.
                    </div>
                }

                <div class="client-account-actions">
                    <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#unlinkMobileAccountModal">
                        <i class="bi bi-person-dash me-1"></i> Odłącz konto mobilne
                    </button>
                </div>
            </div>
        }
        else
        {
            <form asp-action="UtworzKontoMobilne" method="post" novalidate class="news-editor-form client-account-create-form" autocomplete="off">
                @Html.AntiForgeryToken()
                <input type="text" name="fakeUsername" class="d-none" tabindex="-1" autocomplete="username" aria-hidden="true" />
                <input type="password" name="fakePassword" class="d-none" tabindex="-1" autocomplete="current-password" aria-hidden="true" />
                <input asp-for="KontoMobilne.KlientId" type="hidden" value="@klient.IdKlienta" />

                <div class="client-account-create-info">
                    <div class="client-account-create-info__icon"><i class="bi bi-phone"></i></div>
                    <div>
                        <div class="client-account-create-info__title">Brak konta mobilnego</div>
                        <div class="client-account-create-info__text">Utwórz konto, aby klient mógł logować się w MobileApp i składać rezerwacje.</div>
                    </div>
                </div>

                <div asp-validation-summary="ModelOnly" class="news-form-validation text-danger"></div>

                <div class="news-form-grid">
                    <div class="news-form-field">
                        <label asp-for="KontoMobilne.Login" class="form-label"></label>
                        <input asp-for="KontoMobilne.Login" class="form-control news-form-control" autocomplete="off" />
                        <span asp-validation-for="KontoMobilne.Login" class="text-danger"></span>
                    </div>
                    <div class="news-form-field">
                        <label asp-for="KontoMobilne.Email" class="form-label"></label>
                        <input asp-for="KontoMobilne.Email" class="form-control news-form-control" autocomplete="off" />
                        <span asp-validation-for="KontoMobilne.Email" class="text-danger"></span>
                    </div>
                    <div class="news-form-field">
                        <label asp-for="KontoMobilne.Password" class="form-label"></label>
                        <input asp-for="KontoMobilne.Password" class="form-control news-form-control" autocomplete="new-password" />
                        <span asp-validation-for="KontoMobilne.Password" class="text-danger"></span>
                    </div>
                    <div class="news-form-field">
                        <label asp-for="KontoMobilne.ConfirmPassword" class="form-label"></label>
                        <input asp-for="KontoMobilne.ConfirmPassword" class="form-control news-form-control" autocomplete="new-password" />
                        <span asp-validation-for="KontoMobilne.ConfirmPassword" class="text-danger"></span>
                    </div>
                    <div class="news-form-field news-form-field--full">
                        <div class="form-check news-form-check">
                            <input asp-for="KontoMobilne.IsActive" class="form-check-input" />
                            <label asp-for="KontoMobilne.IsActive" class="form-check-label"></label>
                        </div>
                    </div>
                </div>

                <div class="news-form-actions">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-person-plus me-1"></i> Utwórz konto mobilne</button>
                </div>
            </form>
        }
    </section>

    <section class="news-details-panel">
        <div class="news-details-panel__header">
            <div>
                <h2 class="news-details-panel__title">Ostatnie dokumenty WZ <span class="category-products-count">(@ostatnieWz.Count)</span></h2>
                <p class="category-products-panel__subtitle mb-0">Najnowsze wydania zarejestrowane dla tego klienta.</p>
            </div>
            <div class="news-details-panel__actions">
                <a asp-controller="DokumentWZ" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-journal-arrow-up me-1"></i> Lista WZ
                </a>
            </div>
        </div>

        <div class="category-products-panel__body">
            @if (!ostatnieWz.Any())
            {
                <div class="category-products-empty" role="status" aria-live="polite">
                    <div class="category-products-empty__icon" aria-hidden="true"><i class="bi bi-inbox"></i></div>
                    <div>
                        <div class="category-products-empty__title">Brak dokumentów WZ</div>
                        <div class="category-products-empty__text">Ten klient nie ma jeszcze żadnych wydań.</div>
                    </div>
                </div>
            }
            else
            {
                <div class="category-products-table-shell">
                    <div class="entity-table-wrap">
                        <table class="table table-hover align-middle mb-0 entity-table category-products-table">
                            <thead>
                                <tr>
                                    <th>Numer</th>
                                    <th>Magazyn</th>
                                    <th>Status</th>
                                    <th>Data wydania</th>
                                    <th>Utworzył</th>
                                    <th class="text-end">Akcje</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var wz in ostatnieWz)
                                {
                                    var statusClass = wz.Status == "Posted" ? "entity-badge--success"
                                        : wz.Status == "Draft" ? "entity-badge--warning"
                                        : "entity-badge--muted";
                                    <tr>
                                        <td>
                                            <div class="entity-cell-title entity-mono">@wz.Numer</div>
                                            @if (!string.IsNullOrWhiteSpace(wz.Notatka))
                                            {
                                                <div class="entity-cell-subtitle">@wz.Notatka</div>
                                            }
                                        </td>
                                        <td>
                                            <div class="entity-cell-title">@(wz.Magazyn?.Nazwa ?? "-")</div>
                                            <div class="entity-cell-subtitle">ID magazynu: @wz.IdMagazynu</div>
                                        </td>
                                        <td>
                                            <span class="entity-badge @statusClass">@wz.Status</span>
                                        </td>
                                        <td>
                                            <div class="entity-cell-title">@wz.DataWydaniaUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                                            @if (wz.ZaksiegowanoUtc.HasValue)
                                            {
                                                <div class="entity-cell-subtitle">Księg.: @wz.ZaksiegowanoUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                                            }
                                        </td>
                                        <td>
                                            <div class="entity-cell-title">@(wz.Utworzyl?.Email ?? "-")</div>
                                        </td>
                                        <td class="text-end">
                                            <div class="btn-group btn-group-sm category-products-actions" role="group" aria-label="Akcje dla dokumentu @wz.Numer">
                                                <a class="btn btn-outline-info" asp-controller="DokumentWZ" asp-action="Details" asp-route-id="@wz.Id" title="Szczegóły dokumentu WZ"><i class="bi bi-eye"></i></a>
                                                <a class="btn btn-outline-warning" asp-controller="DokumentWZ" asp-action="Edit" asp-route-id="@wz.Id" title="Edytuj dokument WZ"><i class="bi bi-pencil"></i></a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </section>
</div>

@if (klient.IdUzytkownika.HasValue && klient.Uzytkownik != null)
{
    <div class="modal fade" id="unlinkMobileAccountModal" tabindex="-1" aria-labelledby="unlinkMobileAccountModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="unlinkMobileAccountModalLabel">Potwierdź odłączenie konta</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Zamknij"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2">Na pewno odłączyć konto mobilne od tego klienta?</p>
                    <div class="small text-muted">
                        Konto: <strong>@klient.Uzytkownik.Login</strong> (@klient.Uzytkownik.Email)
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Anuluj</button>
                    <form asp-action="OdlaczKontoMobilne" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@klient.IdKlienta" />
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-person-dash me-1"></i> Odłącz konto
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}

