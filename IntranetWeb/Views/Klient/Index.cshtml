@model Interfaces.Magazyn.Dtos.KlientIndexDto

@{
    var isAdmin = User?.IsInRole("Admin") ?? false;
    ViewData["Title"] = "Klienci";
    var items = Model.Items.ToList();
    var searchTerm = Model.SearchTerm ?? string.Empty;
    var activeCount = items.Count(x => x.Klient.CzyAktywny);
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-people"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Klienci</h1>
                <p class="news-admin-header__subheading mb-0">Baza klientów i dane kontaktowe do obsługi wydań.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">Łącznie</span><strong class="news-admin-stat__value">@items.Count</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Aktywni</span><strong class="news-admin-stat__value">@activeCount</strong></div>
        </div>
    </section>

    <section class="news-admin-toolbar">
        <form method="get" class="news-admin-search" role="search" aria-label="Wyszukiwanie klientow">
            <label for="customerSearchTerm" class="visually-hidden">Szukaj klientow</label>
            <div class="news-admin-search__input-wrap">
                <i class="bi bi-search news-admin-search__icon"></i>
                <input id="customerSearchTerm" class="form-control news-admin-search__input" name="searchTerm" value="@searchTerm"
                       placeholder="Szukaj po nazwie, emailu, telefonie lub adresie..." />
            </div>
            <button class="btn btn-primary news-admin-search__submit" type="submit">Szukaj</button>
            @if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                <a class="btn btn-outline-secondary news-admin-search__clear" href="@Url.Action("Index")"><i class="bi bi-x-lg"></i></a>
            }
        </form>
        <a class="btn news-admin-toolbar__cta" asp-action="Create"><i class="bi bi-plus-circle"></i> Dodaj klienta</a>
    </section>

    @if (!items.Any())
    {
        <section class="news-admin-empty">
            <div class="news-admin-empty__icon"><i class="bi bi-people"></i></div>
            <h2 class="h4 mb-2">Brak klientów</h2>
            <p class="text-muted mb-3">Dodaj pierwszego klienta, aby rejestrować dokumenty WZ.</p>
            <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-circle me-1"></i> Dodaj klienta</a>
        </section>
    }
    else
    {
        <div class="news-admin-grid">
            @foreach (var item in items.OrderBy(x => x.Klient.Nazwa))
            {
                var k = item.Klient;
                <article class="news-card">
                    <div class="news-card__accent"></div>
                    <div class="news-card__body">
                        <div class="news-card__meta-top">
                            <span class="news-card__badge"><i class="bi bi-upc"></i> ID @k.IdKlienta</span>
                            @if (k.CzyAktywny)
                            {
                                <span class="entity-badge">Aktywny</span>
                            }
                            else
                            {
                                <span class="entity-badge entity-badge--muted">Nieaktywny</span>
                            }
                        </div>

                        <h2 class="news-card__title" title="@k.Nazwa">@k.Nazwa</h2>
                        <p class="news-card__content" title="@k.Adres">@(string.IsNullOrWhiteSpace(k.Adres) ? "Brak adresu." : k.Adres)</p>

                        <div class="entity-inline-meta">
                            <span class="entity-inline-meta__label">Email:</span>
                            <span class="entity-inline-meta__value">@(k.Email ?? "-")</span>
                        </div>
                        <div class="entity-inline-meta">
                            <span class="entity-inline-meta__label">Telefon:</span>
                            <span class="entity-inline-meta__value">@(k.Telefon ?? "-")</span>
                        </div>
                        <div class="entity-inline-meta">
                            <span class="entity-inline-meta__label">WZ:</span>
                            <span class="entity-inline-meta__value">@item.LiczbaDokumentowWz</span>
                        </div>

                        <div class="news-card__footer">
                            <div class="btn-group btn-group-sm" role="group" aria-label="Akcje dla klienta @k.Nazwa">
                                <a class="btn btn-outline-warning" asp-action="Edit" asp-route-id="@k.IdKlienta" title="Edytuj klienta"><i class="bi bi-pencil"></i></a>
                                <a class="btn btn-outline-info" asp-action="Details" asp-route-id="@k.IdKlienta" title="Szczegóły klienta"><i class="bi bi-eye"></i></a>
                                @if (isAdmin)
                                {
                                <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@k.IdKlienta" title="Usuń klienta"><i class="bi bi-trash"></i></a>
                                }
                            </div>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</div>

