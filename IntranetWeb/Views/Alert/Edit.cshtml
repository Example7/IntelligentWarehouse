@model Data.Data.Magazyn.Alert

@{
    ViewData["Title"] = "Edytuj alert";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-pencil-square"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Edytuj alert</h1>
                <p class="news-admin-header__subheading mb-0">Aktualizuj wage, tresc i status potwierdzenia alertu.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@Model.Id</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Waga</span><strong class="news-admin-stat__value">@Model.Waga</strong></div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Edycja alertu</h2>
            <p class="text-muted mb-0">Zmien dane alertu i zapisz zmiany.</p>
        </div>

        <form asp-action="Edit" method="post" class="news-editor-form" novalidate>
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation" role="alert"></div>
            <div class="news-form-grid">
                <div class="news-form-field">
                    <label asp-for="IdReguly" class="form-label news-form-label"></label>
                    <select asp-for="IdReguly" class="form-select news-form-control" asp-items="ViewBag.IdReguly"></select>
                    <span asp-validation-for="IdReguly" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="IdMagazynu" class="form-label news-form-label"></label>
                    <select asp-for="IdMagazynu" class="form-select news-form-control" asp-items="ViewBag.IdMagazynu"></select>
                    <span asp-validation-for="IdMagazynu" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="IdProduktu" class="form-label news-form-label"></label>
                    <select asp-for="IdProduktu" class="form-select news-form-control" asp-items="ViewBag.IdProduktu"></select>
                    <span asp-validation-for="IdProduktu" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="Waga" class="form-label news-form-label"></label>
                    <input asp-for="Waga" class="form-control news-form-control" />
                    <span asp-validation-for="Waga" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label asp-for="Tresc" class="form-label news-form-label"></label>
                    <textarea asp-for="Tresc" class="form-control news-form-control news-form-control--textarea" rows="4"></textarea>
                    <span asp-validation-for="Tresc" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="UtworzonoUtc" class="form-label news-form-label"></label>
                    <input asp-for="UtworzonoUtc" class="form-control news-form-control" />
                    <span asp-validation-for="UtworzonoUtc" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="PotwierdzilUserId" class="form-label news-form-label"></label>
                    <input asp-for="PotwierdzilUserId" class="form-control news-form-control" />
                    <span asp-validation-for="PotwierdzilUserId" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="PotwierdzonoUtc" class="form-label news-form-label"></label>
                    <input asp-for="PotwierdzonoUtc" class="form-control news-form-control" />
                    <span asp-validation-for="PotwierdzonoUtc" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <div class="form-check form-switch mt-4">
                        <input class="form-check-input" asp-for="CzyPotwierdzony" />
                        <label class="form-check-label news-form-label mb-0" asp-for="CzyPotwierdzony"></label>
                    </div>
                    <span asp-validation-for="CzyPotwierdzony" class="text-danger small"></span>
                </div>
            </div>
            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary"><i class="bi bi-check2-circle"></i> Zapisz zmiany</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i> Anuluj</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
