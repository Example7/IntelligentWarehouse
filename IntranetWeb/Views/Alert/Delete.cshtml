@model Interfaces.Magazyn.Dtos.AlertDeleteDto

@{
    ViewData["Title"] = "Usuń alert";
    var a = Model.Alert;
}

<div class="news-admin-page">
    <section class="news-admin-header news-admin-header--danger">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon news-admin-header__icon--danger"><i class="bi bi-trash3"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Usuń alert</h1>
                <p class="news-admin-header__subheading mb-0">Potwierdź usunięcie alertu z rejestru.</p>
            </div>
        </div>
    </section>

    <section class="news-delete-panel">
        <div class="news-delete-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>Usunięcie alertu</strong>
                <div>Usunięcie rekordu nie cofa zdarzenia źródłowego, usuwa tylko wpis alertu.</div>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item"><div class="news-details-item__label">ID</div><div class="news-details-item__value">@a.Id</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Waga</div><div class="news-details-item__value">@a.Waga</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Reguła</div><div class="news-details-item__value">@(a.Regula?.Typ ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Magazyn</div><div class="news-details-item__value">@(a.Magazyn?.Nazwa ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Produkt</div><div class="news-details-item__value">@(a.Produkt?.Kod ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Status</div><div class="news-details-item__value">@(a.CzyPotwierdzony ? "Potwierdzony" : "Nowy")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Potwierdził</div><div class="news-details-item__value">@(Model.PotwierdzilEmail ?? a.PotwierdzilUserId?.ToString() ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Potwierdzono</div><div class="news-details-item__value">@(a.PotwierdzonoUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</div></div>
            <div class="news-details-item news-details-item--full">
                <div class="news-details-item__label">Treść</div>
                <div class="news-details-item__value news-details-item__value--content">@a.Tresc</div>
            </div>
        </div>

        <form asp-action="Delete" method="post" class="news-form-actions">
            <input type="hidden" asp-for="Alert.Id" name="Id" />
            <button type="submit" class="btn btn-danger news-form-actions__primary"><i class="bi bi-trash3-fill"></i> Usuń alert</button>
            <a asp-action="Details" asp-route-id="@a.Id" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Anuluj</a>
        </form>
    </section>
</div>