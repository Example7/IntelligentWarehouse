@model Interfaces.Magazyn.Dtos.AlertDetailsDto

@{
    ViewData["Title"] = "Szczegóły alertu";
    var a = Model.Alert;
    var severityClass = string.Equals(a.Waga, "CRIT", StringComparison.OrdinalIgnoreCase)
        ? "entity-badge--danger"
        : string.Equals(a.Waga, "WARN", StringComparison.OrdinalIgnoreCase) ? "entity-badge--warning" : "entity-badge--muted";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-bell"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Szczegóły alertu</h1>
                <p class="news-admin-header__subheading mb-0">Podgląd alertu, reguły, wagi i potwierdzenia.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@a.Id</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Status</span><strong class="news-admin-stat__value">@(a.CzyPotwierdzony ? "Potwierdzony" : "Nowy")</strong></div>
        </div>
    </section>

    <section class="news-details-panel">
        <div class="news-details-panel__header">
            <h2 class="news-details-panel__title text-truncate" title="@a.Tresc">@a.Tresc</h2>
            <div class="news-details-panel__actions">
                <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-primary"><i class="bi bi-pencil-square me-1"></i> Edytuj</a>
                <a asp-action="Delete" asp-route-id="@a.Id" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i> Usuń</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Lista</a>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item"><div class="news-details-item__label">Waga</div><div class="news-details-item__value"><span class="entity-badge @severityClass">@a.Waga</span></div></div>
            <div class="news-details-item"><div class="news-details-item__label">Reguła</div><div class="news-details-item__value">@(a.Regula?.Typ ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Magazyn</div><div class="news-details-item__value">@(a.Magazyn?.Nazwa ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Produkt</div><div class="news-details-item__value">@(a.Produkt?.Nazwa ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Kod produktu</div><div class="news-details-item__value entity-mono">@(a.Produkt?.Kod ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Jednostka</div><div class="news-details-item__value">@(a.Produkt?.DomyslnaJednostka?.Kod ?? "j.m.")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Utworzono</div><div class="news-details-item__value">@a.UtworzonoUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Potwierdzenie</div><div class="news-details-item__value">@(a.CzyPotwierdzony ? "Potwierdzony" : "Nowy")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Potwierdził</div><div class="news-details-item__value">@(Model.PotwierdzilEmail ?? a.PotwierdzilUserId?.ToString() ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Potwierdzono</div><div class="news-details-item__value">@(a.PotwierdzonoUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</div></div>
            <div class="news-details-item news-details-item--full">
                <div class="news-details-item__label">Treść</div>
                <div class="news-details-item__value news-details-item__value--content">@a.Tresc</div>
            </div>
        </div>
    </section>
</div>