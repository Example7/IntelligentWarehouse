@model Data.Data.Magazyn.KodProduktu

@{
    ViewData["Title"] = "Dodaj kod produktu";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon" aria-hidden="true"><i class="bi bi-plus-square"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Dodaj kod produktu</h1>
                <p class="news-admin-header__subheading mb-0">Dodaj nowy kod identyfikacyjny (EAN/QR/inny) do produktu.</p>
            </div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Dane kodu</h2>
            <p class="text-muted mb-0">Wybierz produkt i uzupełnij wartość, typ oraz oznaczenie kodu głównego.</p>
        </div>

        <form asp-action="Create" method="post" class="news-editor-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation" role="alert"></div>
            <div class="news-form-grid">
                <div class="news-form-field news-form-field--full">
                    <label asp-for="IdProduktu" class="form-label news-form-label"></label>
                    <select asp-for="IdProduktu" class="form-select news-form-control" asp-items="ViewBag.IdProduktu"></select>
                    <span asp-validation-for="IdProduktu" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="Typ" class="form-label news-form-label"></label>
                    <input asp-for="Typ" class="form-control news-form-control" placeholder="np. EAN, QR, CODE128" />
                    <span asp-validation-for="Typ" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="Wartosc" class="form-label news-form-label"></label>
                    <input asp-for="Wartosc" class="form-control news-form-control entity-mono" placeholder="np. 5901234123457" />
                    <span asp-validation-for="Wartosc" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <div class="form-check form-switch mt-2">
                        <input class="form-check-input" asp-for="CzyGlowny" />
                        <label class="form-check-label news-form-label mb-0" asp-for="CzyGlowny"></label>
                    </div>
                    <div class="form-text">Po zaznaczeniu inne główne kody tego produktu zostaną odznaczone.</div>
                    <span asp-validation-for="CzyGlowny" class="text-danger small"></span>
                </div>
            </div>
            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary"><i class="bi bi-check2-circle"></i> Zapisz kod</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Wróć do listy</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}