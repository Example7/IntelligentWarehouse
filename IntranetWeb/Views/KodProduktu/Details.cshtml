@model Data.Data.Magazyn.KodProduktu

@{
    ViewData["Title"] = "Szczegoly kodu produktu";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-upc-scan"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Szczegóły kodu produktu</h1>
                <p class="news-admin-header__subheading mb-0">Podgląd kodu identyfikacyjnego i powiązanego produktu.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@Model.IdKodu</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Glowny</span><strong class="news-admin-stat__value">@(Model.CzyGlowny ? "Tak" : "Nie")</strong></div>
        </div>
    </section>

    <section class="news-details-panel">
        <div class="news-details-panel__header">
            <h2 class="news-details-panel__title entity-mono">@Model.Wartosc</h2>
            <div class="news-details-panel__actions">
                <a asp-action="Edit" asp-route-id="@Model.IdKodu" class="btn btn-primary"><i class="bi bi-pencil-square me-1"></i> Edytuj</a>
                <a asp-action="Delete" asp-route-id="@Model.IdKodu" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i> Usuń</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Lista</a>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item"><div class="news-details-item__label">Wartość</div><div class="news-details-item__value entity-mono">@Model.Wartosc</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Typ</div><div class="news-details-item__value">@Model.Typ</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Produkt</div><div class="news-details-item__value">@(Model.Produkt?.Nazwa ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Kod produktu</div><div class="news-details-item__value entity-mono">@(Model.Produkt?.Kod ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Czy główny</div><div class="news-details-item__value">@(Model.CzyGlowny ? "Tak" : "Nie")</div></div>
        </div>
    </section>
</div>
