@model Interfaces.Magazyn.Dtos.KodProduktuDetailsDto

@{
    var isAdmin = User?.IsInRole("Admin") ?? false;
    ViewData["Title"] = "Szczegóły kodu produktu";
    var kod = Model.KodProduktu;
    var jm = kod.Produkt?.DomyslnaJednostka?.Kod ?? "j.m.";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon" aria-hidden="true"><i class="bi bi-upc-scan"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Szczegóły kodu produktu</h1>
                <p class="news-admin-header__subheading mb-0">Podgląd kodu identyfikacyjnego i powiązanego produktu.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@kod.IdKodu</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Główne</span><strong class="news-admin-stat__value">@(kod.CzyGlowny ? "Tak" : "Nie")</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Kody produktu</span><strong class="news-admin-stat__value">@Model.LiczbaKodowProduktu</strong></div>
        </div>
    </section>

    <section class="news-details-panel">
        <div class="news-details-panel__header">
            <h2 class="news-details-panel__title entity-mono">@kod.Wartosc</h2>
            <div class="news-details-panel__actions">
                <a asp-action="Edit" asp-route-id="@kod.IdKodu" class="btn btn-primary"><i class="bi bi-pencil-square me-1"></i> Edytuj</a>
                @if (isAdmin)
                {
                    <a asp-action="Delete" asp-route-id="@kod.IdKodu" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i> Usuń</a>
                }
                <a asp-controller="Produkt" asp-action="Details" asp-route-id="@kod.IdProduktu" class="btn btn-outline-info"><i class="bi bi-box-seam me-1"></i> Produkt</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Lista</a>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item">
                <div class="news-details-item__label">Wartość</div>
                <div class="news-details-item__value entity-mono">@kod.Wartosc</div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Typ</div>
                <div class="news-details-item__value"><span class="entity-badge entity-badge--muted">@kod.Typ</span></div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Produkt</div>
                <div class="news-details-item__value">
                    @(kod.Produkt?.Kod ?? "-")
                    <div class="entity-cell-subtitle">@(kod.Produkt?.Nazwa ?? "-")</div>
                </div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Domyślna jednostka miary</div>
                <div class="news-details-item__value">@jm</div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Kod główny</div>
                <div class="news-details-item__value">
                    <span class="entity-badge @(kod.CzyGlowny ? "entity-badge--success" : "entity-badge--muted")">@(kod.CzyGlowny ? "Tak" : "Nie")</span>
                </div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Kody dla produktu</div>
                <div class="news-details-item__value">@Model.LiczbaKodowProduktu</div>
            </div>
        </div>
    </section>
</div>