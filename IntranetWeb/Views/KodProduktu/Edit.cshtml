@model Data.Data.Magazyn.KodProduktu

@{
    ViewData["Title"] = "Edytuj kod produktu";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-pencil-square"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Edytuj kod produktu</h1>
                <p class="news-admin-header__subheading mb-0">Aktualizuj wartość kodu, typ i oznaczenie główne.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@Model.IdKodu</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Typ</span><strong class="news-admin-stat__value">@Model.Typ</strong></div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Edycja kodu</h2>
            <p class="text-muted mb-0">Zmień dane kodu i zapisz zmiany.</p>
        </div>

        <form asp-action="Edit" method="post" class="news-editor-form" novalidate>
            <input type="hidden" asp-for="IdKodu" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation" role="alert"></div>
            <div class="news-form-grid">
                <div class="news-form-field">
                    <label asp-for="IdProduktu" class="form-label news-form-label"></label>
                    <select asp-for="IdProduktu" class="form-select news-form-control" asp-items="ViewBag.IdProduktu"></select>
                    <span asp-validation-for="IdProduktu" class="text-danger small"></span>
                </div>
                <div class="news-form-field">
                    <label asp-for="Typ" class="form-label news-form-label"></label>
                    <input asp-for="Typ" class="form-control news-form-control" />
                    <span asp-validation-for="Typ" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <label asp-for="Wartosc" class="form-label news-form-label"></label>
                    <input asp-for="Wartosc" class="form-control news-form-control" />
                    <span asp-validation-for="Wartosc" class="text-danger small"></span>
                </div>
                <div class="news-form-field news-form-field--full">
                    <div class="form-check form-switch mt-2">
                        <input class="form-check-input" asp-for="CzyGlowny" />
                        <label class="form-check-label news-form-label mb-0" asp-for="CzyGlowny"></label>
                    </div>
                    <span asp-validation-for="CzyGlowny" class="text-danger small"></span>
                </div>
            </div>
            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary"><i class="bi bi-check2-circle"></i> Zapisz zmiany</button>
                <a asp-action="Details" asp-route-id="@Model.IdKodu" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i> Anuluj</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
