@model Interfaces.Magazyn.Dtos.KodProduktuDeleteDto

@{
    ViewData["Title"] = "Usuń kod produktu";
    var kod = Model.KodProduktu;
    var jm = kod.Produkt?.DomyslnaJednostka?.Kod ?? "j.m.";
}

<div class="news-admin-page">
    <section class="news-admin-header news-admin-header--danger">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon news-admin-header__icon--danger" aria-hidden="true"><i class="bi bi-trash3"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Usuń kod produktu</h1>
                <p class="news-admin-header__subheading mb-0">Potwierdź usunięcie kodu identyfikacyjnego produktu.</p>
            </div>
        </div>
    </section>

    <section class="news-delete-panel">
        <div class="news-delete-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>Usunięcie kodu produktu</strong>
                <div>Usunięcie głównego kodu może wpływać na skanowanie i integracje. Pozostałe kody produktu: @(Math.Max(Model.LiczbaKodowProduktu - 1, 0)).</div>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item">
                <div class="news-details-item__label">Wartość</div>
                <div class="news-details-item__value entity-mono">@kod.Wartosc</div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Typ</div>
                <div class="news-details-item__value"><span class="entity-badge entity-badge--muted">@kod.Typ</span></div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Produkt</div>
                <div class="news-details-item__value">
                    @(kod.Produkt?.Kod ?? "-")
                    <div class="entity-cell-subtitle">@(kod.Produkt?.Nazwa ?? "-")</div>
                </div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Domyślna jednostka miary</div>
                <div class="news-details-item__value">@jm</div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Kod główny</div>
                <div class="news-details-item__value">
                    <span class="entity-badge @(kod.CzyGlowny ? "entity-badge--warning" : "entity-badge--muted")">
                        @(kod.CzyGlowny ? "Tak" : "Nie")
                    </span>
                </div>
            </div>
            <div class="news-details-item">
                <div class="news-details-item__label">Kody dla produktu</div>
                <div class="news-details-item__value">@Model.LiczbaKodowProduktu</div>
            </div>
        </div>

        <form asp-action="Delete" method="post" class="news-form-actions">
            <input type="hidden" name="id" value="@kod.IdKodu" />
            <button type="submit" class="btn btn-danger news-form-actions__primary"><i class="bi bi-trash3-fill"></i> Usuń kod</button>
            <a asp-action="Details" asp-route-id="@kod.IdKodu" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
            <a asp-controller="Produkt" asp-action="Details" asp-route-id="@kod.IdProduktu" class="btn btn-outline-secondary"><i class="bi bi-box-seam"></i> Produkt</a>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Anuluj</a>
        </form>
    </section>
</div>