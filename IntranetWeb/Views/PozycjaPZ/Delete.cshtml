@model Interfaces.Magazyn.Dtos.PozycjaPZDeleteDto

@{
    ViewData["Title"] = "Usuń pozycje PZ";
    var p = Model.Pozycja;
    var jm = p.Produkt?.DomyslnaJednostka?.Kod ?? "j.m.";
    var docStatus = p.Dokument?.Status ?? "-";
    var docStatusClass = string.Equals(docStatus, "Draft", StringComparison.OrdinalIgnoreCase) ? "entity-badge--warning" :
        string.Equals(docStatus, "Posted", StringComparison.OrdinalIgnoreCase) ? "entity-badge--success" : "entity-badge--muted";
}

<div class="news-admin-page">
    <section class="news-admin-header news-admin-header--danger">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon news-admin-header__icon--danger"><i class="bi bi-trash3"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Usuń pozycję PZ</h1>
                <p class="news-admin-header__subheading mb-0">Potwierdź usunięcie pozycji z dokumentu przyjęcia.</p>
            </div>
        </div>
    </section>

    <section class="news-delete-panel">
        <div class="news-delete-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>Usunięcie pozycji PZ</strong>
                <div>@(Model.CzyDokumentDraft ? "Usunięcie pozycji zmieni ilość i wartość dokumentu przyjęcia." : (Model.PowodBlokady ?? "Operacja może być zablokowana."))</div>
            </div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mt-3" role="alert">
                <div asp-validation-summary="All" class="mb-0"></div>
            </div>
        }

        <div class="news-details-grid">
            <div class="news-details-item"><div class="news-details-item__label">Dokument PZ</div><div class="news-details-item__value entity-mono">@(p.Dokument?.Numer ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Status dokumentu PZ</div><div class="news-details-item__value"><span class="entity-badge @docStatusClass">@docStatus</span></div></div>
            <div class="news-details-item"><div class="news-details-item__label">Lp</div><div class="news-details-item__value">@p.Lp</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Produkt</div><div class="news-details-item__value">@(p.Produkt?.Kod ?? "-") - @(p.Produkt?.Nazwa ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Partia</div><div class="news-details-item__value">@(p.Partia?.NumerPartii ?? "(brak)")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Lokacja</div><div class="news-details-item__value">@(p.Lokacja?.Kod ?? "-") / @(p.Lokacja?.Magazyn?.Nazwa ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Ilość</div><div class="news-details-item__value">@p.Ilosc.ToString("0.###") @jm</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Cena jednostkowa</div><div class="news-details-item__value">@(p.CenaJednostkowa?.ToString("0.00") ?? "-")</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Wartość</div><div class="news-details-item__value">@Model.Wartosc.ToString("0.00")</div></div>
        </div>

        <form asp-action="Delete" method="post" class="news-form-actions">
            <input type="hidden" name="id" value="@p.Id" />
            <button type="submit" class="btn btn-danger news-form-actions__primary" @(Model.CzyMoznaUsunac ? null : "disabled")><i class="bi bi-trash3-fill"></i> Usuń pozycję</button>
            <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Anuluj</a>
        </form>
    </section>
</div>
