@model Interfaces.Magazyn.Dtos.PozycjaPZIndexDto

@{
    ViewData["Title"] = "Pozycje PZ";
    var items = Model.Items.ToList();
    var searchTerm = Model.SearchTerm ?? string.Empty;
    var totalQuantity = items.Sum(x => x.Ilosc);
    var distinctDocs = items.Select(x => x.IdDokumentu).Distinct().Count();
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon" aria-hidden="true"><i class="bi bi-list-ol"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Pozycje PZ</h1>
                <p class="news-admin-header__subheading mb-0">Lista pozycji dokumentow przyjęcia z ilościami, cenami i lokalizacja.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">Lacznie</span><strong class="news-admin-stat__value">@items.Count</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Dokumenty</span><strong class="news-admin-stat__value">@distinctDocs</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Ilosc</span><strong class="news-admin-stat__value">@totalQuantity.ToString("0.###")</strong></div>
        </div>
    </section>

    <section class="news-admin-toolbar">
        <form method="get" class="news-admin-search" role="search" aria-label="Wyszukiwanie pozycji PZ">
            <label for="pzItemSearchTerm" class="visually-hidden">Szukaj pozycji PZ</label>
            <div class="news-admin-search__input-wrap">
                <i class="bi bi-search news-admin-search__icon" aria-hidden="true"></i>
                <input id="pzItemSearchTerm" class="form-control news-admin-search__input" name="searchTerm" value="@searchTerm"
                       placeholder="Szukaj po numerze PZ, produkcie, lokacji lub magazynie..." />
            </div>
            <button class="btn btn-primary news-admin-search__submit" type="submit">Szukaj</button>
            @if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                <a class="btn btn-outline-secondary news-admin-search__clear" href="@Url.Action("Index")" title="Wyczyść filtr"><i class="bi bi-x-lg"></i></a>
            }
        </form>
        <a class="btn news-admin-toolbar__cta" asp-action="Create"><i class="bi bi-plus-circle"></i> Dodaj pozycje</a>
    </section>

    @if (!items.Any())
    {
        <section class="news-admin-empty">
            <div class="news-admin-empty__icon"><i class="bi bi-list-task"></i></div>
            <h2 class="h4 mb-2">Brak pozycji PZ</h2>
            <p class="text-muted mb-3">
                @if (string.IsNullOrWhiteSpace(searchTerm))
                {
                    <span>Nie dodano jeszcze żadnych pozycji dokumentów PZ.</span>
                }
                else
                {
                    <span>Brak wyników dla frazy: <strong>@searchTerm</strong>.</span>
                }
            </p>
            <div class="d-flex justify-content-center gap-2 flex-wrap">
                <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-circle me-1"></i> Dodaj pozycje</a>
                @if (!string.IsNullOrWhiteSpace(searchTerm))
                {
                    <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Wyczyść filtr</a>
                }
            </div>
        </section>
    }
    else
    {
        <section class="entity-table-panel">
            <div class="entity-table-wrap">
                <table class="table table-hover align-middle mb-0 entity-table">
                    <thead>
                        <tr>
                            <th>Dokument</th>
                            <th class="text-end">Lp</th>
                            <th>Produkt</th>
                            <th>Partia</th>
                            <th>Lokacja</th>
                            <th class="text-end">Ilość</th>
                            <th class="text-end">Cena jedn.</th>
                            <th class="text-end">Wartość</th>
                            <th class="text-end">Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in items.OrderBy(x => x.Dokument != null ? x.Dokument.Numer : string.Empty).ThenBy(x => x.Lp))
                    {
                        var jm = item.Produkt?.DomyslnaJednostka?.Kod ?? "j.m.";
                        var value = item.Ilosc * (item.CenaJednostkowa ?? 0m);
                        var isDraft = string.Equals(item.Dokument?.Status, "Draft", StringComparison.OrdinalIgnoreCase);
                        var statusClass = isDraft ? "entity-badge--warning" :
                            string.Equals(item.Dokument?.Status, "Posted", StringComparison.OrdinalIgnoreCase) ? "entity-badge--success" : "entity-badge--muted";
                        <tr>
                            <td>
                                <div class="entity-cell-title">@(item.Dokument?.Numer ?? "-")</div>
                                <div class="entity-cell-subtitle"><span class="entity-badge @statusClass">@(item.Dokument?.Status ?? "-")</span></div>
                            </td>
                            <td class="text-end">@item.Lp</td>
                            <td>
                                <div class="entity-cell-title">@(item.Produkt?.Kod ?? "-")</div>
                                <div class="entity-cell-subtitle">@(item.Produkt?.Nazwa ?? "Brak nazwy")</div>
                            </td>
                            <td>
                                <div class="entity-cell-title">@(item.Partia?.NumerPartii ?? "(brak)")</div>
                            </td>
                            <td>
                                <div class="entity-cell-title">@(item.Lokacja?.Kod ?? "-")</div>
                                <div class="entity-cell-subtitle">@(item.Lokacja?.Magazyn?.Nazwa ?? "-")</div>
                            </td>
                            <td class="text-end">@item.Ilosc.ToString("0.###") @jm</td>
                            <td class="text-end">@(item.CenaJednostkowa?.ToString("0.00") ?? "-")</td>
                            <td class="text-end">@value.ToString("0.00")</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm" role="group" aria-label="Akcje dla pozycji PZ @item.Id">
                                    @if (isDraft)
                                    {
                                        <a class="btn btn-outline-warning" asp-action="Edit" asp-route-id="@item.Id" title="Edytuj pozycję PZ"><i class="bi bi-pencil"></i></a>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-outline-secondary" disabled title="Edycja tylko dla dokumentu Draft"><i class="bi bi-pencil"></i></button>
                                    }
                                    <a class="btn btn-outline-info" asp-action="Details" asp-route-id="@item.Id" title="Szczegóły pozycji PZ"><i class="bi bi-eye"></i></a>
                                    <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id" title="Usuń pozycję PZ"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>
