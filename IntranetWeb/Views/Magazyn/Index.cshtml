@model Interfaces.Magazyn.Dtos.MagazynIndexDto

@{
    ViewData["Title"] = "Magazyny";
    var items = Model.Items.ToList();
    var searchTerm = Model.SearchTerm ?? string.Empty;
    var activeCount = items.Count(x => x.Magazyn.CzyAktywny);
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-building"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Magazyny</h1>
                <p class="news-admin-header__subheading mb-0">Lista magazynów i ich podstawowych danych adresowych.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">Łącznie</span><strong class="news-admin-stat__value">@items.Count</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Aktywne</span><strong class="news-admin-stat__value">@activeCount</strong></div>
        </div>
    </section>

    <section class="news-admin-toolbar">
        <form method="get" class="news-admin-search" role="search" aria-label="Wyszukiwanie magazynów">
            <label for="warehouseSearchTerm" class="visually-hidden">Szukaj magazynów</label>
            <div class="news-admin-search__input-wrap">
                <i class="bi bi-search news-admin-search__icon"></i>
                <input id="warehouseSearchTerm"
                       class="form-control news-admin-search__input"
                       name="searchTerm"
                       value="@searchTerm"
                       placeholder="Szukaj po nazwie lub adresie..." />
            </div>
            <button class="btn btn-primary news-admin-search__submit" type="submit">Szukaj</button>
            @if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                <a class="btn btn-outline-secondary news-admin-search__clear" href="@Url.Action("Index")" aria-label="Wyczyść wyszukiwanie">
                    <i class="bi bi-x-lg"></i>
                </a>
            }
        </form>
        <a class="btn news-admin-toolbar__cta" asp-action="Create"><i class="bi bi-plus-circle"></i> Dodaj magazyn</a>
    </section>

    @if (!items.Any())
    {
        <section class="news-admin-empty">
            <div class="news-admin-empty__icon"><i class="bi bi-building"></i></div>
            <h2 class="h4 mb-2">Brak magazynów</h2>
            <p class="text-muted mb-3">Dodaj pierwszy magazyn, aby rozpocząć zarządzanie lokalizacjami i stanami.</p>
            <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-circle me-1"></i> Dodaj magazyn</a>
        </section>
    }
    else
    {
        <div class="news-admin-grid">
            @foreach (var item in items.OrderBy(x => x.Magazyn.Nazwa))
            {
                var magazyn = item.Magazyn;
                <article class="news-card">
                    <div class="news-card__accent"></div>
                    <div class="news-card__body">
                        <div class="news-card__meta-top">
                            <span class="news-card__badge"><i class="bi bi-upc"></i> ID @magazyn.IdMagazynu</span>
                            @if (magazyn.CzyAktywny)
                            {
                                <span class="entity-badge">Aktywny</span>
                            }
                            else
                            {
                                <span class="entity-badge entity-badge--muted">Nieaktywny</span>
                            }
                        </div>

                        <h2 class="news-card__title" title="@magazyn.Nazwa">@magazyn.Nazwa</h2>
                        <p class="news-card__content" title="@magazyn.Adres">@(string.IsNullOrWhiteSpace(magazyn.Adres) ? "Brak adresu." : magazyn.Adres)</p>

                        <div class="entity-inline-meta">
                            <span class="entity-inline-meta__label">Adres:</span>
                            <span class="entity-inline-meta__value">@(string.IsNullOrWhiteSpace(magazyn.Adres) ? "-" : magazyn.Adres)</span>
                        </div>
                        <div class="entity-inline-meta">
                            <span class="entity-inline-meta__label">Lokacje:</span>
                            <span class="entity-inline-meta__value">@item.LiczbaLokacji</span>
                            <span class="entity-inline-meta__label ms-3">Rezerwacje:</span>
                            <span class="entity-inline-meta__value">@item.LiczbaRezerwacji</span>
                        </div>
                        <div class="entity-inline-meta">
                            <span class="entity-inline-meta__label">PZ/WZ/MM:</span>
                            <span class="entity-inline-meta__value">@item.LiczbaDokumentowPz/@item.LiczbaDokumentowWz/@item.LiczbaDokumentowMm</span>
                            <span class="entity-inline-meta__label ms-3">Alerty:</span>
                            <span class="entity-inline-meta__value">@item.LiczbaAlertow</span>
                        </div>

                        <div class="news-card__footer">
                            <div class="btn-group btn-group-sm" role="group" aria-label="Akcje dla magazynu @magazyn.Nazwa">
                                <a class="btn btn-outline-warning" asp-action="Edit" asp-route-id="@magazyn.IdMagazynu" aria-label="Edytuj @magazyn.Nazwa"><i class="bi bi-pencil"></i></a>
                                <a class="btn btn-outline-info" asp-action="Details" asp-route-id="@magazyn.IdMagazynu" aria-label="Szczegóły @magazyn.Nazwa"><i class="bi bi-eye"></i></a>
                                <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@magazyn.IdMagazynu" aria-label="Usuń @magazyn.Nazwa"><i class="bi bi-trash"></i></a>
                            </div>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</div>
