@model Data.Data.Magazyn.PozycjaRezerwacji

@{
    ViewData["Title"] = "Edytuj pozycję rezerwacji";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon">
                <i class="bi bi-pencil-square"></i>
            </span>

            <div>
                <h1 class="news-admin-header__heading mb-1">Edytuj pozycję rezerwacji</h1>
                <p class="news-admin-header__subheading mb-0">
                    Aktualizuj ilość i powiązania pozycji rezerwacji.
                </p>
            </div>
        </div>

        <div class="news-admin-header__stats">
            <div class="news-admin-stat">
                <span class="news-admin-stat__label">ID</span>
                <strong class="news-admin-stat__value">@Model.Id</strong>
            </div>

            <div class="news-admin-stat">
                <span class="news-admin-stat__label">Lp</span>
                <strong class="news-admin-stat__value">@Model.Lp</strong>
            </div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Edycja pozycji</h2>
            <p class="text-muted mb-0">Zmień dane pozycji i zapisz zmiany.</p>
        </div>

        <form asp-action="Edit" method="post" class="news-editor-form" novalidate>
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger news-form-validation"
                 role="alert">
            </div>

            <div class="news-form-grid">
                <div class="news-form-field">
                    <label asp-for="IdRezerwacji" class="form-label news-form-label">Rezerwacja</label>
                    <select asp-for="IdRezerwacji"
                            class="form-select news-form-control"
                            asp-items="ViewBag.IdRezerwacji">
                    </select>
                    <span asp-validation-for="IdRezerwacji" class="text-danger small"></span>
                </div>

                <div class="news-form-field">
                    <label asp-for="Lp" class="form-label news-form-label">Lp</label>
                    <input asp-for="Lp" class="form-control news-form-control" min="1" />
                    <span asp-validation-for="Lp" class="text-danger small"></span>
                </div>

                <div class="news-form-field">
                    <label asp-for="IdProduktu" class="form-label news-form-label">Produkt</label>
                    <select asp-for="IdProduktu"
                            class="form-select news-form-control"
                            asp-items="ViewBag.IdProduktu">
                    </select>
                    <span asp-validation-for="IdProduktu" class="text-danger small"></span>
                </div>

                <div class="news-form-field">
                    <label asp-for="IdLokacji" class="form-label news-form-label">Lokacja (opcjonalnie)</label>
                    <select asp-for="IdLokacji"
                            class="form-select news-form-control"
                            asp-items="ViewBag.IdLokacji">
                        <option value="">(brak)</option>
                    </select>
                    <span asp-validation-for="IdLokacji" class="text-danger small"></span>
                </div>

                <div class="news-form-field">
                    <label asp-for="Ilosc" class="form-label news-form-label">Ilość</label>
                    <input asp-for="Ilosc" class="form-control news-form-control" step="0.001" />
                    <div class="form-text">
                        Jednostka: <span id="rezItemUomHint">j.m.</span>
                    </div>
                    <span asp-validation-for="Ilosc" class="text-danger small"></span>
                </div>
            </div>

            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary">
                    <i class="bi bi-check2-circle"></i> Zapisz zmiany
                </button>

                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info">
                    <i class="bi bi-eye"></i> Szczegóły
                </a>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i> Anuluj
                </a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        (() => {
            const productSelect = document.getElementById('IdProduktu');
            const uomHint = document.getElementById('rezItemUomHint');

            const productUomMap = @Html.Raw((string?)ViewData["ProductUomMapJson"] ?? "{}");

            const applyUom = () => {
                const pid = Number.parseInt(productSelect?.value || '', 10);
                if (uomHint) uomHint.textContent = productUomMap[pid] || 'j.m.';
            };

            productSelect?.addEventListener('change', applyUom);
            applyUom();
        })();
    </script>
}