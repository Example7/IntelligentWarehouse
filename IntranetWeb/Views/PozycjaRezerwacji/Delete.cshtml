@model Interfaces.Magazyn.Dtos.PozycjaRezerwacjiDeleteDto

@{
    ViewData["Title"] = "Usuń pozycję rezerwacji";

    var p = Model.Pozycja;
    var jm = p.Produkt?.DomyslnaJednostka?.Kod ?? "j.m.";
    var status = p.Rezerwacja?.Status ?? "-";

    var statusClass =
        string.Equals(status, "Active", StringComparison.OrdinalIgnoreCase) ? "entity-badge--success" :
        string.Equals(status, "Draft", StringComparison.OrdinalIgnoreCase) ? "entity-badge--warning" :
        string.Equals(status, "Completed", StringComparison.OrdinalIgnoreCase) ? "entity-badge--info" :
        "entity-badge--muted";
}

<div class="news-admin-page">
    <section class="news-admin-header news-admin-header--danger">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon news-admin-header__icon--danger">
                <i class="bi bi-trash3"></i>
            </span>

            <div>
                <h1 class="news-admin-header__heading mb-1">Usuń pozycję rezerwacji</h1>
                <p class="news-admin-header__subheading mb-0">Potwierdź usunięcie pozycji rezerwacji.</p>
            </div>
        </div>
    </section>

    <section class="news-delete-panel">
        <div class="news-delete-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>Usunięcie pozycji rezerwacji</strong>
                <div>
                    @(
                        Model.CzyRezerwacjaEdytowalna
                            ? "Usunięcie pozycji zmieni ilość rezerwacji."
                            : (Model.PowodBlokady ?? "Operacja może być zablokowana.")
                    )
                </div>
            </div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mt-3">
                <div asp-validation-summary="All" class="mb-0"></div>
            </div>
        }

        <div class="news-details-grid">
            <div class="news-details-item">
                <div class="news-details-item__label">Rezerwacja</div>
                <div class="news-details-item__value entity-mono">@(p.Rezerwacja?.Numer ?? "-")</div>
            </div>

            <div class="news-details-item">
                <div class="news-details-item__label">Status rezerwacji</div>
                <div class="news-details-item__value">
                    <span class="entity-badge @statusClass">@status</span>
                </div>
            </div>

            <div class="news-details-item">
                <div class="news-details-item__label">Lp</div>
                <div class="news-details-item__value">@p.Lp</div>
            </div>

            <div class="news-details-item">
                <div class="news-details-item__label">Produkt</div>
                <div class="news-details-item__value">
                    @(p.Produkt?.Kod ?? "-") - @(p.Produkt?.Nazwa ?? "-")
                </div>
            </div>

            <div class="news-details-item">
                <div class="news-details-item__label">Lokacja</div>
                <div class="news-details-item__value">
                    @(p.Lokacja?.Kod ?? "(brak)") /
                    @(p.Lokacja?.Magazyn?.Nazwa ?? (p.Lokacja == null ? "Bez wskazanej lokacji" : "-"))
                </div>
            </div>

            <div class="news-details-item">
                <div class="news-details-item__label">Ilość</div>
                <div class="news-details-item__value">@p.Ilosc.ToString("0.###") @jm</div>
            </div>
        </div>

        <form asp-action="Delete" method="post" class="news-form-actions">
            <input type="hidden" name="id" value="@p.Id" />

            <button type="submit"
                    class="btn btn-danger news-form-actions__primary"
                    @(Model.CzyMoznaUsunac ? null : "disabled")>
                <i class="bi bi-trash3-fill"></i> Usuń pozycję rezerwacji
            </button>

            <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-outline-info">
                <i class="bi bi-eye"></i> Szczegóły
            </a>

            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Anuluj
            </a>
        </form>
    </section>
</div>