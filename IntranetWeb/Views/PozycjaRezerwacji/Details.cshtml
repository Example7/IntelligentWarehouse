@model Interfaces.Magazyn.Dtos.PozycjaRezerwacjiDetailsDto

@{
    ViewData["Title"] = "Szczegóły pozycji rezerwacji";

    var p = Model.Pozycja;
    var jm = p.Produkt?.DomyslnaJednostka?.Kod ?? "j.m.";
    var canEdit = Model.CzyRezerwacjaEdytowalna;

    var status = p.Rezerwacja?.Status ?? "-";
    var statusClass =
        string.Equals(status, "Active", StringComparison.OrdinalIgnoreCase) ? "entity-badge--success" :
        string.Equals(status, "Draft", StringComparison.OrdinalIgnoreCase) ? "entity-badge--warning" :
        string.Equals(status, "Completed", StringComparison.OrdinalIgnoreCase) ? "entity-badge--info" :
        "entity-badge--muted";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon">
                <i class="bi bi-list-check"></i>
            </span>

            <div>
                <h1 class="news-admin-header__heading mb-1">Szczegóły pozycji rezerwacji</h1>
                <p class="news-admin-header__subheading mb-0">
                    Podgląd pozycji rezerwacji z produktem i lokacją.
                </p>
            </div>
        </div>

        <div class="news-admin-header__stats">
            <div class="news-admin-stat">
                <span class="news-admin-stat__label">Lp</span>
                <strong class="news-admin-stat__value">@p.Lp</strong>
            </div>

            <div class="news-admin-stat">
                <span class="news-admin-stat__label">Status</span>
                <strong class="news-admin-stat__value">@status</strong>
            </div>

            <div class="news-admin-stat">
                <span class="news-admin-stat__label">ID</span>
                <strong class="news-admin-stat__value">@p.Id</strong>
            </div>
        </div>
    </section>

    @if (TempData["PozycjaRezerwacjiEditBlocked"] is string blocked && !string.IsNullOrWhiteSpace(blocked))
    {
        <div class="alert alert-warning mt-3">
            <i class="bi bi-exclamation-triangle me-1"></i>@blocked
        </div>
    }

    <section class="news-details-panel">
        <div class="news-details-panel__header">
            <h2 class="news-details-panel__title">
                Rezerwacja @(p.Rezerwacja?.Numer ?? "-") / pozycja @p.Lp
            </h2>

            <div class="news-details-panel__actions">
                @if (canEdit)
                {
                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-primary">
                        <i class="bi bi-pencil-square me-1"></i> Edytuj
                    </a>
                }
                else
                {
                    <button type="button"
                            class="btn btn-outline-secondary"
                            disabled
                            title="Edycja zablokowana">
                        <i class="bi bi-pencil-square me-1"></i> Edytuj
                    </button>
                }

                <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-outline-danger">
                    <i class="bi bi-trash me-1"></i> Usuń
                </a>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Lista
                </a>
            </div>
        </div>

        <div class="news-details-grid">
            <div class="news-details-item">
                <div class="news-details-item__label">Rezerwacja</div>
                <div class="news-details-item__value entity-mono">@(p.Rezerwacja?.Numer ?? "-")</div>

                @if (p.Rezerwacja != null)
                {
                    <div class="mt-2">
                        <a class="btn btn-sm btn-outline-info"
                           asp-controller="Rezerwacja"
                           asp-action="Details"
                           asp-route-id="@p.Rezerwacja.Id">
                            <i class="bi bi-file-earmark-text me-1"></i>Szczegóły rezerwacji
                        </a>
                    </div>
                }
            </div>

            <div class="news-details-item">
                <div class="news-details-item__label">Status rezerwacji</div>
                <div class="news-details-item__value">
                    <span class="entity-badge @statusClass">@status</span>
                </div>
            </div>

            <div class="news-details-item">
                <div class="news-details-item__label">Produkt</div>
                <div class="news-details-item__value">@(p.Produkt?.Kod ?? "-")</div>
                <div class="news-details-item__value news-details-item__value--content">
                    @(p.Produkt?.Nazwa ?? "-")
                </div>

                @if (p.Produkt != null)
                {
                    <div class="mt-2">
                        <a class="btn btn-sm btn-outline-info"
                           asp-controller="Produkt"
                           asp-action="Details"
                           asp-route-id="@p.Produkt.IdProduktu">
                            <i class="bi bi-box-seam me-1"></i>Szczegóły produktu
                        </a>
                    </div>
                }
            </div>

            <div class="news-details-item">
                <div class="news-details-item__label">Lokacja</div>
                <div class="news-details-item__value">@(p.Lokacja?.Kod ?? "(brak)")</div>
                <div class="news-details-item__value news-details-item__value--content">
                    @(p.Lokacja?.Magazyn?.Nazwa ?? (p.Lokacja == null ? "Bez wskazanej lokacji" : "-"))
                </div>

                @if (p.Lokacja != null)
                {
                    <div class="mt-2">
                        <a class="btn btn-sm btn-outline-info"
                           asp-controller="Lokacja"
                           asp-action="Details"
                           asp-route-id="@p.Lokacja.IdLokacji">
                            <i class="bi bi-geo-alt me-1"></i>Szczegóły lokacji
                        </a>
                    </div>
                }
            </div>

            <div class="news-details-item">
                <div class="news-details-item__label">Ilość</div>
                <div class="news-details-item__value">@p.Ilosc.ToString("0.###") @jm</div>
            </div>

            <div class="news-details-item">
                <div class="news-details-item__label">Jednostka miary</div>
                <div class="news-details-item__value">@jm</div>
            </div>
        </div>
    </section>
</div>