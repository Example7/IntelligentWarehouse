@model Interfaces.Magazyn.Dtos.PozycjaRezerwacjiIndexDto

@{
    ViewData["Title"] = "Pozycje rezerwacji";

    var items = Model.Items.ToList();
    var searchTerm = Model.SearchTerm ?? string.Empty;

    var distinctDocs = items.Select(x => x.IdRezerwacji).Distinct().Count();
    var totalQty = items.Sum(x => x.Ilosc);
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon">
                <i class="bi bi-list-ol"></i>
            </span>

            <div>
                <h1 class="news-admin-header__heading mb-1">Pozycje rezerwacji</h1>
                <p class="news-admin-header__subheading mb-0">
                    Lista pozycji rezerwacji z produktem, lokacją i ilością.
                </p>
            </div>
        </div>

        <div class="news-admin-header__stats">
            <div class="news-admin-stat">
                <span class="news-admin-stat__label">Łącznie</span>
                <strong class="news-admin-stat__value">@items.Count</strong>
            </div>

            <div class="news-admin-stat">
                <span class="news-admin-stat__label">Rezerwacje</span>
                <strong class="news-admin-stat__value">@distinctDocs</strong>
            </div>

            <div class="news-admin-stat">
                <span class="news-admin-stat__label">Ilość</span>
                <strong class="news-admin-stat__value">@totalQty.ToString("0.###")</strong>
            </div>
        </div>
    </section>

    <section class="news-admin-toolbar">
        <form method="get" class="news-admin-search" role="search">
            <div class="news-admin-search__input-wrap">
                <i class="bi bi-search news-admin-search__icon"></i>
                <input class="form-control news-admin-search__input"
                       name="searchTerm"
                       value="@searchTerm"
                       placeholder="Szukaj po numerze, produkcie, lokacji lub magazynie..." />
            </div>

            <button class="btn btn-primary news-admin-search__submit" type="submit">
                Szukaj
            </button>

            @if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                <a class="btn btn-outline-secondary news-admin-search__clear" href="@Url.Action("Index")">
                    <i class="bi bi-x-lg"></i>
                </a>
            }
        </form>

        <a class="btn news-admin-toolbar__cta" asp-action="Create">
            <i class="bi bi-plus-circle"></i> Dodaj pozycję
        </a>
    </section>

    @if (!items.Any())
    {
        <section class="news-admin-empty">
            <div class="news-admin-empty__icon">
                <i class="bi bi-list-task"></i>
            </div>
            <h2 class="h4 mb-2">Brak pozycji rezerwacji</h2>
        </section>
    }
    else
    {
        <section class="entity-table-panel">
            <div class="entity-table-wrap">
                <table class="table table-hover align-middle mb-0 entity-table">
                    <thead>
                        <tr>
                            <th>Rezerwacja</th>
                            <th class="text-end">Lp</th>
                            <th>Produkt</th>
                            <th>Lokacja</th>
                            <th class="text-end">Ilość</th>
                            <th class="text-end">Akcje</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in items
                            .OrderBy(x => x.Rezerwacja != null ? x.Rezerwacja.Numer : string.Empty)
                            .ThenBy(x => x.Lp))
                        {
                            var jm = item.Produkt?.DomyslnaJednostka?.Kod ?? "j.m.";
                            var status = item.Rezerwacja?.Status ?? "-";

                            var statusClass =
                                string.Equals(status, "Active", StringComparison.OrdinalIgnoreCase) ? "entity-badge--success" :
                                string.Equals(status, "Draft", StringComparison.OrdinalIgnoreCase) ? "entity-badge--warning" :
                                string.Equals(status, "Completed", StringComparison.OrdinalIgnoreCase) ? "entity-badge--info" :
                                "entity-badge--muted";

                            var editable =
                                !string.Equals(status, "Completed", StringComparison.OrdinalIgnoreCase) &&
                                !string.Equals(status, "Cancelled", StringComparison.OrdinalIgnoreCase) &&
                                !string.Equals(status, "Released", StringComparison.OrdinalIgnoreCase);

                            <tr>
                                <td>
                                    <div class="entity-cell-title">@(item.Rezerwacja?.Numer ?? "-")</div>
                                    <div class="entity-cell-subtitle">
                                        <span class="entity-badge @statusClass">@status</span>
                                    </div>
                                </td>

                                <td class="text-end">@item.Lp</td>

                                <td>
                                    <div class="entity-cell-title">@(item.Produkt?.Kod ?? "-")</div>
                                    <div class="entity-cell-subtitle">
                                        @(item.Produkt?.Nazwa ?? "Brak nazwy")
                                    </div>
                                </td>

                                <td>
                                    <div class="entity-cell-title">@(item.Lokacja?.Kod ?? "(brak)")</div>
                                    <div class="entity-cell-subtitle">
                                        @(item.Lokacja?.Magazyn?.Nazwa ?? (item.Lokacja == null ? "Bez wskazanej lokacji" : "-"))
                                    </div>
                                </td>

                                <td class="text-end">@item.Ilosc.ToString("0.###") @jm</td>

                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        @if (editable)
                                        {
                                            <a class="btn btn-outline-warning" asp-action="Edit" asp-route-id="@item.Id">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <button type="button"
                                                    class="btn btn-outline-secondary"
                                                    disabled
                                                    title="Edycja zablokowana">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                        }

                                        <a class="btn btn-outline-info" asp-action="Details" asp-route-id="@item.Id">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>