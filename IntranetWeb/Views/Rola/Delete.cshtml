@model Data.Data.Magazyn.Rola

@{
    ViewData["Title"] = "Usun role";
}

<div class="news-admin-page">
    <section class="news-admin-header news-admin-header--danger">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon news-admin-header__icon--danger"><i class="bi bi-trash3"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Usun role</h1>
                <p class="news-admin-header__subheading mb-0">Potwierdz usuniecie roli systemowej.</p>
            </div>
        </div>
    </section>
    <section class="news-delete-panel">
        <div class="news-delete-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>Usuniecie roli</strong>
                <div>Operacja moze byc zablokowana, jesli rola jest przypisana do uzytkownikow.</div>
            </div>
        </div>
        <div class="news-details-grid">
            <div class="news-details-item news-details-item--full"><div class="news-details-item__label">Nazwa</div><div class="news-details-item__value">@Model.Nazwa</div></div>
        </div>
        <form asp-action="Delete" method="post" class="news-form-actions">
            <input type="hidden" asp-for="IdRoli" />
            <button type="submit" class="btn btn-danger news-form-actions__primary"><i class="bi bi-trash3-fill"></i> Usun role</button>
            <a asp-action="Details" asp-route-id="@Model.IdRoli" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegoly</a>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Anuluj</a>
        </form>
    </section>
</div>
