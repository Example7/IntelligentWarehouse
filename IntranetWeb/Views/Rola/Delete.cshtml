@model Interfaces.Magazyn.Dtos.RolaDeleteDto

@{
    ViewData["Title"] = "Usuń rolę";
    var role = Model.Rola;
}

<div class="news-admin-page">
    <section class="news-admin-header news-admin-header--danger">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon news-admin-header__icon--danger"><i class="bi bi-trash3"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Usuń rolę</h1>
                <p class="news-admin-header__subheading mb-0">Potwierdź usunięcie roli systemowej.</p>
            </div>
        </div>
    </section>
    <section class="news-delete-panel">
        <div class="news-delete-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>Usunięcie roli</strong>
                <div>Operacja jest blokowana, jeśli rola jest przypisana do użytkowników.</div>
            </div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation mt-3 mb-0" role="alert"></div>
        }

        <div class="news-details-grid">
            <div class="news-details-item"><div class="news-details-item__label">Nazwa</div><div class="news-details-item__value">@role.Nazwa</div></div>
            <div class="news-details-item"><div class="news-details-item__label">Przypisania</div><div class="news-details-item__value">@Model.LiczbaPrzypisan</div></div>
        </div>
        <form asp-action="Delete" method="post" class="news-form-actions">
            <input type="hidden" name="id" value="@role.IdRoli" />
            <button type="submit" class="btn btn-danger news-form-actions__primary" disabled="@(!Model.CzyMoznaUsunac)"><i class="bi bi-trash3-fill"></i> Usuń rolę</button>
            <a asp-action="Details" asp-route-id="@role.IdRoli" class="btn btn-outline-info"><i class="bi bi-eye"></i> Szczegóły</a>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Anuluj</a>
        </form>
    </section>
</div>