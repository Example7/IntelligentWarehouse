@model Data.Data.Magazyn.Rola

@{
    ViewData["Title"] = "Szczegoly roli";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-shield-lock"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Szczegoly roli</h1>
                <p class="news-admin-header__subheading mb-0">Podglad danych roli systemowej.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">ID</span><strong class="news-admin-stat__value">@Model.IdRoli</strong></div>
        </div>
    </section>
    <section class="news-details-panel">
        <div class="news-details-panel__header">
            <h2 class="news-details-panel__title">@Model.Nazwa</h2>
            <div class="news-details-panel__actions">
                <a asp-action="Edit" asp-route-id="@Model.IdRoli" class="btn btn-primary"><i class="bi bi-pencil-square me-1"></i> Edytuj</a>
                <a asp-action="Delete" asp-route-id="@Model.IdRoli" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i> Usun</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Lista</a>
            </div>
        </div>
        <div class="news-details-grid">
            <div class="news-details-item news-details-item--full"><div class="news-details-item__label">Nazwa</div><div class="news-details-item__value">@Model.Nazwa</div></div>
        </div>
    </section>
</div>
