@model Interfaces.Magazyn.Dtos.PozycjaInwentaryzacjiIndexDto

@{
    ViewData["Title"] = "Pozycje inwentaryzacji";
    var items = Model.Items.ToList();
    var searchTerm = Model.SearchTerm ?? string.Empty;
    var distinctDocs = items.Select(x => x.IdDokumentu).Distinct().Count();
    var sumExpected = items.Sum(x => x.IloscOczekiwana);
    var sumCounted = items.Sum(x => x.IloscPoliczona);
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-list-ol"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Pozycje inwentaryzacji</h1>
                <p class="news-admin-header__subheading mb-0">Lista pozycji inwentaryzacji z ilościami oczekiwanymi i policzonymi.</p>
            </div>
        </div>
        <div class="news-admin-header__stats">
            <div class="news-admin-stat"><span class="news-admin-stat__label">Lacznie</span><strong class="news-admin-stat__value">@items.Count</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Dokumenty</span><strong class="news-admin-stat__value">@distinctDocs</strong></div>
            <div class="news-admin-stat"><span class="news-admin-stat__label">Policzona</span><strong class="news-admin-stat__value">@sumCounted.ToString("0.###")</strong></div>
        </div>
    </section>

    <section class="news-admin-toolbar">
        <form method="get" class="news-admin-search" role="search" aria-label="Wyszukiwanie pozycji inwentaryzacji">
            <div class="news-admin-search__input-wrap">
                <i class="bi bi-search news-admin-search__icon"></i>
                <input class="form-control news-admin-search__input" name="searchTerm" value="@searchTerm" placeholder="Szukaj po numerze, produkcie, lokacji lub magazynie..." />
            </div>
            <button class="btn btn-primary news-admin-search__submit" type="submit">Szukaj</button>
            @if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                <a class="btn btn-outline-secondary news-admin-search__clear" href="@Url.Action("Index")"><i class="bi bi-x-lg"></i></a>
            }
        </form>
        <a class="btn news-admin-toolbar__cta" asp-action="Create"><i class="bi bi-plus-circle"></i> Dodaj pozycje</a>
    </section>

    @if (!items.Any())
    {
        <section class="news-admin-empty"><div class="news-admin-empty__icon"><i class="bi bi-list-task"></i></div><h2 class="h4 mb-2">Brak pozycji inwentaryzacji</h2></section>
    }
    else
    {
        <section class="entity-table-panel">
            <div class="entity-table-wrap">
                <table class="table table-hover align-middle mb-0 entity-table">
                    <thead>
                        <tr>
                            <th>Dokument</th>
                            <th class="text-end">Lp</th>
                            <th>Produkt</th>
                            <th>Lokacja</th>
                            <th class="text-end">Oczekiwana</th>
                            <th class="text-end">Policzona</th>
                            <th class="text-end">Różnica</th>
                            <th class="text-end">Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in items.OrderBy(x => x.Dokument != null ? x.Dokument.Numer : string.Empty).ThenBy(x => x.Lp))
                    {
                        var jm = item.Produkt?.DomyslnaJednostka?.Kod ?? "j.m.";
                        var isDraft = string.Equals(item.Dokument?.Status, "Draft", StringComparison.OrdinalIgnoreCase);
                        var statusClass = isDraft ? "entity-badge--warning" : string.Equals(item.Dokument?.Status, "Closed", StringComparison.OrdinalIgnoreCase) ? "entity-badge--success" : "entity-badge--muted";
                        var diff = item.IloscPoliczona - item.IloscOczekiwana;
                        var diffClass = diff > 0 ? "text-success" : diff < 0 ? "text-danger" : "text-muted";
                        <tr>
                            <td>
                                <div class="entity-cell-title">@(item.Dokument?.Numer ?? "-")</div>
                                <div class="entity-cell-subtitle"><span class="entity-badge @statusClass">@(item.Dokument?.Status ?? "-")</span></div>
                            </td>
                            <td class="text-end">@item.Lp</td>
                            <td><div class="entity-cell-title">@(item.Produkt?.Kod ?? "-")</div><div class="entity-cell-subtitle">@(item.Produkt?.Nazwa ?? "Brak nazwy")</div></td>
                            <td><div class="entity-cell-title">@(item.Lokacja?.Kod ?? "-")</div><div class="entity-cell-subtitle">@(item.Lokacja?.Magazyn?.Nazwa ?? "-")</div></td>
                            <td class="text-end">@item.IloscOczekiwana.ToString("0.###") @jm</td>
                            <td class="text-end">@item.IloscPoliczona.ToString("0.###") @jm</td>
                            <td class="text-end"><span class="@diffClass">@diff.ToString("+0.###;-0.###;0") @jm</span></td>
                            <td class="text-end"><div class="btn-group btn-group-sm">
                                @if (isDraft) { <a class="btn btn-outline-warning" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil"></i></a> }
                                else { <button type="button" class="btn btn-outline-secondary" disabled title="Edycja tylko dla Draft"><i class="bi bi-pencil"></i></button> }
                                <a class="btn btn-outline-info" asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye"></i></a>
                                <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id"><i class="bi bi-trash"></i></a>
                            </div></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>
