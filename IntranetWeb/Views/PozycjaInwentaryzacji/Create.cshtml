@model Data.Data.Magazyn.PozycjaInwentaryzacji

@{
    ViewData["Title"] = "Dodaj pozycję inwentaryzacji";
}

<div class="news-admin-page">
    <section class="news-admin-header">
        <div class="news-admin-header__title">
            <span class="news-admin-header__icon"><i class="bi bi-plus-square"></i></span>
            <div>
                <h1 class="news-admin-header__heading mb-1">Dodaj pozycję inwentaryzacji</h1>
                <p class="news-admin-header__subheading mb-0">Dodaj wiersz liczenia z produktem, lokacją i ilościami.</p>
            </div>
        </div>
    </section>

    <section class="news-editor-panel">
        <div class="news-editor-panel__header">
            <h2 class="h5 mb-1">Dane pozycji</h2>
            <p class="text-muted mb-0">Wybierz dokument inwentaryzacji (Draft), produkt i lokację oraz podaj ilosci.</p>
        </div>

        <form asp-action="Create" method="post" class="news-editor-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger news-form-validation" role="alert"></div>

            <div class="news-form-grid">
                <div class="news-form-field">
                    <label asp-for="IdDokumentu" class="form-label news-form-label">Dokument inwentaryzacji</label>
                    <select asp-for="IdDokumentu" class="form-select news-form-control" asp-items="ViewBag.IdDokumentu"></select>
                    <span asp-validation-for="IdDokumentu" class="text-danger small"></span>
                </div>

                <div class="news-form-field">
                    <label asp-for="Lp" class="form-label news-form-label">Lp</label>
                    <input asp-for="Lp" class="form-control news-form-control" min="1" />
                    <div class="form-text">Domyślnie ustawiany jest kolejny numer pozycji dla wybranego dokumentu.</div>
                    <span asp-validation-for="Lp" class="text-danger small"></span>
                </div>

                <div class="news-form-field">
                    <label asp-for="IdProduktu" class="form-label news-form-label">Produkt</label>
                    <select asp-for="IdProduktu" class="form-select news-form-control" asp-items="ViewBag.IdProduktu"></select>
                    <span asp-validation-for="IdProduktu" class="text-danger small"></span>
                </div>

                <div class="news-form-field">
                    <label asp-for="IdLokacji" class="form-label news-form-label">Lokacja</label>
                    <select asp-for="IdLokacji" class="form-select news-form-control" asp-items="ViewBag.IdLokacji"></select>
                    <span asp-validation-for="IdLokacji" class="text-danger small"></span>
                </div>

                <div class="news-form-field">
                    <label asp-for="IloscOczekiwana" class="form-label news-form-label">Ilość oczekiwana</label>
                    <input asp-for="IloscOczekiwana" class="form-control news-form-control" step="0.001" value="@(Model.IloscOczekiwana == 0 ? "" : Model.IloscOczekiwana.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture))" placeholder="np. 10" />
                    <div class="form-text">Jednostka: <span id="invItemUomHintExpected">j.m.</span></div>
                    <span asp-validation-for="IloscOczekiwana" class="text-danger small"></span>
                </div>

                <div class="news-form-field">
                    <label asp-for="IloscPoliczona" class="form-label news-form-label">Ilość policzona</label>
                    <input asp-for="IloscPoliczona" class="form-control news-form-control" step="0.001" value="@(Model.IloscPoliczona == 0 ? "" : Model.IloscPoliczona.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture))" placeholder="np. 10" />
                    <div class="form-text">Jednostka: <span id="invItemUomHintCounted">j.m.</span></div>
                    <span asp-validation-for="IloscPoliczona" class="text-danger small"></span>
                </div>
            </div>

            <div class="news-form-actions">
                <button type="submit" class="btn btn-primary news-form-actions__primary"><i class="bi bi-check2-circle"></i> Zapisz pozycję</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Wróć do listy</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (() => {
            const docSelect = document.getElementById('IdDokumentu');
            const lpInput = document.getElementById('Lp');
            const productSelect = document.getElementById('IdProduktu');
            const locationSelect = document.getElementById('IdLokacji');
            const expectedInput = document.getElementById('IloscOczekiwana');
            const uomHintExpected = document.getElementById('invItemUomHintExpected');
            const uomHintCounted = document.getElementById('invItemUomHintCounted');
            const nextLpByDocument = @Html.Raw((string?)ViewData["NextLpByDocumentJson"] ?? "{}");
            const productUomMap = @Html.Raw((string?)ViewData["ProductUomMapJson"] ?? "{}");
            const stockQtyMap = @Html.Raw((string?)ViewData["StockQtyMapJson"] ?? "{}");

            const applyNextLp = () => {
                const docId = Number.parseInt(docSelect?.value || '', 10);
                const nextLp = nextLpByDocument[docId];
                if (typeof nextLp === 'number' && nextLp > 0 && lpInput) {
                    lpInput.value = String(nextLp);
                }
            };

            const applyUom = () => {
                const pid = Number.parseInt(productSelect?.value || '', 10);
                const uom = productUomMap[pid] || 'j.m.';
                if (uomHintExpected) uomHintExpected.textContent = uom;
                if (uomHintCounted) uomHintCounted.textContent = uom;
            };

            const applyExpectedQtyFromStock = () => {
                if (!expectedInput) return;
                const pid = Number.parseInt(productSelect?.value || '', 10);
                const lid = Number.parseInt(locationSelect?.value || '', 10);
                if (!Number.isInteger(pid) || !Number.isInteger(lid)) {
                    return;
                }
                const key = `${pid}:${lid}`;
                const qty = stockQtyMap[key];
                if (typeof qty === 'number') {
                    expectedInput.value = Number(qty).toString();
                    return;
                }
                expectedInput.value = '0';
            };

            docSelect?.addEventListener('change', applyNextLp);
            productSelect?.addEventListener('change', applyUom);
            productSelect?.addEventListener('change', applyExpectedQtyFromStock);
            locationSelect?.addEventListener('change', applyExpectedQtyFromStock);

            if (!lpInput?.value || lpInput.value === '0' || lpInput.value === '1') {
                applyNextLp();
            }
            applyUom();
            applyExpectedQtyFromStock();
        })();
    </script>
}
