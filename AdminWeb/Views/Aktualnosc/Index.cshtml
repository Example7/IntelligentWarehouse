@model IEnumerable<Data.Data.CMS.Aktualnosc>

<div class="container align-content-center">
    <div class="container text-center">
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-12 col-md-6 col-lg-3">
                    <h2>@item.Nazwa</h2>
                    <p>
                        @item.Tresc
                    </p>
                    <a class="btn btn-outline-primary" asp-area="" asp-controller="Aktualnosc" asp-action="Index" asp-route-id="@item.IdAktualnosci">@item.TytulLinku</a>
                </div>
            }
        </div>
    </div>
</div>
