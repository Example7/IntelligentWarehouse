@model IEnumerable<Data.Data.CMS.Aktualnosc>

<div class="container align-content-center">
    <div class="container text-center">
        <div class="row">
            @foreach(var aktualnosc in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <h2>@aktualnosc.TytulLinku</h2>
                    <p>@aktualnosc.Tresc</p>
                    <button type="button" class="btn btn-primary">Szczegoły</button>
                </div>
            }
        </div>
    </div>
</div>

